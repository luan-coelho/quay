// Quay main window — Lanes-inspired three-pane layout.
//
// Layout:
//   ┌──────────┬──────────────────┬─────────────────────────────┐
//   │ title bar (36px)                                            │
//   ├──────────┼──────────────────┼─────────────────────────────┤
//   │ sidebar  │  task list       │  task detail / terminal      │
//   │ 200px    │  flex            │  flex (2x)                   │
//   │          │                  │                              │
//   └──────────┴──────────────────┴─────────────────────────────┘
//
// All colours, paddings and dimensions are taken straight from the Lanes
// reference markup the user provided so the visual language stays close.

import { ScrollView, TextEdit, LineEdit } from "std-widgets.slint";

// ── Design tokens ───────────────────────────────────────────────────────────
global Tokens {
    out property <color> bg-base: #1e2024;
    out property <color> bg-section-header: #222428;
    out property <color> bg-tab-active: #202329;
    out property <color> bg-hover: rgba(255, 255, 255, 5%);
    out property <color> bg-card-selected: rgba(255, 255, 255, 4%);

    out property <color> border-soft: rgba(150, 160, 180, 14%);
    out property <color> border-very-soft: rgba(150, 160, 180, 7%);

    out property <color> text-primary: #e6e8eb;
    out property <color> text-secondary: #a7afb8;
    out property <color> text-tertiary: rgba(167, 175, 184, 50%);
    out property <color> text-muted: rgba(167, 175, 184, 35%);

    out property <color> kind-enhancement: #10b981;
    out property <color> kind-feature: #60a5fa;
    out property <color> kind-bug: #f87171;
    out property <color> kind-done: #34d399;

    out property <color> accent-warm: #c87533;
}

// ── Data structures ─────────────────────────────────────────────────────────
export struct LabelPillData {
    id: string,
    name: string,
    // RGB components 0-255. Slint's `string` → `brush` conversion is not
    // supported, so we pass the colour as separate ints and build the
    // brush with `rgb(r, g, b)` at the call site.
    color-r: int,
    color-g: int,
    color-b: int,
}

export struct QuickActionRowData {
    id: string,
    name: string,
    kind: string,        // "claude" | "shell"
    body: string,
    shortcut: string,    // "⌘⌥1" .. "⌘⌥9" (only first 9 have shortcuts)
}

export struct ProcessRowData {
    pid: int,
    name: string,
    cmdline: string,
    class: string,       // "tracked" | "external" | "orphan"
}

export struct FileEntryData {
    name: string,
    /// Absolute path — passed back in the click callback so Rust can
    /// figure out whether to navigate into a directory or shell out to
    /// $EDITOR for a file.
    path: string,
    kind: string,        // "directory" | "file" | "parent"
}

export struct TaskCardData {
    id: string,           // UUID for callbacks
    display-id: int,      // sequential numeric ID for display (#1, #2, …)
    title: string,
    kind: string,         // "enhancement" | "feature" | "bug"
    running: bool,
    // Whether the task's git worktree has uncommitted or untracked changes.
    // Populated from `git::status::read_status` during refresh_kanban.
    dirty: bool,
    // Labels attached to this task, rendered as small pills on the card.
    labels: [LabelPillData],
    // Number of unresolved prerequisite tasks. Non-zero → blocked badge.
    blocked-count: int,
}

export struct DiffFileData {
    path: string,
    status: string,       // "M" | "A" | "D" | "R" | "?" | "T"
    additions: int,
    deletions: int,
    patch: string,
}

export struct CommitEntryData {
    sha-short: string,
    summary: string,
    author-name: string,
    /// Pre-formatted timestamp, e.g. "3 minutes ago".
    timestamp: string,
}

export struct MenuItemData {
    id: string,
    label: string,
    glyph: string,        // 1-char unicode icon
    shortcut: string,
}

export struct ProjectData {
    id: string,
    name: string,
}

// ── Helper components ───────────────────────────────────────────────────────

component KindDiamond inherits Rectangle {
    in property <string> kind;
    width: 12px;
    height: 12px;
    background: transparent;

    Text {
        text: "◆";
        color: kind == "enhancement" ? Tokens.kind-enhancement
              : kind == "feature" ? Tokens.kind-feature
              : kind == "bug" ? Tokens.kind-bug
              : Tokens.text-tertiary;
        font-size: 11px;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

component KindChip inherits Rectangle {
    in property <string> kind;
    height: 16px;
    width: chip-content.preferred-width + 14px;
    border-radius: 8px;
    border-width: 1px;
    border-color: Tokens.border-soft;
    background: transparent;

    chip-content := HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 5px;
        alignment: center;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 3px;
                background: kind == "enhancement" ? Tokens.kind-enhancement
                           : kind == "feature" ? Tokens.kind-feature
                           : kind == "bug" ? Tokens.kind-bug
                           : Tokens.text-tertiary;
            }
        }
        Text {
            text: kind == "enhancement" ? "Enhancement"
                 : kind == "feature" ? "Feature"
                 : kind == "bug" ? "Bug"
                 : kind;
            color: Tokens.text-secondary;
            font-size: 9px;
            vertical-alignment: center;
        }
    }
}

component MenuRow inherits Rectangle {
    in property <MenuItemData> item;
    callback clicked();

    height: 26px;
    border-radius: 6px;
    background: hover.has-hover ? Tokens.bg-hover : transparent;

    hover := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 12px;
        alignment: start;

        VerticalLayout {
            alignment: center;
            Text {
                text: item.glyph;
                color: Tokens.text-secondary;
                font-size: 11px;
            }
        }
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: item.label;
                color: Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: item.shortcut;
                color: Tokens.text-muted;
                font-size: 10px;
                vertical-alignment: center;
            }
        }
    }
}

component ProjectRow inherits Rectangle {
    in property <ProjectData> project;
    callback clicked();

    height: 26px;
    border-radius: 6px;
    background: ta.has-hover ? Tokens.bg-hover : transparent;

    ta := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 12px;
        alignment: start;
        VerticalLayout {
            alignment: center;
            Text {
                text: "▸";
                color: Tokens.text-tertiary;
                font-size: 11px;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: project.name;
                color: Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}

component FilterChip inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked();

    height: 24px;
    width: chip-row.preferred-width + 16px;
    border-radius: 4px;
    border-width: 1px;
    border-color: Tokens.border-soft;
    background: selected ? Tokens.bg-tab-active : transparent;

    TouchArea { clicked => { root.clicked(); } }

    chip-row := HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        alignment: center;
        VerticalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: selected ? Tokens.text-primary : Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: "×";
                color: Tokens.text-tertiary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}

component SectionHeader inherits Rectangle {
    in property <string> label;
    in property <int> count;
    height: 28px;
    background: Tokens.bg-section-header;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        alignment: start;

        VerticalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: count-text.preferred-width + 8px;
                height: 14px;
                border-radius: 7px;
                background: rgba(167, 175, 184, 10%);
                count-text := Text {
                    text: root.count;
                    color: Tokens.text-tertiary;
                    font-size: 9px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}

component CardRow inherits Rectangle {
    in property <TaskCardData> task;
    in property <bool> selected;
    callback clicked();
    callback move-back();
    callback move-forward();

    height: 30px;
    background: selected ? Tokens.bg-card-selected
              : ta.has-hover ? Tokens.bg-hover
              : transparent;

    Rectangle {
        // Top divider line.
        x: 0; y: 0; width: parent.width; height: 1px;
        background: Tokens.border-very-soft;
    }

    ta := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 8px;
        spacing: 8px;
        alignment: start;

        // Display ID
        VerticalLayout {
            alignment: center;
            Text {
                text: "#" + task.display-id;
                color: Tokens.text-tertiary;
                font-size: 10px;
                font-family: "JetBrains Mono";
                vertical-alignment: center;
            }
        }

        // Diamond
        VerticalLayout {
            alignment: center;
            KindDiamond { kind: task.kind; }
        }

        // Title (stretches)
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: task.title;
                color: selected ? Tokens.text-primary : Tokens.text-secondary;
                font-size: 11px;
                overflow: elide;
                vertical-alignment: center;
            }
        }

        // Tag chip
        // Label pills — one small coloured pill per attached label.
        // Rendered in a horizontal strip before the KindChip; wraps
        // gracefully if a card has many labels by just truncating
        // (Slint HorizontalLayout will push later items off-screen,
        // which is fine for 1-3 labels per card).
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                spacing: 3px;
                for label in task.labels: Rectangle {
                    width: label-name.preferred-width + 10px;
                    height: 14px;
                    border-radius: 3px;
                    background: rgb(label.color-r, label.color-g, label.color-b);
                    label-name := Text {
                        text: label.name;
                        color: #0b0d11;
                        font-size: 8px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
            }
        }

        VerticalLayout {
            alignment: center;
            KindChip { kind: task.kind; }
        }

        // Blocked badge — small lock icon + count if the task has any
        // unresolved dependencies.
        VerticalLayout {
            alignment: center;
            visible: task.blocked-count > 0;
            Rectangle {
                width: blocked-row.preferred-width + 10px;
                height: 14px;
                border-radius: 7px;
                background: rgba(248, 113, 113, 15%);
                border-width: 1px;
                border-color: rgba(248, 113, 113, 40%);
                blocked-row := HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 5px;
                    spacing: 3px;
                    alignment: center;
                    Text {
                        text: "⊘";
                        color: Tokens.kind-bug;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: task.blocked-count;
                        color: Tokens.kind-bug;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Dirty dot — small amber circle if the task's worktree has
        // uncommitted changes. Shown to the left of the running dot so
        // the two signals read naturally (uncommitted → running).
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 3px;
                background: task.dirty ? #f5b54e : transparent;
            }
        }

        // Status dot (running indicator)
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: task.running ? Tokens.kind-enhancement : transparent;
                border-width: 1px;
                border-color: task.running ? Tokens.kind-enhancement : Tokens.text-muted;
            }
        }

        // Move arrows — visible only on hover/selected, very subtle.
        Rectangle {
            width: 24px;
            background: transparent;
            visible: root.selected || ta.has-hover;

            HorizontalLayout {
                spacing: 0px;
                alignment: center;
                TouchArea {
                    width: 12px;
                    clicked => { root.move-back(); }
                    Text { text: "‹"; color: Tokens.text-tertiary; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                }
                TouchArea {
                    width: 12px;
                    clicked => { root.move-forward(); }
                    Text { text: "›"; color: Tokens.text-tertiary; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }
}

component RightTab inherits Rectangle {
    in property <string> label;
    in property <string> glyph;
    in property <bool> selected;
    callback clicked();

    height: 24px;
    width: row.preferred-width + 16px;
    border-radius: 6px;
    border-width: 1px;
    border-color: Tokens.border-soft;
    background: selected ? Tokens.bg-tab-active : transparent;

    TouchArea { clicked => { root.clicked(); } }

    row := HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        alignment: center;

        VerticalLayout {
            alignment: center;
            Text {
                text: root.glyph;
                color: selected ? Tokens.text-primary : Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: selected ? Tokens.text-primary : Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}

// ── Main window ─────────────────────────────────────────────────────────────

export component MainWindow inherits Window {
    title: "Quay";
    background: Tokens.bg-base;

    // Terminal pixel buffer + dimensions (driven from Rust).
    in property <image> frame;
    in property <int> cell-w: 10;
    in property <int> cell-h: 22;
    in property <int> cols: 100;
    in property <int> rows: 30;

    // Selection / context.
    in property <string> active-task-id: "";
    in property <string> active-task-display: "";
    in property <string> active-task-kind: "feature";
    in-out property <string> active-task-title: "";
    in-out property <string> active-task-description: "";
    in-out property <string> active-task-instructions: "";
    // Session state for the active task: one of idle/busy/awaiting/stopped/exited/error.
    in property <string> active-task-session-state: "idle";

    // Kanban data — one VecModel per column. Phase 2 expanded this from
    // 3 combined sections to 6 (matching Lanes' workflow).
    in property <[TaskCardData]> tasks-backlog;
    in property <[TaskCardData]> tasks-planning;
    in property <[TaskCardData]> tasks-implementation;
    in property <[TaskCardData]> tasks-review;
    in property <[TaskCardData]> tasks-done;
    in property <[TaskCardData]> tasks-misc;

    in property <[MenuItemData]> menu-items;
    in property <[ProjectData]> projects;

    // All labels available in the system, rendered as filter chips at
    // the top of the task list. Clicking one sets `filter-label-id`;
    // clicking it again (or the "All" chip) clears the filter.
    in property <[LabelPillData]> all-labels;
    in-out property <string> filter-label-id: "";

    // Settings modal state + content.
    in-out property <bool> settings-open: false;
    in-out property <string> settings-default-base-branch: "main";
    in property <[QuickActionRowData]> settings-quick-actions;
    in property <[ProcessRowData]> settings-processes;

    // File browser state for the Files tab (Phase 6).
    in property <[FileEntryData]> file-entries;
    in-out property <string> file-current-dir: "";

    // Editor state (Phase 7). When `editor-open` is true, the Files tab
    // shows the editor surface instead of the directory listing.
    in-out property <bool> editor-open: false;
    in-out property <string> editor-file-path: "";
    in-out property <string> editor-file-content: "";
    in property <string> editor-syntax-name: "Plain Text";
    in property <bool> editor-file-dirty: false;

    // Git Changes tab data — refreshed ~1×/s while the tab is open.
    in property <[DiffFileData]> git-diff-files;
    in property <[CommitEntryData]> git-commit-log;

    // Right pane tab selection.
    in-out property <string> active-right-tab: "terminal";

    callback select-task(string);
    callback move-task-back(string);
    callback move-task-forward(string);
    callback create-task();
    callback title-changed(string);
    callback description-changed(string);
    callback instructions-changed(string);
    callback start-plan(string);
    callback start-implement(string);
    callback filter-changed(string);  // Phase 4: fires when filter-label-id changes
    callback toggle-settings();
    callback settings-base-branch-changed(string);
    callback process-kill(int);        // SIGTERM
    callback process-force-kill(int);  // SIGKILL
    callback refresh-processes();
    callback file-entry-clicked(string, string);   // path, kind
    callback editor-content-changed(string);
    callback editor-save();
    callback editor-close();
    callback key-pressed(string, bool, bool, bool);

    // Layout constants.
    property <length> sidebar-w: 200px;
    property <length> middle-w: 400px;
    property <length> title-bar-h: 36px;
    property <length> tab-strip-h: 32px;
    property <length> term-w: root.cols * root.cell-w * 1px;
    property <length> term-h: root.rows * root.cell-h * 1px;
    property <length> right-pad-h: 18px;
    property <length> right-pad-v: 14px;

    preferred-width: sidebar-w + middle-w + term-w + right-pad-h * 2 + 2px;
    preferred-height: title-bar-h + tab-strip-h + term-h + right-pad-v * 2 + 14px;
    min-width: sidebar-w + middle-w + term-w + right-pad-h * 2 + 2px;
    min-height: title-bar-h + tab-strip-h + term-h + right-pad-v * 2 + 14px;

    init => { focus-scope.focus(); }

    // ── Title bar ────────────────────────────────────────────────────────────
    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: title-bar-h;
        background: Tokens.bg-base;

        Rectangle {
            x: 0; y: parent.height - 1px;
            width: parent.width; height: 1px;
            background: Tokens.border-soft;
        }

        // Traffic-light styled trio (decorative — purely visual).
        HorizontalLayout {
            x: 12px;
            y: (parent.height - self.preferred-height) / 2;
            spacing: 6px;
            Rectangle { width: 11px; height: 11px; border-radius: 5.5px; background: #ff5f57; }
            Rectangle { width: 11px; height: 11px; border-radius: 5.5px; background: #febc2e; }
            Rectangle { width: 11px; height: 11px; border-radius: 5.5px; background: #28c840; }
        }

        // Centered app name.
        Text {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            text: "Quay";
            color: Tokens.text-tertiary;
            font-size: 11px;
            font-weight: 600;
        }

        // Active task display id on the right.
        Text {
            x: parent.width - self.width - 18px;
            y: (parent.height - self.height) / 2;
            text: root.active-task-display;
            color: Tokens.text-secondary;
            font-size: 11px;
        }
    }

    // ── Sidebar ──────────────────────────────────────────────────────────────
    Rectangle {
        x: 0;
        y: title-bar-h;
        width: sidebar-w;
        height: parent.height - title-bar-h;
        background: Tokens.bg-base;

        // Right divider.
        Rectangle {
            x: parent.width - 1px;
            y: 0;
            width: 1px;
            height: parent.height;
            background: Tokens.border-soft;
        }

        VerticalLayout {
            padding: 8px;
            padding-top: 12px;
            spacing: 16px;

            // Menu items.
            VerticalLayout {
                spacing: 2px;
                for item in root.menu-items: MenuRow {
                    item: item;
                    clicked => {
                        if (item.id == "new-task") { root.create-task(); }
                        if (item.id == "configure") { root.toggle-settings(); }
                        if (item.id == "sessions") { root.toggle-settings(); }
                    }
                }
            }

            // Projects section.
            VerticalLayout {
                spacing: 4px;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    height: 22px;
                    spacing: 0px;
                    alignment: start;

                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        Text {
                            text: "Projects";
                            color: Tokens.text-secondary;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "+";
                            color: Tokens.text-tertiary;
                            font-size: 12px;
                            vertical-alignment: center;
                        }
                    }
                }

                for project in root.projects: ProjectRow {
                    project: project;
                }
            }
        }
    }

    // ── Middle pane: task list ──────────────────────────────────────────────
    Rectangle {
        x: sidebar-w;
        y: title-bar-h;
        width: middle-w;
        height: parent.height - title-bar-h;
        background: Tokens.bg-base;

        Rectangle {
            x: parent.width - 1px;
            y: 0;
            width: 1px;
            height: parent.height;
            background: Tokens.border-soft;
        }

        VerticalLayout {
            spacing: 0px;

            // Filter chips.
            Rectangle {
                height: tab-strip-h;
                background: Tokens.bg-base;

                Rectangle {
                    x: 0; y: parent.height - 1px;
                    width: parent.width; height: 1px;
                    background: Tokens.border-soft;
                }

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 4px;
                    alignment: start;

                    VerticalLayout {
                        alignment: end;
                        FilterChip {
                            label: "All";
                            selected: root.filter-label-id == "";
                            clicked => {
                                root.filter-label-id = "";
                                root.filter-changed("");
                            }
                        }
                    }
                    for lbl in root.all-labels: VerticalLayout {
                        alignment: end;
                        FilterChip {
                            label: lbl.name;
                            selected: root.filter-label-id == lbl.id;
                            clicked => {
                                if root.filter-label-id == lbl.id {
                                    root.filter-label-id = "";
                                    root.filter-changed("");
                                } else {
                                    root.filter-label-id = lbl.id;
                                    root.filter-changed(lbl.id);
                                }
                            }
                        }
                    }
                }
            }

            // Scrollable task list.
            ScrollView {
                vertical-scrollbar-policy: as-needed;

                VerticalLayout {
                    spacing: 0px;

                    // BACKLOG
                    SectionHeader { label: "Backlog"; count: root.tasks-backlog.length; }
                    for task in root.tasks-backlog: CardRow {
                        task: task;
                        selected: task.id == root.active-task-id;
                        clicked => { root.select-task(task.id); }
                        move-back => { root.move-task-back(task.id); }
                        move-forward => { root.move-task-forward(task.id); }
                    }

                    // PLANNING
                    SectionHeader { label: "Planning"; count: root.tasks-planning.length; }
                    for task in root.tasks-planning: CardRow {
                        task: task;
                        selected: task.id == root.active-task-id;
                        clicked => { root.select-task(task.id); }
                        move-back => { root.move-task-back(task.id); }
                        move-forward => { root.move-task-forward(task.id); }
                    }

                    // IMPLEMENTATION
                    SectionHeader { label: "Implementation"; count: root.tasks-implementation.length; }
                    for task in root.tasks-implementation: CardRow {
                        task: task;
                        selected: task.id == root.active-task-id;
                        clicked => { root.select-task(task.id); }
                        move-back => { root.move-task-back(task.id); }
                        move-forward => { root.move-task-forward(task.id); }
                    }

                    // REVIEW
                    SectionHeader { label: "Review"; count: root.tasks-review.length; }
                    for task in root.tasks-review: CardRow {
                        task: task;
                        selected: task.id == root.active-task-id;
                        clicked => { root.select-task(task.id); }
                        move-back => { root.move-task-back(task.id); }
                        move-forward => { root.move-task-forward(task.id); }
                    }

                    // DONE
                    SectionHeader { label: "Done"; count: root.tasks-done.length; }
                    for task in root.tasks-done: CardRow {
                        task: task;
                        selected: task.id == root.active-task-id;
                        clicked => { root.select-task(task.id); }
                        move-back => { root.move-task-back(task.id); }
                        move-forward => { root.move-task-forward(task.id); }
                    }

                    // MISC — sits outside the linear workflow.
                    SectionHeader { label: "Misc"; count: root.tasks-misc.length; }
                    for task in root.tasks-misc: CardRow {
                        task: task;
                        selected: task.id == root.active-task-id;
                        clicked => { root.select-task(task.id); }
                        move-back => { root.move-task-back(task.id); }
                        move-forward => { root.move-task-forward(task.id); }
                    }
                }
            }
        }
    }

    // ── Right pane: task detail / terminal ──────────────────────────────────
    Rectangle {
        x: sidebar-w + middle-w;
        y: title-bar-h;
        width: parent.width - sidebar-w - middle-w;
        height: parent.height - title-bar-h;
        background: Tokens.bg-base;

        // Tab strip
        Rectangle {
            x: 0; y: 0;
            width: parent.width;
            height: tab-strip-h;
            background: Tokens.bg-base;

            Rectangle {
                x: 0; y: parent.height - 1px;
                width: parent.width; height: 1px;
                background: Tokens.border-soft;
            }

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 4px;
                alignment: start;

                VerticalLayout { alignment: end;
                    RightTab { label: "Terminal"; glyph: "▶"; selected: root.active-right-tab == "terminal"; clicked => { root.active-right-tab = "terminal"; } }
                }
                VerticalLayout { alignment: end;
                    RightTab { label: "Description"; glyph: "≡"; selected: root.active-right-tab == "description"; clicked => { root.active-right-tab = "description"; } }
                }
                VerticalLayout { alignment: end;
                    RightTab { label: "Git Changes"; glyph: "⎇"; selected: root.active-right-tab == "git"; clicked => { root.active-right-tab = "git"; } }
                }
                VerticalLayout { alignment: end;
                    RightTab { label: "Files"; glyph: "▤"; selected: root.active-right-tab == "files"; clicked => { root.active-right-tab = "files"; } }
                }
                VerticalLayout { alignment: end;
                    RightTab { label: "History"; glyph: "◷"; selected: root.active-right-tab == "history"; clicked => { root.active-right-tab = "history"; } }
                }
            }
        }

        // Terminal area (only visible when active-right-tab == "terminal")
        focus-scope := FocusScope {
            x: right-pad-h;
            y: tab-strip-h + right-pad-v;
            width: term-w;
            height: term-h;

            key-pressed(event) => {
                root.key-pressed(
                    event.text,
                    event.modifiers.control,
                    event.modifiers.alt,
                    event.modifiers.shift,
                );
                accept
            }

            Rectangle {
                background: #07080b;
                border-radius: 6px;
                border-width: 1px;
                border-color: Tokens.border-soft;
                clip: true;

                Image {
                    source: root.frame;
                    x: 0; y: 0;
                    width: parent.width;
                    height: parent.height;
                    image-fit: contain;
                    image-rendering: pixelated;
                }

                // Empty state.
                Rectangle {
                    visible: root.active-task-id == "";
                    background: #07080b;
                    Text {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        text: "Select a task or create one to begin";
                        color: Tokens.text-tertiary;
                        font-size: 12px;
                    }
                }
            }
        }

        // Footer status line.
        Text {
            x: right-pad-h + 4px;
            y: parent.height - 22px;
            text: "‖ Quay terminal · esc to interrupt the active session";
            color: Tokens.kind-enhancement;
            font-size: 10px;
        }

        // Description tab — editable text area backed by task.description.
        Rectangle {
            visible: root.active-right-tab == "description";
            x: right-pad-h;
            y: tab-strip-h + right-pad-v;
            width: parent.width - right-pad-h * 2;
            height: parent.height - tab-strip-h - right-pad-v * 2 - 22px;
            background: #14161a;
            border-radius: 6px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            if root.active-task-id == "": Rectangle {
                VerticalLayout {
                    alignment: center;
                    spacing: 6px;
                    Text {
                        text: "Description";
                        color: Tokens.text-primary;
                        font-size: 13px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "Select a task to read or edit its description.";
                        color: Tokens.text-tertiary;
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }
            }

            if root.active-task-id != "": VerticalLayout {
                padding: 14px;
                spacing: 12px;

                // Display ID + session state chip in a single row.
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: root.active-task-display;
                        color: Tokens.text-tertiary;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }

                    // Session state badge — small coloured dot + label.
                    Rectangle {
                        width: state-chip.preferred-width + 16px;
                        height: 16px;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Tokens.border-soft;
                        background: transparent;

                        state-chip := HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 8px;
                            spacing: 5px;
                            alignment: center;

                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 6px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background:
                                        root.active-task-session-state == "busy"     ? Tokens.kind-enhancement
                                      : root.active-task-session-state == "awaiting" ? #f5b54e
                                      : root.active-task-session-state == "error"    ? Tokens.kind-bug
                                      : root.active-task-session-state == "exited"   ? Tokens.text-muted
                                      : root.active-task-session-state == "stopped"  ? Tokens.text-muted
                                                                                     : Tokens.text-muted;
                                }
                            }
                            Text {
                                text: root.active-task-session-state;
                                color: Tokens.text-secondary;
                                font-size: 9px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Editable title.
                LineEdit {
                    text: root.active-task-title;
                    placeholder-text: "Task title";
                    font-size: 15px;
                    edited(new-text) => {
                        root.title-changed(new-text);
                    }
                }

                Rectangle {
                    height: 1px;
                    background: Tokens.border-very-soft;
                }

                // Instructions — the initial prompt sent to the agent.
                Text {
                    text: "Instructions (sent to the agent on start)";
                    color: Tokens.text-tertiary;
                    font-size: 10px;
                }
                LineEdit {
                    text: root.active-task-instructions;
                    placeholder-text: "e.g. Add dark mode with a toggle in settings";
                    font-size: 12px;
                    edited(new-text) => {
                        root.instructions-changed(new-text);
                    }
                }

                // Plan / Implement action row.
                HorizontalLayout {
                    spacing: 8px;

                    plan-area := TouchArea {
                        width: 96px;
                        height: 30px;
                        clicked => { root.start-plan(root.active-task-id); }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : #181a23;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: parent.has-hover ? #2b3144 : #23262f;
                            HorizontalLayout {
                                alignment: center;
                                Text {
                                    text: "✦ Plan";
                                    color: Tokens.text-primary;
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    implement-area := TouchArea {
                        width: 120px;
                        height: 30px;
                        clicked => { root.start-implement(root.active-task-id); }
                        Rectangle {
                            background: parent.has-hover ? rgba(16, 185, 129, 18%) : rgba(16, 185, 129, 12%);
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: rgba(16, 185, 129, 40%);
                            HorizontalLayout {
                                alignment: center;
                                Text {
                                    text: "⚡ Implement";
                                    color: Tokens.kind-enhancement;
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Rectangle { horizontal-stretch: 1; }
                }

                Rectangle {
                    height: 1px;
                    background: Tokens.border-very-soft;
                }

                Text {
                    text: "Description";
                    color: Tokens.text-tertiary;
                    font-size: 10px;
                }

                TextEdit {
                    text: root.active-task-description;
                    placeholder-text: "Add a description, notes for the agent, acceptance criteria…";
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    edited => {
                        root.description-changed(self.text);
                    }
                }
            }
        }

        // Git Changes tab — live diff + commit log for the active task's worktree.
        Rectangle {
            visible: root.active-right-tab == "git";
            x: right-pad-h;
            y: tab-strip-h + right-pad-v;
            width: parent.width - right-pad-h * 2;
            height: parent.height - tab-strip-h - right-pad-v * 2 - 22px;
            background: #14161a;
            border-radius: 6px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            if root.active-task-id == "" || (root.git-diff-files.length == 0 && root.git-commit-log.length == 0): Rectangle {
                VerticalLayout {
                    alignment: center;
                    spacing: 6px;
                    Text {
                        text: "Git Changes";
                        color: Tokens.text-primary;
                        font-size: 13px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: root.active-task-id == "" ? "Select a task with a git worktree to see changes." : "No changes yet.";
                        color: Tokens.text-tertiary;
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }
            }

            if root.active-task-id != "" && (root.git-diff-files.length > 0 || root.git-commit-log.length > 0): VerticalLayout {
                padding: 12px;
                spacing: 10px;

                // Changed files header.
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "Changed files";
                        color: Tokens.text-secondary;
                        font-size: 10px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; height: 1px; }
                    Text {
                        text: root.git-diff-files.length;
                        color: Tokens.text-tertiary;
                        font-size: 10px;
                    }
                }

                // Files list + patches — scrolls together.
                ScrollView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 8px;

                        for f in root.git-diff-files: Rectangle {
                            background: #0e0f13;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;

                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;
                                    Rectangle {
                                        width: 18px;
                                        height: 14px;
                                        border-radius: 3px;
                                        background: f.status == "A" ? rgba(16, 185, 129, 20%)
                                                   : f.status == "M" ? rgba(245, 181, 78, 20%)
                                                   : f.status == "D" ? rgba(248, 113, 113, 20%)
                                                                     : rgba(167, 175, 184, 15%);
                                        Text {
                                            text: f.status;
                                            color: f.status == "A" ? Tokens.kind-enhancement
                                                 : f.status == "M" ? #f5b54e
                                                 : f.status == "D" ? Tokens.kind-bug
                                                                    : Tokens.text-secondary;
                                            font-size: 9px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }
                                    Text {
                                        text: f.path;
                                        color: Tokens.text-primary;
                                        font-size: 11px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Text {
                                        text: "+" + f.additions;
                                        color: Tokens.kind-enhancement;
                                        font-size: 10px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "-" + f.deletions;
                                        color: Tokens.kind-bug;
                                        font-size: 10px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                    }
                                }

                                // Patch text (monospaced). Slint's Text
                                // element handles basic wrapping; per-line
                                // colouring by origin char would need a
                                // custom widget — deferred to a polish
                                // iteration.
                                if f.patch != "": Text {
                                    text: f.patch;
                                    color: Tokens.text-secondary;
                                    font-size: 10px;
                                    font-family: "JetBrains Mono";
                                    wrap: no-wrap;
                                }
                            }
                        }

                        // Commit log section.
                        if root.git-commit-log.length > 0: Rectangle {
                            height: 1px;
                            background: Tokens.border-very-soft;
                        }

                        if root.git-commit-log.length > 0: HorizontalLayout {
                            spacing: 6px;
                            Text {
                                text: "Commits on this branch";
                                color: Tokens.text-secondary;
                                font-size: 10px;
                                font-weight: 700;
                            }
                            Rectangle { horizontal-stretch: 1; height: 1px; }
                            Text {
                                text: root.git-commit-log.length;
                                color: Tokens.text-tertiary;
                                font-size: 10px;
                            }
                        }

                        for c in root.git-commit-log: Rectangle {
                            background: #0e0f13;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            VerticalLayout {
                                padding: 6px;
                                padding-left: 10px;
                                spacing: 2px;
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: c.sha-short;
                                        color: Tokens.kind-feature;
                                        font-size: 10px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: c.summary;
                                        color: Tokens.text-primary;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Text {
                                        text: c.timestamp;
                                        color: Tokens.text-tertiary;
                                        font-size: 9px;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: c.author-name;
                                    color: Tokens.text-tertiary;
                                    font-size: 9px;
                                }
                            }
                        }
                    }
                }
            }
        }

        // Files tab — shows either the directory listing or the inline
        // editor, depending on `editor-open`.
        Rectangle {
            visible: root.active-right-tab == "files";
            x: right-pad-h;
            y: tab-strip-h + right-pad-v;
            width: parent.width - right-pad-h * 2;
            height: parent.height - tab-strip-h - right-pad-v * 2 - 22px;
            background: #14161a;
            border-radius: 6px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            // ── File tree mode ─────────────────────────────────────
            if !root.editor-open: VerticalLayout {
                padding: 12px;
                spacing: 8px;

                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "▸";
                        color: Tokens.text-tertiary;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.file-current-dir == "" ? "Select a task with a worktree" : root.file-current-dir;
                        color: Tokens.text-primary;
                        font-size: 11px;
                        font-family: "JetBrains Mono";
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                Rectangle { height: 1px; background: Tokens.border-very-soft; }

                ScrollView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 1px;
                        for entry in root.file-entries: TouchArea {
                            height: 24px;
                            clicked => {
                                root.file-entry-clicked(entry.path, entry.kind);
                            }
                            Rectangle {
                                background: parent.has-hover ? #1f2331 : transparent;
                                border-radius: 3px;
                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 8px;
                                    spacing: 8px;
                                    alignment: start;
                                    Text {
                                        text: entry.kind == "directory" ? "▸"
                                             : entry.kind == "parent" ? "⇧"
                                                                       : "·";
                                        color: entry.kind == "file" ? Tokens.text-tertiary : Tokens.kind-feature;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: entry.name;
                                        color: Tokens.text-primary;
                                        font-size: 11px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }

                Text {
                    text: "Click a text file to open it in the built-in editor. Binary or very large files fall back to $EDITOR.";
                    color: Tokens.text-tertiary;
                    font-size: 9px;
                }
            }

            // ── Inline editor mode (Phase 7) ───────────────────────
            if root.editor-open: VerticalLayout {
                padding: 12px;
                spacing: 8px;

                // Header with path, syntax, dirty indicator, save/close buttons.
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    // Back / close button.
                    TouchArea {
                        width: 22px;
                        height: 22px;
                        clicked => { root.editor-close(); }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 4px;
                            Text {
                                text: "←";
                                color: Tokens.text-secondary;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }

                    Text {
                        text: root.editor-file-path;
                        color: Tokens.text-primary;
                        font-size: 11px;
                        font-family: "JetBrains Mono";
                        overflow: elide;
                        vertical-alignment: center;
                    }

                    // Dirty dot.
                    Rectangle {
                        visible: root.editor-file-dirty;
                        width: 6px;
                        height: 6px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 3px;
                        background: #f5b54e;
                    }

                    Rectangle { horizontal-stretch: 1; }

                    // Syntax badge.
                    Rectangle {
                        width: syn-text.preferred-width + 12px;
                        height: 18px;
                        border-radius: 9px;
                        border-width: 1px;
                        border-color: Tokens.border-soft;
                        syn-text := Text {
                            text: root.editor-syntax-name;
                            color: Tokens.text-secondary;
                            font-size: 9px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    // Save button.
                    TouchArea {
                        width: 56px;
                        height: 22px;
                        clicked => { root.editor-save(); }
                        Rectangle {
                            background: parent.has-hover ? rgba(16, 185, 129, 20%) : rgba(16, 185, 129, 12%);
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: rgba(16, 185, 129, 40%);
                            Text {
                                text: "save";
                                color: Tokens.kind-enhancement;
                                font-size: 10px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Tokens.border-very-soft; }

                // The actual text area. Uses Slint's built-in TextEdit —
                // multi-line, wraps, integrates with keyboard. Bound
                // two-way: on edit we call back into Rust to update the
                // EditorBuffer and mark it dirty.
                TextEdit {
                    text: root.editor-file-content;
                    wrap: no-wrap;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    font-family: "JetBrains Mono";
                    font-size: 12px;
                    edited => {
                        root.editor-content-changed(self.text);
                    }
                }

                Text {
                    text: "Slint's built-in text editor. Press save to persist. Syntax highlighting will be enriched in a follow-up iteration.";
                    color: Tokens.text-tertiary;
                    font-size: 9px;
                }
            }
        }

        // History placeholder — stays while Fase 5 defers the real
        // transcript browser.
        Rectangle {
            visible: root.active-right-tab == "history";
            x: right-pad-h;
            y: tab-strip-h + right-pad-v;
            width: parent.width - right-pad-h * 2;
            height: parent.height - tab-strip-h - right-pad-v * 2 - 22px;
            background: #14161a;
            border-radius: 6px;
            border-width: 1px;
            border-color: Tokens.border-soft;

            VerticalLayout {
                alignment: center;
                spacing: 8px;
                Text {
                    text: "History";
                    color: Tokens.text-primary;
                    font-size: 13px;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Session transcript browser — coming in Phase 6.";
                    color: Tokens.text-tertiary;
                    font-size: 11px;
                    horizontal-alignment: center;
                }
            }
        }
    }

    // ── Settings modal overlay ──────────────────────────────────────────
    Rectangle {
        visible: root.settings-open;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 60%);

        // Click outside the card closes the modal.
        TouchArea {
            clicked => { root.settings-open = false; }
        }

        Rectangle {
            // Centered card.
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 640px;
            height: 560px;
            background: #14161a;
            border-radius: 10px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            // Click inside the card — swallow so it doesn't close the modal.
            TouchArea { }

            VerticalLayout {
                padding: 20px;
                spacing: 14px;

                // Header row with title + close button.
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text {
                        text: "Settings";
                        color: Tokens.text-primary;
                        font-size: 16px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    TouchArea {
                        width: 24px;
                        height: 24px;
                        clicked => { root.settings-open = false; }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 4px;
                            Text {
                                text: "×";
                                color: Tokens.text-secondary;
                                font-size: 18px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Tokens.border-very-soft; }

                // ── General section ───────────────────────────────────
                Text {
                    text: "GENERAL";
                    color: Tokens.text-tertiary;
                    font-size: 9px;
                    font-weight: 700;
                }

                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Default base branch";
                        color: Tokens.text-secondary;
                        font-size: 11px;
                    }
                    LineEdit {
                        text: root.settings-default-base-branch;
                        placeholder-text: "main";
                        font-size: 12px;
                        edited(new-text) => {
                            root.settings-base-branch-changed(new-text);
                        }
                    }
                }

                // ── Quick Actions section ─────────────────────────────
                Rectangle { height: 1px; background: Tokens.border-very-soft; }
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "QUICK ACTIONS";
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; height: 1px; }
                    Text {
                        text: root.settings-quick-actions.length;
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                    }
                }

                ScrollView {
                    height: 160px;
                    VerticalLayout {
                        spacing: 4px;
                        for qa in root.settings-quick-actions: Rectangle {
                            height: 28px;
                            background: #0e0f13;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 8px;
                                alignment: start;
                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: qa.shortcut;
                                        color: Tokens.text-tertiary;
                                        font-size: 10px;
                                        font-family: "JetBrains Mono";
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: qa.name;
                                        color: Tokens.text-primary;
                                        font-size: 11px;
                                        overflow: elide;
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: kind-text.preferred-width + 10px;
                                        height: 14px;
                                        border-radius: 7px;
                                        border-width: 1px;
                                        border-color: Tokens.border-soft;
                                        kind-text := Text {
                                            text: qa.kind;
                                            color: qa.kind == "claude" ? Tokens.kind-feature : Tokens.kind-enhancement;
                                            font-size: 9px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Process Manager section ───────────────────────────
                Rectangle { height: 1px; background: Tokens.border-very-soft; }
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "PROCESSES";
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; height: 1px; }
                    TouchArea {
                        width: 56px;
                        height: 16px;
                        clicked => { root.refresh-processes(); }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 3px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            Text {
                                text: "↻ refresh";
                                color: Tokens.text-secondary;
                                font-size: 9px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                    Text {
                        text: root.settings-processes.length;
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                }

                ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 4px;
                        if root.settings-processes.length == 0: Text {
                            text: "No agent processes detected.";
                            color: Tokens.text-tertiary;
                            font-size: 11px;
                        }
                        for p in root.settings-processes: Rectangle {
                            height: 32px;
                            background: #0e0f13;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 6px;
                                spacing: 8px;
                                alignment: start;
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 8px;
                                        height: 8px;
                                        border-radius: 4px;
                                        background: p.class == "tracked" ? Tokens.kind-enhancement
                                                  : p.class == "orphan" ? Tokens.kind-bug
                                                                         : #f5b54e;
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: p.name + "  " + p.pid;
                                        color: Tokens.text-primary;
                                        font-size: 11px;
                                        font-family: "JetBrains Mono";
                                    }
                                    Text {
                                        text: p.class;
                                        color: Tokens.text-tertiary;
                                        font-size: 9px;
                                    }
                                }
                                TouchArea {
                                    width: 52px;
                                    height: 22px;
                                    clicked => { root.process-kill(p.pid); }
                                    Rectangle {
                                        background: parent.has-hover ? rgba(245, 181, 78, 15%) : transparent;
                                        border-radius: 3px;
                                        border-width: 1px;
                                        border-color: rgba(245, 181, 78, 40%);
                                        Text {
                                            text: "stop";
                                            color: #f5b54e;
                                            font-size: 9px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }
                                }
                                TouchArea {
                                    width: 52px;
                                    height: 22px;
                                    clicked => { root.process-force-kill(p.pid); }
                                    Rectangle {
                                        background: parent.has-hover ? rgba(248, 113, 113, 15%) : transparent;
                                        border-radius: 3px;
                                        border-width: 1px;
                                        border-color: rgba(248, 113, 113, 40%);
                                        Text {
                                            text: "kill";
                                            color: Tokens.kind-bug;
                                            font-size: 9px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
