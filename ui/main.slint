// Quay main window — Lanes-inspired three-pane layout.
//
// Layout:
//   ┌──────────┬──────────────────┬─────────────────────────────┐
//   │ title bar (36px)                                            │
//   ├──────────┼──────────────────┼─────────────────────────────┤
//   │ sidebar  │  task list       │  task detail / terminal      │
//   │ 200px    │  flex            │  flex (2x)                   │
//   │          │                  │                              │
//   └──────────┴──────────────────┴─────────────────────────────┘
//
// All colours, paddings and dimensions are taken straight from the Lanes
// reference markup the user provided so the visual language stays close.

import { ScrollView, TextEdit, LineEdit } from "std-widgets.slint";

// ── Design tokens ───────────────────────────────────────────────────────────
global Tokens {
    // Polish 19 — base bg darkened from #1e2024 to match the Lanes
    // reference screenshot more closely.
    out property <color> bg-base: #1a1d22;
    out property <color> bg-section-header: #222428;
    out property <color> bg-tab-active: #202329;
    out property <color> bg-hover: rgba(255, 255, 255, 5%);
    out property <color> bg-card-selected: rgba(255, 255, 255, 4%);
    // Polish 16 — hover/active shades for open-task tab chips.
    out property <color> bg-card-hover: rgba(255, 255, 255, 3%);

    out property <color> border-soft: rgba(150, 160, 180, 14%);
    out property <color> border-very-soft: rgba(150, 160, 180, 7%);
    // Polish 16 — stronger border for the active task tab in the
    // right-pane open-tabs strip. Same hue as kind-feature but thinner.
    out property <color> border-accent: rgba(96, 165, 250, 45%);

    out property <color> text-primary: #e6e8eb;
    out property <color> text-secondary: #a7afb8;
    out property <color> text-tertiary: rgba(167, 175, 184, 50%);
    out property <color> text-muted: rgba(167, 175, 184, 35%);

    out property <color> kind-enhancement: #10b981;
    out property <color> kind-feature: #60a5fa;
    out property <color> kind-bug: #f87171;
    out property <color> kind-done: #34d399;

    out property <color> accent-warm: #c87533;
    // Polish 19 — pink/coral fill for the user avatar circle in the
    // title bar (introduced visually in Polish 20).
    out property <color> accent-pink-coral: #f58a82;
}

// ── Data structures ─────────────────────────────────────────────────────────
export struct LabelPillData {
    id: string,
    name: string,
    // RGB components 0-255. Slint's `string` → `brush` conversion is not
    // supported, so we pass the colour as separate ints and build the
    // brush with `rgb(r, g, b)` at the call site.
    color-r: int,
    color-g: int,
    color-b: int,
}

export struct QuickActionRowData {
    id: string,
    name: string,
    kind: string,        // "claude" | "shell"
    body: string,
    shortcut: string,    // "⌘⌥1" .. "⌘⌥9" (only first 9 have shortcuts)
}

export struct ProcessRowData {
    pid: int,
    name: string,
    cmdline: string,
    class: string,       // "tracked" | "external" | "orphan"
}

export struct FileEntryData {
    name: string,
    /// Absolute path — passed back in the click callback so Rust can
    /// figure out whether to toggle a directory or open a file.
    path: string,
    kind: string,        // "directory" | "file"
    // Polish 17 — depth in the flattened tree, used by the Files tab
    // to indent each row (10 px + depth × 14 px left padding).
    depth: int,
    // Polish 17 — true when `kind == "directory"` and the user has
    // expanded this row. Drives the chevron glyph (▸/▾).
    expanded: bool,
}

export struct HlSpanData {
    text: string,
    color-r: int,
    color-g: int,
    color-b: int,
    bold: bool,
    italic: bool,
}

export struct HighlightedLineData {
    line-no: int,
    spans: [HlSpanData],
}

export struct TaskCardData {
    id: string,           // UUID for callbacks
    display-id: int,      // sequential numeric ID for display (#1, #2, …)
    title: string,
    kind: string,         // "enhancement" | "feature" | "bug"
    running: bool,
    // Whether the task's git worktree has uncommitted or untracked changes.
    // Populated from `git::status::read_status` during refresh_kanban.
    dirty: bool,
    // Labels attached to this task, rendered as small pills on the card.
    labels: [LabelPillData],
    // Number of unresolved prerequisite tasks. Non-zero → blocked badge.
    blocked-count: int,
    // Polish 22: drives the spinner-vs-static-dot decision in CardRow.
    // One of "idle" | "busy" | "awaiting" | "stopped" | "exited" | "error".
    session-state: string,
}

export struct DiffLineData {
    origin: string,   // "+" | "-" | " " | "H" | "F"
    text: string,
}

export struct DiffFileData {
    path: string,
    status: string,       // "M" | "A" | "D" | "R" | "?" | "T"
    additions: int,
    deletions: int,
    lines: [DiffLineData],
}

export struct CommitEntryData {
    sha-short: string,
    summary: string,
    author-name: string,
    /// Pre-formatted timestamp, e.g. "3 minutes ago".
    timestamp: string,
}

export struct MenuItemData {
    id: string,
    label: string,
    glyph: string,        // 1-char unicode icon
    shortcut: string,
}

export struct ProjectData {
    id: string,
    name: string,
}

// Polish 16 — one entry in the right-pane "open task tabs" strip.
// A separate struct (rather than reusing TaskCardData) because the tab
// strip only needs a compact subset + an `is-active` bit.
export struct OpenTaskTabData {
    id: string,           // UUID — used by open/close callbacks
    display-id: int,      // "#12" prefix
    title: string,
    kind: string,         // drives the diamond glyph colour
    is-active: bool,      // currently focused tab
    session-state: string,// "busy" / "idle" / … — drives the dot
}

// ── Helper components ───────────────────────────────────────────────────────

component KindDiamond inherits Rectangle {
    in property <string> kind;
    width: 12px;
    height: 12px;
    background: transparent;

    Text {
        text: "◆";
        color: kind == "enhancement" ? Tokens.kind-enhancement
              : kind == "feature" ? Tokens.kind-feature
              : kind == "bug" ? Tokens.kind-bug
              : Tokens.text-tertiary;
        font-size: 11px;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

// Polish 22 — busy spinner. Slint 1.15 has no native widget and no
// rotation-angle on Rectangle/Image, so we drive a single-character
// braille glyph from a window-wide `spinner-glyph` property cycled
// in the existing `poll_timer` (~96 ms cadence). All instances
// share the same global phase — exactly how every CLI spinner
// (cargo, npm, rustup, git, …) works in practice. Reference Lanes
// uses an SVG arc; this is the closest pure-text equivalent we
// can render without adding deps.
//
// `font-family: "JetBrains Mono"` is critical: without it some
// of the 8 braille glyphs fall back to a sans font with different
// advance widths and the spinner visually "jitters".
component Spinner inherits Rectangle {
    in property <string> glyph: "⣾";
    // Property name avoids the deprecated `color` alias on Rectangle.
    in property <color> glyph-color: Tokens.kind-feature;
    in property <length> size: 12px;

    width: size;
    height: size;
    background: transparent;

    Text {
        text: glyph;
        color: glyph-color;
        font-size: 11px;
        font-family: "JetBrains Mono";
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

component KindChip inherits Rectangle {
    in property <string> kind;
    height: 16px;
    width: chip-content.preferred-width + 14px;
    border-radius: 8px;
    border-width: 1px;
    border-color: Tokens.border-soft;
    background: transparent;

    chip-content := HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 5px;
        alignment: center;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 3px;
                background: kind == "enhancement" ? Tokens.kind-enhancement
                           : kind == "feature" ? Tokens.kind-feature
                           : kind == "bug" ? Tokens.kind-bug
                           : Tokens.text-tertiary;
            }
        }
        Text {
            text: kind == "enhancement" ? "Enhancement"
                 : kind == "feature" ? "Feature"
                 : kind == "bug" ? "Bug"
                 : kind;
            color: Tokens.text-secondary;
            font-size: 9px;
            vertical-alignment: center;
        }
    }
}

// Polish 25 — transient notification toast. Floats above the
// status bar at the bottom of the window. Shows for ~3 s then
// fades out via the `visible: bool` property (driven by a
// Slint Timer in main.rs). Color stripe on the left edge keys
// the message kind.
//
// Polish 31 — `opacity` and `y` are animated so the chip slides
// up from below and fades in on show, then reverses on hide.
// The container stays mounted (always `visible: true`) so the
// animation can run on the way out — `opacity == 0` makes it
// invisible without removing it from the layout.
component Toast inherits Rectangle {
    in property <string> message;
    in property <string> kind;  // "success" | "error" | "info"
    in property <bool> visible-toast: false;

    opacity: visible-toast ? 1.0 : 0.0;
    animate opacity { duration: 200ms; easing: ease-out; }

    height: 32px;
    border-radius: 8px;
    border-width: 1px;
    border-color: kind == "error" ? Tokens.kind-bug
                : kind == "success" ? Tokens.kind-enhancement
                                     : Tokens.kind-feature;
    background: #14161a;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 14px;
        spacing: 10px;
        alignment: start;

        // Polish 38 — kind glyph instead of a bare dot. ✓ / ✕ / ℹ
        // are far easier to parse at a glance than a colored circle.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 18px;
                height: 18px;
                border-radius: 9px;
                background: kind == "error" ? rgba(248, 113, 113, 22%)
                          : kind == "success" ? rgba(16, 185, 129, 22%)
                                              : rgba(96, 165, 250, 22%);
                Text {
                    text: kind == "error" ? "✕"
                        : kind == "success" ? "✓"
                                            : "i";
                    color: kind == "error" ? Tokens.kind-bug
                         : kind == "success" ? Tokens.kind-enhancement
                                             : Tokens.kind-feature;
                    font-size: 11px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
            }
        }
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: message;
                color: Tokens.text-primary;
                font-size: 11px;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }
}

// Polish 26 — single row in the keyboard shortcuts overlay.
// Left: chip showing the key combo. Right: human description.
component ShortcutRow inherits Rectangle {
    in property <string> keys;
    in property <string> label;

    height: 22px;
    background: transparent;

    HorizontalLayout {
        spacing: 12px;
        alignment: start;

        Rectangle {
            width: 80px;
            height: 18px;
            border-radius: 4px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            background: Tokens.bg-tab-active;
            Text {
                text: keys;
                color: Tokens.text-primary;
                font-size: 10px;
                font-family: "JetBrains Mono";
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
        }
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: label;
                color: Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}

// Polish 20 — small circular avatar shown in the title bar (and
// reusable for any future "user" / "agent" identity slot). The
// initial defaults to "L" because Quay has no user system yet —
// the slot exists purely as a visual anchor matching the Lanes
// reference screenshot.
component Avatar inherits Rectangle {
    in property <length> size: 22px;
    in property <string> initial: "L";
    in property <color> bg: Tokens.accent-pink-coral;

    width: size;
    height: size;
    border-radius: size / 2;
    background: bg;

    Text {
        text: initial;
        color: #1a0a0a;
        font-size: 11px;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

// Polish 19 — reusable × close button for modal headers and inline
// clear actions. Matches the existing open-coded blocks (rounded
// circle, red-tinted hover, kind-bug glyph color on hover) so all
// modal close affordances stay visually consistent.
component CloseButton inherits Rectangle {
    in property <length> size: 22px;
    callback clicked();

    width: size;
    height: size;
    border-radius: size / 2;
    background: ta.has-hover ? rgba(248, 113, 113, 18%) : transparent;
    // Polish 30 — smooth close-button hover.
    animate background { duration: 120ms; easing: ease-out; }

    ta := TouchArea { clicked => { root.clicked(); } }
    Text {
        text: "×";
        color: ta.has-hover ? Tokens.kind-bug : Tokens.text-tertiary;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

component MenuRow inherits Rectangle {
    in property <MenuItemData> item;
    // Polish 24: when the sidebar is collapsed, only the glyph
    // column survives. Label and shortcut hide entirely.
    in property <bool> compact: false;
    callback clicked();

    // Polish 20 — when the shortcut slot carries a `▸` chevron the
    // row is acting as a submenu indicator (e.g. Quick Action), so
    // render the glyph larger and brighter than a regular ⌘N hint.
    property <bool> is-submenu: item.shortcut == "▸";

    height: 26px;
    border-radius: 6px;
    background: hover.has-hover ? Tokens.bg-hover : transparent;
    // Polish 30 — smooth menu row hover.
    animate background { duration: 120ms; easing: ease-out; }

    hover := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: compact ? 0px : 12px;
        padding-right: compact ? 0px : 12px;
        spacing: 12px;
        alignment: compact ? center : start;

        VerticalLayout {
            alignment: center;
            Text {
                text: item.glyph;
                color: Tokens.text-secondary;
                font-size: 13px;
            }
        }
        if !compact: VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: item.label;
                color: Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
        if !compact: VerticalLayout {
            alignment: center;
            Text {
                text: item.shortcut;
                color: is-submenu ? Tokens.text-secondary : Tokens.text-muted;
                font-size: is-submenu ? 13px : 10px;
                vertical-alignment: center;
            }
        }
    }
}

component ProjectRow inherits Rectangle {
    in property <ProjectData> project;
    in property <bool> selected;
    // Polish 24: compact mode for collapsed sidebar — name hides,
    // only the chevron remains (re-purposed as a folder dot icon).
    in property <bool> compact: false;
    callback clicked();

    height: 26px;
    border-radius: 6px;
    background: selected ? Tokens.bg-card-selected
              : ta.has-hover ? Tokens.bg-hover
              : transparent;
    // Polish 30 — smooth project row hover/select.
    animate background { duration: 120ms; easing: ease-out; }

    ta := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: compact ? 0px : 12px;
        padding-right: compact ? 0px : 12px;
        spacing: 12px;
        alignment: compact ? center : start;
        VerticalLayout {
            alignment: center;
            Text {
                text: compact ? "▤" : (root.selected ? "▾" : "▸");
                color: root.selected ? Tokens.kind-feature : Tokens.text-tertiary;
                font-size: compact ? 13px : 11px;
            }
        }
        if !compact: VerticalLayout {
            alignment: center;
            Text {
                text: project.name;
                color: root.selected ? Tokens.text-primary : Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}

component FilterChip inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked();

    height: 24px;
    width: chip-row.preferred-width + 16px;
    border-radius: 4px;
    border-width: 1px;
    border-color: Tokens.border-soft;
    background: selected ? Tokens.bg-tab-active : transparent;
    // Polish 30 — smooth filter chip toggle.
    animate background { duration: 120ms; easing: ease-out; }

    TouchArea { clicked => { root.clicked(); } }

    chip-row := HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        alignment: center;
        // Polish 23: kind glyph on the left of the label, matching
        // the Lanes reference. Color is muted text-tertiary because
        // filter chips aren't kinded.
        VerticalLayout {
            alignment: center;
            Text {
                text: "◆";
                color: Tokens.text-tertiary;
                font-size: 9px;
                vertical-alignment: center;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: selected ? Tokens.text-primary : Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
        // Polish 23: × only renders when the chip is the active
        // filter, removing visual noise from the inactive ones.
        if root.selected: VerticalLayout {
            alignment: center;
            Text {
                text: "×";
                color: Tokens.text-tertiary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}

component SectionHeader inherits Rectangle {
    in property <string> label;
    in property <int> count;
    height: 28px;
    background: Tokens.bg-section-header;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        alignment: start;

        VerticalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: count-text.preferred-width + 8px;
                height: 14px;
                border-radius: 7px;
                background: rgba(167, 175, 184, 10%);
                count-text := Text {
                    text: root.count;
                    color: Tokens.text-tertiary;
                    font-size: 9px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}

component CardRow inherits Rectangle {
    in property <TaskCardData> task;
    in property <bool> selected;
    // Polish 22: piped down from MainWindow because Slint components
    // can't reach the window root from inside their body. Each
    // CardRow instance forwards `root.spinner-glyph` here.
    in property <string> spinner-glyph;
    callback clicked();
    callback move-back();
    callback move-forward();

    height: 30px;
    background: selected ? Tokens.bg-card-selected
              : ta.has-hover ? Tokens.bg-hover
              : transparent;
    // Polish 30 — smooth fade between hover/select/idle backgrounds.
    animate background { duration: 120ms; easing: ease-out; }

    Rectangle {
        // Top divider line.
        x: 0; y: 0; width: parent.width; height: 1px;
        background: Tokens.border-very-soft;
    }

    // Polish 37 — left accent bar when the card is selected. Gives
    // a stronger "this is the active task" cue than the background
    // tint alone. The width grows from 0 → 3px so it slides in.
    Rectangle {
        x: 0;
        y: 0;
        width: selected ? 3px : 0px;
        height: parent.height;
        background:
            task.kind == "bug"         ? Tokens.kind-bug
          : task.kind == "enhancement" ? Tokens.kind-enhancement
                                       : Tokens.kind-feature;
        animate width { duration: 140ms; easing: ease-out; }
    }

    ta := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 8px;
        spacing: 8px;
        alignment: start;

        // Display ID
        VerticalLayout {
            alignment: center;
            Text {
                text: "#" + task.display-id;
                color: Tokens.text-tertiary;
                font-size: 10px;
                font-family: "JetBrains Mono";
                vertical-alignment: center;
            }
        }

        // Diamond
        VerticalLayout {
            alignment: center;
            KindDiamond { kind: task.kind; }
        }

        // Title (stretches)
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: task.title;
                color: selected ? Tokens.text-primary : Tokens.text-secondary;
                font-size: 11px;
                overflow: elide;
                vertical-alignment: center;
            }
        }

        // Tag chip
        // Label pills — one small coloured pill per attached label.
        // Rendered in a horizontal strip before the KindChip; wraps
        // gracefully if a card has many labels by just truncating
        // (Slint HorizontalLayout will push later items off-screen,
        // which is fine for 1-3 labels per card).
        VerticalLayout {
            alignment: center;
            HorizontalLayout {
                spacing: 3px;
                for label in task.labels: Rectangle {
                    width: label-name.preferred-width + 10px;
                    height: 14px;
                    border-radius: 3px;
                    background: rgb(label.color-r, label.color-g, label.color-b);
                    label-name := Text {
                        text: label.name;
                        color: #0b0d11;
                        font-size: 8px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
            }
        }

        VerticalLayout {
            alignment: center;
            KindChip { kind: task.kind; }
        }

        // Blocked badge — small lock icon + count if the task has any
        // unresolved dependencies.
        VerticalLayout {
            alignment: center;
            visible: task.blocked-count > 0;
            Rectangle {
                width: blocked-row.preferred-width + 10px;
                height: 14px;
                border-radius: 7px;
                background: rgba(248, 113, 113, 15%);
                border-width: 1px;
                border-color: rgba(248, 113, 113, 40%);
                blocked-row := HorizontalLayout {
                    padding-left: 4px;
                    padding-right: 5px;
                    spacing: 3px;
                    alignment: center;
                    Text {
                        text: "⊘";
                        color: Tokens.kind-bug;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: task.blocked-count;
                        color: Tokens.kind-bug;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Dirty dot — small amber circle if the task's worktree has
        // uncommitted changes. Shown to the left of the running dot so
        // the two signals read naturally (uncommitted → running).
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 3px;
                background: task.dirty ? #f5b54e : transparent;
            }
        }

        // Polish 22: status indicator. Spinner when busy, otherwise
        // the existing static dot (green if running, hollow if idle).
        VerticalLayout {
            alignment: center;
            if task.session-state == "busy": Spinner {
                glyph: root.spinner-glyph;
                glyph-color: Tokens.kind-feature;
                size: 10px;
            }
            if task.session-state != "busy": Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: task.running ? Tokens.kind-enhancement : transparent;
                border-width: 1px;
                border-color: task.running ? Tokens.kind-enhancement : Tokens.text-muted;
            }
        }

        // Move arrows — visible only on hover/selected, very subtle.
        Rectangle {
            width: 24px;
            background: transparent;
            visible: root.selected || ta.has-hover;

            HorizontalLayout {
                spacing: 0px;
                alignment: center;
                TouchArea {
                    width: 12px;
                    clicked => { root.move-back(); }
                    Text { text: "‹"; color: Tokens.text-tertiary; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                }
                TouchArea {
                    width: 12px;
                    clicked => { root.move-forward(); }
                    Text { text: "›"; color: Tokens.text-tertiary; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }
}

component RightTab inherits Rectangle {
    in property <string> label;
    in property <string> glyph;
    in property <bool> selected;
    callback clicked();

    height: 24px;
    width: row.preferred-width + 16px;
    border-radius: 6px;
    border-width: 1px;
    border-color: Tokens.border-soft;
    background: selected ? Tokens.bg-tab-active : transparent;

    TouchArea { clicked => { root.clicked(); } }

    row := HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 6px;
        alignment: center;

        VerticalLayout {
            alignment: center;
            Text {
                text: root.glyph;
                color: selected ? Tokens.text-primary : Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: selected ? Tokens.text-primary : Tokens.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}

// Polish 16 — one pinned-task chip in the right-pane tab strip.
// Kind glyph, "#N Title", session dot, × close button. Active tab gets
// a filled background + brighter text. Clicking the body fires
// `clicked()`; clicking × fires `close-clicked()`.
component OpenTaskTab inherits Rectangle {
    in property <string> display-label;   // "#12 Dark mode"
    in property <string> kind;             // "feature" / "bug" / "enhancement"
    in property <string> session-state;    // "busy" / "idle" / …
    in property <bool> active;
    // Polish 22: piped from MainWindow.spinner-glyph by the open-tabs
    // strip's `for tab in ...:` loop. Drives the busy spinner.
    in property <string> spinner-glyph;
    callback clicked();
    callback close-clicked();

    height: 26px;
    width: body.preferred-width + 14px;
    border-radius: 6px;
    border-width: 1px;
    border-color: active ? Tokens.border-accent : Tokens.border-soft;
    background: active ? Tokens.bg-tab-active : (ta.has-hover ? Tokens.bg-card-hover : transparent);
    // Polish 30 — smooth tab background transition.
    animate background { duration: 120ms; easing: ease-out; }
    animate border-color { duration: 120ms; easing: ease-out; }

    ta := TouchArea { clicked => { root.clicked(); } }

    body := HorizontalLayout {
        padding-left: 7px;
        padding-right: 4px;
        spacing: 6px;
        alignment: center;

        // Kind diamond — same palette used on CardRow.
        VerticalLayout {
            alignment: center;
            Text {
                text: "◆";
                font-size: 9px;
                color:
                    root.kind == "bug"         ? Tokens.kind-bug
                  : root.kind == "enhancement" ? Tokens.kind-enhancement
                                               : Tokens.kind-feature;
                vertical-alignment: center;
            }
        }

        // Display id + title.
        VerticalLayout {
            alignment: center;
            Text {
                text: root.display-label;
                color: active ? Tokens.text-primary : Tokens.text-secondary;
                font-size: 11px;
                font-weight: active ? 600 : 500;
                vertical-alignment: center;
            }
        }

        // Polish 22: spinner when busy, colored dot for awaiting/error,
        // hidden otherwise. The braille spinner glyph is window-wide,
        // piped through `spinner-glyph`.
        if root.session-state == "busy": VerticalLayout {
            alignment: center;
            Spinner {
                glyph: root.spinner-glyph;
                glyph-color: Tokens.kind-feature;
                size: 8px;
            }
        }
        if root.session-state == "awaiting" || root.session-state == "error": VerticalLayout {
            alignment: center;
            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 3px;
                background:
                    root.session-state == "awaiting" ? #f5b54e
                  : root.session-state == "error"    ? Tokens.kind-bug
                                                     : Tokens.text-muted;
            }
        }

        // × close button.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 14px;
                height: 14px;
                border-radius: 7px;
                background: close-ta.has-hover ? rgba(248, 113, 113, 20%) : transparent;
                close-ta := TouchArea { clicked => { root.close-clicked(); } }
                Text {
                    text: "×";
                    color: close-ta.has-hover ? Tokens.kind-bug : Tokens.text-tertiary;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
            }
        }
    }
}

// ── Main window ─────────────────────────────────────────────────────────────

export component MainWindow inherits Window {
    title: "Quay";
    background: Tokens.bg-base;

    // Terminal pixel buffer + dimensions (driven from Rust).
    in property <image> frame;
    in property <int> cell-w: 10;
    in property <int> cell-h: 22;
    in property <int> cols: 100;
    in property <int> rows: 30;

    // Polish 22: window-wide braille spinner phase, cycled by the
    // existing poll_timer in main.rs at ~96 ms. All Spinner instances
    // (CardRow + OpenTaskTab) read this single string so every
    // spinner stays in lockstep — same convention every CLI spinner
    // (cargo, npm, rustup, …) follows.
    in property <string> spinner-glyph: "⣾";

    // Polish 25 — transient notification state. The Toast component
    // at the bottom of the window reads these. A Slint Timer in
    // main.rs (started by `show_toast`) clears `toast-visible` after
    // ~3 s.
    in-out property <string> toast-message: "";
    in-out property <string> toast-kind: "info";
    in-out property <bool> toast-visible: false;

    // Polish 26 — keyboard shortcuts overlay. Toggled by Cmd+? from
    // the key dispatcher in main.rs. Esc closes (handled in the
    // existing modal escape branch).
    in-out property <bool> shortcuts-open: false;

    // Polish 35 — Cmd+P fuzzy task quick switcher. Modal overlay
    // with a search input and a filtered list of tasks. The Rust
    // side rebuilds `task-search-results` on every keystroke.
    in-out property <bool> task-search-open: false;
    in-out property <string> task-search-query: "";
    in property <[TaskCardData]> task-search-results;
    callback task-search-changed(string);
    callback task-search-select(string);

    // Polish 28 — true when every kanban model is empty (after the
    // active label/project filters are applied in Rust). Drives the
    // empty-state placeholder in the middle pane.
    property <bool> kanban-empty:
        root.tasks-backlog.length == 0
        && root.tasks-planning.length == 0
        && root.tasks-implementation.length == 0
        && root.tasks-review.length == 0
        && root.tasks-done.length == 0
        && root.tasks-misc.length == 0;

    // Selection / context.
    in property <string> active-task-id: "";
    in property <string> active-task-display: "";
    in property <string> active-task-kind: "feature";
    in-out property <string> active-task-title: "";
    in-out property <string> active-task-description: "";
    in-out property <string> active-task-instructions: "";
    // Session state for the active task: one of idle/busy/awaiting/stopped/exited/error.
    in property <string> active-task-session-state: "idle";

    // Polish 15 — live stats parsed from the Claude Code session JSONL
    // transcript at ~/.claude/projects/<cwd>/<session-id>.jsonl. A 2s
    // Timer in main.rs refreshes these for the active task whenever
    // it has a captured `claude_session_id`. Display strings are
    // pre-formatted in Rust (Slint's formatting story is limited).
    // `active-task-message-count` stays numeric so the row can hide
    // itself when there's no data yet.
    in property <string> active-task-tokens-text: "";
    in property <string> active-task-cost-text: "";
    in property <string> active-task-runtime-text: "";
    in property <int> active-task-message-count: 0;

    // Kanban data — one VecModel per column. Phase 2 expanded this from
    // 3 combined sections to 6 (matching Lanes' workflow).
    in property <[TaskCardData]> tasks-backlog;
    in property <[TaskCardData]> tasks-planning;
    in property <[TaskCardData]> tasks-implementation;
    in property <[TaskCardData]> tasks-review;
    in property <[TaskCardData]> tasks-done;
    in property <[TaskCardData]> tasks-misc;

    in property <[MenuItemData]> menu-items;
    in property <[ProjectData]> projects;

    // All labels available in the system, rendered as filter chips at
    // the top of the task list. Clicking one sets `filter-label-id`;
    // clicking it again (or the "All" chip) clears the filter.
    in property <[LabelPillData]> all-labels;
    in-out property <string> filter-label-id: "";
    // Polish 9: active project filter. Empty string = all projects.
    // Set by clicking a project row in the sidebar.
    in-out property <string> active-project-id: "";

    // Settings modal state + content.
    in-out property <bool> settings-open: false;
    in-out property <string> settings-default-base-branch: "main";
    in property <[QuickActionRowData]> settings-quick-actions;
    in property <[ProcessRowData]> settings-processes;

    // Polish 8: New Project modal state.
    in-out property <bool> new-project-open: false;
    in-out property <string> new-project-name: "";
    in-out property <string> new-project-repo-path: "";
    in-out property <string> new-project-base-branch: "main";

    // Polish 10: New Task modal state.
    in-out property <bool> new-task-open: false;
    in-out property <string> new-task-title: "";
    in-out property <string> new-task-instructions: "";

    // Polish 13: status bar counts, updated on every refresh_kanban.
    in property <int> stats-backlog: 0;
    in property <int> stats-planning: 0;
    in property <int> stats-implementation: 0;
    in property <int> stats-review: 0;
    in property <int> stats-done: 0;
    in property <int> stats-misc: 0;
    in property <int> stats-sessions: 0;
    in property <int> stats-total: 0;

    // File browser state for the Files tab (Phase 6).
    in property <[FileEntryData]> file-entries;
    in-out property <string> file-current-dir: "";

    // Editor state (Phase 7). When `editor-open` is true, the Files tab
    // shows the editor surface instead of the directory listing.
    in-out property <bool> editor-open: false;
    in-out property <string> editor-file-path: "";
    in-out property <string> editor-file-content: "";
    in property <string> editor-syntax-name: "Plain Text";
    in property <bool> editor-file-dirty: false;
    // Polish 5: syntect-coloured read-only preview of the last saved
    // state of the file, rendered above the editable TextEdit.
    in property <[HighlightedLineData]> editor-highlighted-lines;
    in property <int> editor-line-count: 0;

    // Description tab: labels attached to the active task + dependencies.
    in property <[LabelPillData]> active-task-labels;
    // Potential labels to attach (all available ones the task doesn't have yet).
    in property <[LabelPillData]> active-task-available-labels;
    in property <[TaskCardData]> active-task-dependencies;
    // Polish 7: available dependency candidates (every task that isn't
    // this one and isn't already a prereq and wouldn't create a cycle).
    in property <[TaskCardData]> active-task-available-deps;
    in-out property <bool> label-picker-open: false;
    in-out property <bool> dep-picker-open: false;

    // Git Changes tab data — refreshed ~1×/s while the tab is open.
    in property <[DiffFileData]> git-diff-files;
    in property <[CommitEntryData]> git-commit-log;

    // Right pane tab selection.
    in-out property <string> active-right-tab: "terminal";

    // Polish 16 — open task tabs at the top of the right pane. Each
    // entry is a task the user has "pinned" into the workspace. The
    // `is-active` flag on exactly one entry mirrors `active-task-id`.
    // The strip hides entirely when <2 tabs are open — a single task
    // does not need a tab bar.
    in property <[OpenTaskTabData]> open-task-tabs;
    callback open-task-tab(string);    // task id — make tab active
    callback close-task-tab(string);   // task id — close & fall back

    // Polish 20 — sidebar collapse stub. Wired to a no-op for now;
    // a future polish will actually shrink `sidebar-w` when toggled.
    callback toggle-sidebar();

    callback select-task(string);
    callback move-task-back(string);
    callback move-task-forward(string);
    callback create-task();
    callback title-changed(string);
    callback description-changed(string);
    callback instructions-changed(string);
    callback start-plan(string);
    callback start-implement(string);
    callback filter-changed(string);  // Phase 4: fires when filter-label-id changes
    callback toggle-settings();
    callback settings-base-branch-changed(string);
    callback process-kill(int);        // SIGTERM
    callback process-force-kill(int);  // SIGKILL
    callback refresh-processes();
    callback file-entry-clicked(string, string);   // path, kind
    callback editor-content-changed(string);
    callback editor-save();
    callback editor-close();
    callback attach-label(string);   // label id
    callback detach-label(string);   // label id
    callback remove-dependency(string);  // dep task id
    callback add-dependency(string);     // dep task id
    callback delete-task(string);    // task id
    callback create-project();
    callback project-clicked(string);   // project id
    callback submit-new-task();         // actually inserts the task from the modal fields
    callback add-quick-action();        // opens inline editor with blank row
    callback delete-quick-action(string); // by id
    callback update-quick-action(string, string, string, string); // id, name, kind, body
    // text, ctrl, alt, shift, meta. Meta added in Polish 6 for
    // Cmd-based shortcuts on macOS.
    callback key-pressed(string, bool, bool, bool, bool);

    // Layout constants.
    // Polish 24: sidebar-w switches between full and compact based
    // on `sidebar-collapsed`. The middle and right panes use this
    // in their `x:` positioning so they reflow automatically when
    // the toggle is fired.
    in-out property <bool> sidebar-collapsed: false;
    property <length> sidebar-w: sidebar-collapsed ? 56px : 200px;
    property <length> middle-w: 400px;
    property <length> title-bar-h: 36px;
    property <length> tab-strip-h: 32px;
    property <length> term-w: root.cols * root.cell-w * 1px;
    property <length> term-h: root.rows * root.cell-h * 1px;
    property <length> right-pad-h: 18px;
    property <length> right-pad-v: 14px;

    property <length> status-bar-h: 22px;

    // Polish 16 — height of the open-task tabs strip above the inner
    // Terminal/Description/… strip. Collapses to 0 when ≤1 task is
    // open, so a single-task workflow keeps the original compact look.
    property <length> open-tabs-strip-h: root.open-task-tabs.length >= 2 ? 34px : 0px;

    preferred-width: sidebar-w + middle-w + term-w + right-pad-h * 2 + 2px;
    preferred-height: title-bar-h + tab-strip-h + open-tabs-strip-h + term-h + right-pad-v * 2 + 14px + status-bar-h;
    min-width: sidebar-w + middle-w + term-w + right-pad-h * 2 + 2px;
    min-height: title-bar-h + tab-strip-h + open-tabs-strip-h + term-h + right-pad-v * 2 + 14px + status-bar-h;

    init => { focus-scope.focus(); }

    // ── Title bar ────────────────────────────────────────────────────────────
    Rectangle {
        x: 0; y: 0;
        width: parent.width;
        height: title-bar-h;
        background: Tokens.bg-base;

        Rectangle {
            x: 0; y: parent.height - 1px;
            width: parent.width; height: 1px;
            background: Tokens.border-soft;
        }

        // Traffic-light styled trio (decorative — purely visual).
        HorizontalLayout {
            x: 12px;
            y: (parent.height - self.preferred-height) / 2;
            spacing: 6px;
            Rectangle { width: 11px; height: 11px; border-radius: 5.5px; background: #ff5f57; }
            Rectangle { width: 11px; height: 11px; border-radius: 5.5px; background: #febc2e; }
            Rectangle { width: 11px; height: 11px; border-radius: 5.5px; background: #28c840; }
        }

        // Polish 24 — sidebar toggle (hamburger). Now actually
        // collapses the sidebar to a 56 px icon-only strip via the
        // `sidebar-collapsed` property. Pure Slint, no Rust round-trip.
        TouchArea {
            x: sidebar-w + 8px;
            y: (parent.height - self.height) / 2;
            width: 22px;
            height: 22px;
            clicked => {
                root.sidebar-collapsed = !root.sidebar-collapsed;
                root.toggle-sidebar();
            }
            Text {
                text: "☰";
                color: Tokens.text-tertiary;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
        }

        // Centered app name.
        Text {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            text: "Quay";
            color: Tokens.text-tertiary;
            font-size: 11px;
            font-weight: 600;
        }

        // Polish 27 — active task display id + truncated title.
        // Was just `root.active-task-display` ("#7"); now shows
        // "#7  Add dark mode" so the user has context even when
        // the open-tabs strip is empty (only 1 tab open). The
        // title elides if too long.
        Rectangle {
            x: parent.width - self.width - 44px;
            y: (parent.height - self.height) / 2;
            width: title-info.preferred-width + 4px;
            height: title-info.preferred-height;
            background: transparent;

            title-info := HorizontalLayout {
                spacing: 8px;
                alignment: end;

                Text {
                    text: root.active-task-display;
                    color: Tokens.text-tertiary;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                Text {
                    text: root.active-task-title;
                    color: Tokens.text-secondary;
                    font-size: 11px;
                    font-weight: 500;
                    vertical-alignment: center;
                    overflow: elide;
                    max-width: 240px;
                }
            }
        }

        // Polish 20 — user avatar circle (visual stub, no user system).
        Avatar {
            x: parent.width - self.width - 14px;
            y: (parent.height - self.height) / 2;
        }
    }

    // ── Sidebar ──────────────────────────────────────────────────────────────
    Rectangle {
        x: 0;
        y: title-bar-h;
        width: sidebar-w;
        height: parent.height - title-bar-h;
        background: Tokens.bg-base;

        // Right divider.
        Rectangle {
            x: parent.width - 1px;
            y: 0;
            width: 1px;
            height: parent.height;
            background: Tokens.border-soft;
        }

        VerticalLayout {
            padding: 8px;
            padding-top: 12px;
            spacing: 16px;

            // Menu items.
            VerticalLayout {
                spacing: 2px;
                for item in root.menu-items: MenuRow {
                    item: item;
                    compact: root.sidebar-collapsed;
                    clicked => {
                        if (item.id == "new-task") { root.new-task-open = true; }
                        if (item.id == "configure") { root.toggle-settings(); }
                        if (item.id == "sessions") { root.toggle-settings(); }
                    }
                }
            }

            // Polish 20 — hairline divider before Projects section.
            Rectangle {
                height: 1px;
                background: Tokens.border-very-soft;
            }

            // Projects section.
            VerticalLayout {
                spacing: 4px;

                // Polish 24: hide the "Projects" header + `+` row when
                // the sidebar is collapsed (compact mode shows only
                // icons under it).
                if !root.sidebar-collapsed: HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    height: 22px;
                    spacing: 0px;
                    alignment: start;

                    VerticalLayout {
                        alignment: center;
                        horizontal-stretch: 1;
                        Text {
                            text: "Projects";
                            color: Tokens.text-secondary;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }
                    TouchArea {
                        width: 18px;
                        height: 18px;
                        clicked => { root.new-project-open = true; }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 4px;
                            Text {
                                text: "+";
                                color: Tokens.text-tertiary;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }

                for project in root.projects: ProjectRow {
                    project: project;
                    selected: root.active-project-id == project.id;
                    compact: root.sidebar-collapsed;
                    clicked => {
                        root.project-clicked(project.id);
                    }
                }
            }
        }
    }

    // ── Middle pane: task list ──────────────────────────────────────────────
    Rectangle {
        x: sidebar-w;
        y: title-bar-h;
        width: middle-w;
        height: parent.height - title-bar-h;
        background: Tokens.bg-base;

        Rectangle {
            x: parent.width - 1px;
            y: 0;
            width: 1px;
            height: parent.height;
            background: Tokens.border-soft;
        }

        VerticalLayout {
            spacing: 0px;

            // Filter chips.
            Rectangle {
                height: tab-strip-h;
                background: Tokens.bg-base;

                Rectangle {
                    x: 0; y: parent.height - 1px;
                    width: parent.width; height: 1px;
                    background: Tokens.border-soft;
                }

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 4px;
                    alignment: start;

                    VerticalLayout {
                        alignment: end;
                        FilterChip {
                            label: "All";
                            selected: root.filter-label-id == "";
                            clicked => {
                                root.filter-label-id = "";
                                root.filter-changed("");
                            }
                        }
                    }
                    for lbl in root.all-labels: VerticalLayout {
                        alignment: end;
                        FilterChip {
                            label: lbl.name;
                            selected: root.filter-label-id == lbl.id;
                            clicked => {
                                if root.filter-label-id == lbl.id {
                                    root.filter-label-id = "";
                                    root.filter-changed("");
                                } else {
                                    root.filter-label-id = lbl.id;
                                    root.filter-changed(lbl.id);
                                }
                            }
                        }
                    }
                    // Polish 23: spacer pushes the funnel icon to the
                    // right edge of the strip.
                    Rectangle { horizontal-stretch: 1; }
                    // Polish 23: funnel icon stub. Slint 1.15 has no
                    // dedicated funnel codepoint in its built-in font,
                    // so we use `▽` as the closest visual hint.
                    // Click is a no-op for now — wiring an actual
                    // filter menu is a future polish.
                    VerticalLayout {
                        alignment: end;
                        TouchArea {
                            width: 22px;
                            height: 22px;
                            clicked => { /* stub */ }
                            Text {
                                text: "▽";
                                color: Tokens.text-tertiary;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }
            }

            // Scrollable task list.
            ScrollView {
                vertical-scrollbar-policy: as-needed;

                VerticalLayout {
                    spacing: 0px;

                    // Polish 28 — friendly placeholder when every
                    // section is empty (no tasks at all, or filter
                    // returned zero results). Centered glyph + title +
                    // hint text.
                    if root.kanban-empty: VerticalLayout {
                        padding-top: 80px;
                        padding-left: 24px;
                        padding-right: 24px;
                        spacing: 12px;
                        alignment: start;

                        Text {
                            text: "✦";
                            color: Tokens.text-muted;
                            font-size: 56px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: root.filter-label-id == "" && root.active-project-id == ""
                                ? "No tasks yet"
                                : "No tasks match the current filter";
                            color: Tokens.text-secondary;
                            font-size: 14px;
                            font-weight: 600;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: root.filter-label-id == "" && root.active-project-id == ""
                                ? "Press ⌘N to create your first task"
                                : "Click the active filter chip again to clear it";
                            color: Tokens.text-tertiary;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }

                    // Polish 21: Backlog — always visible.
                    if !root.kanban-empty: VerticalLayout {
                        spacing: 0px;
                        SectionHeader { label: "Backlog"; count: root.tasks-backlog.length; }
                        for task in root.tasks-backlog: CardRow {
                            task: task;
                            spinner-glyph: root.spinner-glyph;
                            selected: task.id == root.active-task-id;
                            clicked => { root.select-task(task.id); }
                            move-back => { root.move-task-back(task.id); }
                            move-forward => { root.move-task-forward(task.id); }
                        }
                    }

                    // Polish 21: Planning + Implementation merged under
                    // a single header. Two consecutive `for` loops
                    // render contiguously — same visual as one combined
                    // model, with zero schema/Rust changes and a single
                    // source of truth (still backed by the original two
                    // VecModels). Always visible — except when the
                    // whole kanban is empty (Polish 28), in which case
                    // the empty-state placeholder takes over.
                    if !root.kanban-empty: VerticalLayout {
                        spacing: 0px;
                        SectionHeader {
                            label: "Planning & Implementation";
                            count: root.tasks-planning.length + root.tasks-implementation.length;
                        }
                        for task in root.tasks-planning: CardRow {
                            task: task;
                            spinner-glyph: root.spinner-glyph;
                            selected: task.id == root.active-task-id;
                            clicked => { root.select-task(task.id); }
                            move-back => { root.move-task-back(task.id); }
                            move-forward => { root.move-task-forward(task.id); }
                        }
                        for task in root.tasks-implementation: CardRow {
                            task: task;
                            spinner-glyph: root.spinner-glyph;
                            selected: task.id == root.active-task-id;
                            clicked => { root.select-task(task.id); }
                            move-back => { root.move-task-back(task.id); }
                            move-forward => { root.move-task-forward(task.id); }
                        }
                    }

                    // Polish 21: Review — hidden when empty.
                    VerticalLayout {
                        visible: root.tasks-review.length > 0;
                        spacing: 0px;
                        SectionHeader { label: "Review"; count: root.tasks-review.length; }
                        for task in root.tasks-review: CardRow {
                            task: task;
                            spinner-glyph: root.spinner-glyph;
                            selected: task.id == root.active-task-id;
                            clicked => { root.select-task(task.id); }
                            move-back => { root.move-task-back(task.id); }
                            move-forward => { root.move-task-forward(task.id); }
                        }
                    }

                    // Polish 21: Done — hidden when empty.
                    VerticalLayout {
                        visible: root.tasks-done.length > 0;
                        spacing: 0px;
                        SectionHeader { label: "Done"; count: root.tasks-done.length; }
                        for task in root.tasks-done: CardRow {
                            task: task;
                            spinner-glyph: root.spinner-glyph;
                            selected: task.id == root.active-task-id;
                            clicked => { root.select-task(task.id); }
                            move-back => { root.move-task-back(task.id); }
                            move-forward => { root.move-task-forward(task.id); }
                        }
                    }

                    // Polish 21: Misc — hidden when empty.
                    VerticalLayout {
                        visible: root.tasks-misc.length > 0;
                        spacing: 0px;
                        SectionHeader { label: "Misc"; count: root.tasks-misc.length; }
                        for task in root.tasks-misc: CardRow {
                            task: task;
                            spinner-glyph: root.spinner-glyph;
                            selected: task.id == root.active-task-id;
                            clicked => { root.select-task(task.id); }
                            move-back => { root.move-task-back(task.id); }
                            move-forward => { root.move-task-forward(task.id); }
                        }
                    }
                }
            }
        }
    }

    // ── Right pane: task detail / terminal ──────────────────────────────────
    Rectangle {
        x: sidebar-w + middle-w;
        y: title-bar-h;
        width: parent.width - sidebar-w - middle-w;
        height: parent.height - title-bar-h;
        background: Tokens.bg-base;

        // Polish 16 — open-task tabs strip. Only visible when ≥2 tabs
        // are pinned; a single-task workflow skips this row entirely so
        // the usual Terminal/Description/Git/Files/History strip stays
        // at the top. The strip scrolls horizontally when many tabs
        // are open so we never truncate the tab text.
        if root.open-task-tabs.length >= 2: Rectangle {
            x: 0; y: 0;
            width: parent.width;
            height: open-tabs-strip-h;
            background: Tokens.bg-base;

            // Bottom separator — visual continuation of the tab strip below.
            Rectangle {
                x: 0; y: parent.height - 1px;
                width: parent.width; height: 1px;
                background: Tokens.border-very-soft;
            }

            Flickable {
                x: 8px;
                y: 4px;
                width: parent.width - 16px;
                height: parent.height - 8px;
                viewport-height: parent.height - 8px;
                viewport-width: tab-row.preferred-width;

                tab-row := HorizontalLayout {
                    spacing: 6px;
                    alignment: start;

                    for tab in root.open-task-tabs: OpenTaskTab {
                        display-label: "#" + tab.display-id + "  " + tab.title;
                        kind: tab.kind;
                        session-state: tab.session-state;
                        active: tab.is-active;
                        spinner-glyph: root.spinner-glyph;
                        clicked => { root.open-task-tab(tab.id); }
                        close-clicked => { root.close-task-tab(tab.id); }
                    }
                }
            }
        }

        // Tab strip
        Rectangle {
            x: 0; y: open-tabs-strip-h;
            width: parent.width;
            height: tab-strip-h;
            background: Tokens.bg-base;

            Rectangle {
                x: 0; y: parent.height - 1px;
                width: parent.width; height: 1px;
                background: Tokens.border-soft;
            }

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 4px;
                alignment: start;

                VerticalLayout { alignment: end;
                    RightTab { label: "Terminal"; glyph: "▶"; selected: root.active-right-tab == "terminal"; clicked => { root.active-right-tab = "terminal"; } }
                }
                VerticalLayout { alignment: end;
                    RightTab { label: "Description"; glyph: "≡"; selected: root.active-right-tab == "description"; clicked => { root.active-right-tab = "description"; } }
                }
                VerticalLayout { alignment: end;
                    RightTab { label: "Git Changes"; glyph: "⎇"; selected: root.active-right-tab == "git"; clicked => { root.active-right-tab = "git"; } }
                }
                VerticalLayout { alignment: end;
                    RightTab { label: "Files"; glyph: "▤"; selected: root.active-right-tab == "files"; clicked => { root.active-right-tab = "files"; } }
                }
                VerticalLayout { alignment: end;
                    RightTab { label: "History"; glyph: "◷"; selected: root.active-right-tab == "history"; clicked => { root.active-right-tab = "history"; } }
                }
            }
        }

        // Terminal area (only visible when active-right-tab == "terminal")
        focus-scope := FocusScope {
            x: right-pad-h;
            y: tab-strip-h + open-tabs-strip-h + right-pad-v;
            width: term-w;
            height: term-h;

            key-pressed(event) => {
                root.key-pressed(
                    event.text,
                    event.modifiers.control,
                    event.modifiers.alt,
                    event.modifiers.shift,
                    event.modifiers.meta,
                );
                accept
            }

            Rectangle {
                background: #07080b;
                border-radius: 6px;
                border-width: 1px;
                border-color: Tokens.border-soft;
                clip: true;

                Image {
                    source: root.frame;
                    x: 0; y: 0;
                    width: parent.width;
                    height: parent.height;
                    image-fit: contain;
                    image-rendering: pixelated;
                }

                // Polish 29 — empty state. Used to be a single line
                // of text; now a glyph + title + actionable hint
                // matching the kanban empty state from Polish 28.
                Rectangle {
                    visible: root.active-task-id == "";
                    background: #07080b;
                    VerticalLayout {
                        x: 0;
                        y: (parent.height - self.preferred-height) / 2;
                        width: parent.width;
                        spacing: 10px;
                        alignment: center;

                        Text {
                            text: "▶";
                            color: Tokens.text-muted;
                            font-size: 48px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "No active session";
                            color: Tokens.text-secondary;
                            font-size: 14px;
                            font-weight: 600;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Click a task in the kanban, then press Plan or Implement.";
                            color: Tokens.text-tertiary;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }

        // Footer status line.
        Text {
            x: right-pad-h + 4px;
            y: parent.height - 22px;
            text: "‖ Quay terminal · esc to interrupt the active session";
            color: Tokens.kind-enhancement;
            font-size: 10px;
        }

        // Description tab — editable text area backed by task.description.
        Rectangle {
            visible: root.active-right-tab == "description";
            x: right-pad-h;
            y: tab-strip-h + open-tabs-strip-h + right-pad-v;
            width: parent.width - right-pad-h * 2;
            height: parent.height - tab-strip-h - open-tabs-strip-h - right-pad-v * 2 - 22px;
            background: #14161a;
            border-radius: 6px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            if root.active-task-id == "": Rectangle {
                VerticalLayout {
                    alignment: center;
                    spacing: 6px;
                    Text {
                        text: "Description";
                        color: Tokens.text-primary;
                        font-size: 13px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "Select a task to read or edit its description.";
                        color: Tokens.text-tertiary;
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }
            }

            if root.active-task-id != "": VerticalLayout {
                padding: 14px;
                spacing: 12px;

                // Display ID + session state chip + delete in a single row.
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: root.active-task-display;
                        color: Tokens.text-tertiary;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }

                    // Delete button — small, unobtrusive, red outline.
                    TouchArea {
                        width: 48px;
                        height: 16px;
                        clicked => { root.delete-task(root.active-task-id); }
                        Rectangle {
                            background: parent.has-hover ? rgba(248, 113, 113, 15%) : transparent;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: rgba(248, 113, 113, 40%);
                            Text {
                                text: "delete";
                                color: Tokens.kind-bug;
                                font-size: 9px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }

                    // Session state badge — small coloured dot + label.
                    Rectangle {
                        width: state-chip.preferred-width + 16px;
                        height: 16px;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: Tokens.border-soft;
                        background: transparent;

                        state-chip := HorizontalLayout {
                            padding-left: 6px;
                            padding-right: 8px;
                            spacing: 5px;
                            alignment: center;

                            VerticalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 6px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background:
                                        root.active-task-session-state == "busy"     ? Tokens.kind-enhancement
                                      : root.active-task-session-state == "awaiting" ? #f5b54e
                                      : root.active-task-session-state == "error"    ? Tokens.kind-bug
                                      : root.active-task-session-state == "exited"   ? Tokens.text-muted
                                      : root.active-task-session-state == "stopped"  ? Tokens.text-muted
                                                                                     : Tokens.text-muted;
                                }
                            }
                            Text {
                                text: root.active-task-session-state;
                                color: Tokens.text-secondary;
                                font-size: 9px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Polish 15 — live agent stats row: tokens, cost, runtime,
                // message count. Only rendered when there's something to
                // show (message_count > 0). The refresh_active_stats timer
                // in main.rs pushes new values every 2s while the task has
                // a captured claude_session_id.
                if root.active-task-message-count > 0: HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    // Tokens chip.
                    Rectangle {
                        width: tokens-text.preferred-width + 16px;
                        height: 18px;
                        border-radius: 9px;
                        border-width: 1px;
                        border-color: Tokens.border-soft;
                        background: rgba(96, 165, 250, 8%);
                        tokens-text := Text {
                            x: 8px;
                            y: 0;
                            width: parent.width - 16px;
                            height: parent.height;
                            text: root.active-task-tokens-text;
                            color: #9bbcf2;
                            font-size: 9px;
                            font-weight: 500;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }

                    // Cost chip.
                    Rectangle {
                        width: cost-text.preferred-width + 16px;
                        height: 18px;
                        border-radius: 9px;
                        border-width: 1px;
                        border-color: Tokens.border-soft;
                        background: rgba(16, 185, 129, 8%);
                        cost-text := Text {
                            x: 8px;
                            y: 0;
                            width: parent.width - 16px;
                            height: parent.height;
                            text: root.active-task-cost-text;
                            color: Tokens.kind-enhancement;
                            font-size: 9px;
                            font-weight: 500;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }

                    // Runtime chip.
                    Rectangle {
                        width: runtime-text.preferred-width + 16px;
                        height: 18px;
                        border-radius: 9px;
                        border-width: 1px;
                        border-color: Tokens.border-soft;
                        background: transparent;
                        runtime-text := Text {
                            x: 8px;
                            y: 0;
                            width: parent.width - 16px;
                            height: parent.height;
                            text: root.active-task-runtime-text;
                            color: Tokens.text-tertiary;
                            font-size: 9px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }

                    // Message count chip.
                    Rectangle {
                        width: msgs-text.preferred-width + 16px;
                        height: 18px;
                        border-radius: 9px;
                        border-width: 1px;
                        border-color: Tokens.border-soft;
                        background: transparent;
                        msgs-text := Text {
                            x: 8px;
                            y: 0;
                            width: parent.width - 16px;
                            height: parent.height;
                            text: root.active-task-message-count + " msgs";
                            color: Tokens.text-tertiary;
                            font-size: 9px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }

                    Rectangle { horizontal-stretch: 1; }
                }

                // Editable title.
                LineEdit {
                    text: root.active-task-title;
                    placeholder-text: "Task title";
                    font-size: 15px;
                    edited(new-text) => {
                        root.title-changed(new-text);
                    }
                }

                Rectangle {
                    height: 1px;
                    background: Tokens.border-very-soft;
                }

                // Instructions — the initial prompt sent to the agent.
                Text {
                    text: "Instructions (sent to the agent on start)";
                    color: Tokens.text-tertiary;
                    font-size: 10px;
                }
                LineEdit {
                    text: root.active-task-instructions;
                    placeholder-text: "e.g. Add dark mode with a toggle in settings — press Enter to Implement";
                    font-size: 12px;
                    edited(new-text) => {
                        root.instructions-changed(new-text);
                    }
                    // Polish 12: pressing Enter inside the Instructions
                    // field fires start-implement — the most common
                    // gesture is "type a quick prompt, hit Enter".
                    accepted(new-text) => {
                        root.instructions-changed(new-text);
                        root.start-implement(root.active-task-id);
                    }
                }

                // Plan / Implement action row (Polish 39 — smooth
                // hover animations + Implement gets a stronger
                // accent border that brightens on hover for a more
                // affirmative "this is the primary action" look).
                HorizontalLayout {
                    spacing: 8px;

                    plan-area := TouchArea {
                        width: 96px;
                        height: 30px;
                        clicked => { root.start-plan(root.active-task-id); }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : #181a23;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: parent.has-hover ? #2b3144 : #23262f;
                            animate background { duration: 120ms; easing: ease-out; }
                            animate border-color { duration: 120ms; easing: ease-out; }
                            HorizontalLayout {
                                alignment: center;
                                Text {
                                    text: "✦ Plan";
                                    color: Tokens.text-primary;
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    implement-area := TouchArea {
                        width: 120px;
                        height: 30px;
                        clicked => { root.start-implement(root.active-task-id); }
                        Rectangle {
                            background: parent.has-hover ? rgba(16, 185, 129, 24%) : rgba(16, 185, 129, 12%);
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: parent.has-hover ? rgba(16, 185, 129, 70%) : rgba(16, 185, 129, 40%);
                            animate background { duration: 120ms; easing: ease-out; }
                            animate border-color { duration: 120ms; easing: ease-out; }
                            HorizontalLayout {
                                alignment: center;
                                Text {
                                    text: "⚡ Implement";
                                    color: Tokens.kind-enhancement;
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Rectangle { horizontal-stretch: 1; }
                }

                Rectangle {
                    height: 1px;
                    background: Tokens.border-very-soft;
                }

                // ── Labels section ─────────────────────────────────
                HorizontalLayout {
                    spacing: 6px;
                    alignment: start;
                    Text {
                        text: "LABELS";
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    TouchArea {
                        width: 20px;
                        height: 16px;
                        clicked => { root.label-picker-open = !root.label-picker-open; }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 3px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            Text {
                                text: "+";
                                color: Tokens.text-secondary;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }

                // Attached labels row — click × to detach.
                HorizontalLayout {
                    spacing: 4px;
                    alignment: start;
                    if root.active-task-labels.length == 0 && !root.label-picker-open: Text {
                        text: "No labels — click + to add one.";
                        color: Tokens.text-tertiary;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                    for label in root.active-task-labels: TouchArea {
                        width: detach-chip.preferred-width + 14px;
                        height: 18px;
                        clicked => { root.detach-label(label.id); }
                        Rectangle {
                            background: rgb(label.color-r, label.color-g, label.color-b);
                            border-radius: 3px;
                            detach-chip := HorizontalLayout {
                                padding-left: 6px;
                                padding-right: 6px;
                                spacing: 4px;
                                alignment: center;
                                Text {
                                    text: label.name;
                                    color: #0b0d11;
                                    font-size: 9px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: "×";
                                    color: #0b0d11;
                                    font-size: 10px;
                                    font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // Label picker — visible only when label-picker-open.
                if root.label-picker-open: Rectangle {
                    height: 54px;
                    background: #0e0f13;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Tokens.border-soft;

                    VerticalLayout {
                        padding: 6px;
                        spacing: 4px;
                        Text {
                            text: "Pick a label to attach";
                            color: Tokens.text-tertiary;
                            font-size: 9px;
                        }
                        HorizontalLayout {
                            spacing: 4px;
                            alignment: start;
                            for available in root.active-task-available-labels: TouchArea {
                                width: pick-chip.preferred-width + 12px;
                                height: 16px;
                                clicked => {
                                    root.attach-label(available.id);
                                    root.label-picker-open = false;
                                }
                                Rectangle {
                                    background: rgb(available.color-r, available.color-g, available.color-b);
                                    border-radius: 3px;
                                    pick-chip := Text {
                                        text: available.name;
                                        color: #0b0d11;
                                        font-size: 9px;
                                        font-weight: 700;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: parent.width;
                                        height: parent.height;
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Dependencies section ───────────────────────────
                HorizontalLayout {
                    spacing: 6px;
                    alignment: start;
                    Text {
                        text: "BLOCKED BY";
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    Text {
                        text: root.active-task-dependencies.length;
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                    TouchArea {
                        width: 20px;
                        height: 16px;
                        clicked => { root.dep-picker-open = !root.dep-picker-open; }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 3px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            Text {
                                text: "+";
                                color: Tokens.text-secondary;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }
                if root.active-task-dependencies.length == 0 && !root.dep-picker-open: Text {
                    text: "No dependencies — click + to add one.";
                    color: Tokens.text-tertiary;
                    font-size: 10px;
                }

                // Dep picker drawer
                if root.dep-picker-open: Rectangle {
                    height: 90px;
                    background: #0e0f13;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Tokens.border-soft;

                    VerticalLayout {
                        padding: 6px;
                        spacing: 4px;
                        Text {
                            text: "Pick a task to depend on";
                            color: Tokens.text-tertiary;
                            font-size: 9px;
                        }
                        ScrollView {
                            vertical-stretch: 1;
                            VerticalLayout {
                                spacing: 2px;
                                if root.active-task-available-deps.length == 0: Text {
                                    text: "No candidate tasks.";
                                    color: Tokens.text-tertiary;
                                    font-size: 10px;
                                }
                                for candidate in root.active-task-available-deps: TouchArea {
                                    height: 20px;
                                    clicked => {
                                        root.add-dependency(candidate.id);
                                        root.dep-picker-open = false;
                                    }
                                    Rectangle {
                                        background: parent.has-hover ? #1f2331 : transparent;
                                        border-radius: 3px;
                                        HorizontalLayout {
                                            padding-left: 8px;
                                            padding-right: 8px;
                                            spacing: 6px;
                                            alignment: start;
                                            Text {
                                                text: "#" + candidate.display-id;
                                                color: Tokens.text-tertiary;
                                                font-size: 9px;
                                                font-family: "JetBrains Mono";
                                                vertical-alignment: center;
                                            }
                                            Text {
                                                text: candidate.title;
                                                color: Tokens.text-primary;
                                                font-size: 10px;
                                                vertical-alignment: center;
                                                overflow: elide;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                for dep in root.active-task-dependencies: Rectangle {
                    height: 22px;
                    background: #0e0f13;
                    border-radius: 3px;
                    border-width: 1px;
                    border-color: Tokens.border-soft;
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 4px;
                        spacing: 6px;
                        alignment: start;
                        Text {
                            text: "#" + dep.display-id;
                            color: Tokens.text-tertiary;
                            font-size: 9px;
                            font-family: "JetBrains Mono";
                            vertical-alignment: center;
                        }
                        Text {
                            text: dep.title;
                            color: Tokens.text-secondary;
                            font-size: 10px;
                            vertical-alignment: center;
                            overflow: elide;
                        }
                        Rectangle { horizontal-stretch: 1; }
                        CloseButton {
                            size: 16px;
                            clicked => { root.remove-dependency(dep.id); }
                        }
                    }
                }

                Rectangle {
                    height: 1px;
                    background: Tokens.border-very-soft;
                }

                Text {
                    text: "Description";
                    color: Tokens.text-tertiary;
                    font-size: 10px;
                }

                TextEdit {
                    text: root.active-task-description;
                    placeholder-text: "Add a description, notes for the agent, acceptance criteria…";
                    wrap: word-wrap;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    edited => {
                        root.description-changed(self.text);
                    }
                }
            }
        }

        // Git Changes tab — live diff + commit log for the active task's worktree.
        Rectangle {
            visible: root.active-right-tab == "git";
            x: right-pad-h;
            y: tab-strip-h + open-tabs-strip-h + right-pad-v;
            width: parent.width - right-pad-h * 2;
            height: parent.height - tab-strip-h - open-tabs-strip-h - right-pad-v * 2 - 22px;
            background: #14161a;
            border-radius: 6px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            if root.active-task-id == "" || (root.git-diff-files.length == 0 && root.git-commit-log.length == 0): Rectangle {
                VerticalLayout {
                    alignment: center;
                    spacing: 6px;
                    Text {
                        text: "Git Changes";
                        color: Tokens.text-primary;
                        font-size: 13px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: root.active-task-id == "" ? "Select a task with a git worktree to see changes." : "No changes yet.";
                        color: Tokens.text-tertiary;
                        font-size: 11px;
                        horizontal-alignment: center;
                    }
                }
            }

            if root.active-task-id != "" && (root.git-diff-files.length > 0 || root.git-commit-log.length > 0): VerticalLayout {
                padding: 12px;
                spacing: 10px;

                // Changed files header.
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "Changed files";
                        color: Tokens.text-secondary;
                        font-size: 10px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; height: 1px; }
                    Text {
                        text: root.git-diff-files.length;
                        color: Tokens.text-tertiary;
                        font-size: 10px;
                    }
                }

                // Files list + patches — scrolls together.
                ScrollView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 8px;

                        for f in root.git-diff-files: Rectangle {
                            background: #0e0f13;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;

                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;
                                    Rectangle {
                                        width: 18px;
                                        height: 14px;
                                        border-radius: 3px;
                                        background: f.status == "A" ? rgba(16, 185, 129, 20%)
                                                   : f.status == "M" ? rgba(245, 181, 78, 20%)
                                                   : f.status == "D" ? rgba(248, 113, 113, 20%)
                                                                     : rgba(167, 175, 184, 15%);
                                        Text {
                                            text: f.status;
                                            color: f.status == "A" ? Tokens.kind-enhancement
                                                 : f.status == "M" ? #f5b54e
                                                 : f.status == "D" ? Tokens.kind-bug
                                                                    : Tokens.text-secondary;
                                            font-size: 9px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }
                                    Text {
                                        text: f.path;
                                        color: Tokens.text-primary;
                                        font-size: 11px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Text {
                                        text: "+" + f.additions;
                                        color: Tokens.kind-enhancement;
                                        font-size: 10px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "-" + f.deletions;
                                        color: Tokens.kind-bug;
                                        font-size: 10px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                    }
                                }

                                // Per-line diff rendering (Polish 14):
                                // each physical line is one Text element
                                // coloured by its origin char — green for
                                // +, red for -, muted grey for context.
                                // Slint handles a few hundred elements
                                // per file comfortably; large diffs may
                                // benefit from virtualisation later.
                                for dl in f.lines: HorizontalLayout {
                                    spacing: 0px;
                                    Rectangle {
                                        width: 10px;
                                        Text {
                                            text: dl.origin;
                                            color: dl.origin == "+" ? Tokens.kind-enhancement
                                                 : dl.origin == "-" ? Tokens.kind-bug
                                                                    : Tokens.text-muted;
                                            font-size: 10px;
                                            font-family: "JetBrains Mono";
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }
                                    Text {
                                        text: dl.text;
                                        color: dl.origin == "+" ? Tokens.kind-enhancement
                                             : dl.origin == "-" ? Tokens.kind-bug
                                             : dl.origin == "H" ? Tokens.kind-feature
                                             : dl.origin == "F" ? Tokens.text-secondary
                                                                : Tokens.text-tertiary;
                                        font-size: 10px;
                                        font-family: "JetBrains Mono";
                                        wrap: no-wrap;
                                    }
                                }
                            }
                        }

                        // Commit log section.
                        if root.git-commit-log.length > 0: Rectangle {
                            height: 1px;
                            background: Tokens.border-very-soft;
                        }

                        if root.git-commit-log.length > 0: HorizontalLayout {
                            spacing: 6px;
                            Text {
                                text: "Commits on this branch";
                                color: Tokens.text-secondary;
                                font-size: 10px;
                                font-weight: 700;
                            }
                            Rectangle { horizontal-stretch: 1; height: 1px; }
                            Text {
                                text: root.git-commit-log.length;
                                color: Tokens.text-tertiary;
                                font-size: 10px;
                            }
                        }

                        for c in root.git-commit-log: Rectangle {
                            background: #0e0f13;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            VerticalLayout {
                                padding: 6px;
                                padding-left: 10px;
                                spacing: 2px;
                                HorizontalLayout {
                                    spacing: 8px;
                                    Text {
                                        text: c.sha-short;
                                        color: Tokens.kind-feature;
                                        font-size: 10px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: c.summary;
                                        color: Tokens.text-primary;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    Rectangle { horizontal-stretch: 1; }
                                    Text {
                                        text: c.timestamp;
                                        color: Tokens.text-tertiary;
                                        font-size: 9px;
                                        vertical-alignment: center;
                                    }
                                }
                                Text {
                                    text: c.author-name;
                                    color: Tokens.text-tertiary;
                                    font-size: 9px;
                                }
                            }
                        }
                    }
                }
            }
        }

        // Files tab — shows either the directory listing or the inline
        // editor, depending on `editor-open`.
        Rectangle {
            visible: root.active-right-tab == "files";
            x: right-pad-h;
            y: tab-strip-h + open-tabs-strip-h + right-pad-v;
            width: parent.width - right-pad-h * 2;
            height: parent.height - tab-strip-h - open-tabs-strip-h - right-pad-v * 2 - 22px;
            background: #14161a;
            border-radius: 6px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            // ── File tree mode ─────────────────────────────────────
            if !root.editor-open: VerticalLayout {
                padding: 12px;
                spacing: 8px;

                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "▸";
                        color: Tokens.text-tertiary;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.file-current-dir == "" ? "Select a task with a worktree" : root.file-current-dir;
                        color: Tokens.text-primary;
                        font-size: 11px;
                        font-family: "JetBrains Mono";
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }

                Rectangle { height: 1px; background: Tokens.border-very-soft; }

                ScrollView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 1px;
                        // Polish 17 — each row is one entry in the
                        // flattened tree. Left padding scales with
                        // `depth` so nested entries indent. Directory
                        // chevron flips ▸ ↔ ▾ based on `expanded`.
                        for entry in root.file-entries: TouchArea {
                            height: 22px;
                            clicked => {
                                root.file-entry-clicked(entry.path, entry.kind);
                            }
                            Rectangle {
                                background: parent.has-hover ? #1f2331 : transparent;
                                border-radius: 3px;
                                HorizontalLayout {
                                    padding-left: 10px + entry.depth * 14px;
                                    padding-right: 8px;
                                    spacing: 6px;
                                    alignment: start;
                                    Text {
                                        text: entry.kind == "directory"
                                               ? (entry.expanded ? "▾" : "▸")
                                               : " ";
                                        color: Tokens.text-secondary;
                                        font-size: 10px;
                                        vertical-alignment: center;
                                        width: 10px;
                                    }
                                    Text {
                                        text: entry.kind == "directory" ? "▤" : "·";
                                        color: entry.kind == "directory"
                                               ? Tokens.kind-feature
                                               : Tokens.text-tertiary;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: entry.name;
                                        color: Tokens.text-primary;
                                        font-size: 11px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }

                Text {
                    text: "Click a text file to open it in the built-in editor. Binary or very large files fall back to $EDITOR.";
                    color: Tokens.text-tertiary;
                    font-size: 9px;
                }
            }

            // ── Inline editor mode (Phase 7) ───────────────────────
            if root.editor-open: VerticalLayout {
                padding: 12px;
                spacing: 8px;

                // Header with path, syntax, dirty indicator, save/close buttons.
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;

                    // Back / close button.
                    TouchArea {
                        width: 22px;
                        height: 22px;
                        clicked => { root.editor-close(); }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 4px;
                            Text {
                                text: "←";
                                color: Tokens.text-secondary;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }

                    Text {
                        text: root.editor-file-path;
                        color: Tokens.text-primary;
                        font-size: 11px;
                        font-family: "JetBrains Mono";
                        overflow: elide;
                        vertical-alignment: center;
                    }

                    // Dirty dot.
                    Rectangle {
                        visible: root.editor-file-dirty;
                        width: 6px;
                        height: 6px;
                        y: (parent.height - self.height) / 2;
                        border-radius: 3px;
                        background: #f5b54e;
                    }

                    Rectangle { horizontal-stretch: 1; }

                    // Syntax badge.
                    Rectangle {
                        width: syn-text.preferred-width + 12px;
                        height: 18px;
                        border-radius: 9px;
                        border-width: 1px;
                        border-color: Tokens.border-soft;
                        syn-text := Text {
                            text: root.editor-syntax-name;
                            color: Tokens.text-secondary;
                            font-size: 9px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }

                    // Save button.
                    TouchArea {
                        width: 56px;
                        height: 22px;
                        clicked => { root.editor-save(); }
                        Rectangle {
                            background: parent.has-hover ? rgba(16, 185, 129, 20%) : rgba(16, 185, 129, 12%);
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: rgba(16, 185, 129, 40%);
                            Text {
                                text: "save";
                                color: Tokens.kind-enhancement;
                                font-size: 10px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Tokens.border-very-soft; }

                // ── Syntect-coloured read-only preview ──────────────
                // Shows the last saved state of the file with per-token
                // colouring. Updates on save so it always reflects
                // disk state.
                Rectangle {
                    height: 220px;
                    background: #0a0b0e;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: Tokens.border-soft;
                    clip: true;

                    ScrollView {
                        VerticalLayout {
                            padding: 8px;
                            spacing: 0px;
                            if root.editor-line-count == 0: Text {
                                text: "(empty file)";
                                color: Tokens.text-tertiary;
                                font-size: 10px;
                                font-family: "JetBrains Mono";
                            }
                            for line in root.editor-highlighted-lines: HorizontalLayout {
                                spacing: 8px;
                                alignment: start;
                                Text {
                                    text: line.line-no;
                                    color: Tokens.text-muted;
                                    font-size: 10px;
                                    font-family: "JetBrains Mono";
                                    width: 32px;
                                    horizontal-alignment: right;
                                }
                                HorizontalLayout {
                                    spacing: 0px;
                                    alignment: start;
                                    horizontal-stretch: 1;
                                    for span in line.spans: Text {
                                        text: span.text;
                                        color: rgb(span.color-r, span.color-g, span.color-b);
                                        font-size: 11px;
                                        font-family: "JetBrains Mono";
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Editable TextEdit ───────────────────────────────
                // Plain (non-coloured) text editing surface. Slint's
                // built-in TextEdit doesn't support per-token colour so
                // editing happens in uniform text; the preview above
                // shows the colours for the last saved state.
                TextEdit {
                    text: root.editor-file-content;
                    wrap: no-wrap;
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    font-size: 12px;
                    edited => {
                        root.editor-content-changed(self.text);
                    }
                }

                Text {
                    text: "Top pane: syntect-coloured preview of the last saved state. Bottom pane: plain editable text. Save to refresh the preview.";
                    color: Tokens.text-tertiary;
                    font-size: 9px;
                }
            }
        }

        // History placeholder — stays while Fase 5 defers the real
        // transcript browser.
        Rectangle {
            visible: root.active-right-tab == "history";
            x: right-pad-h;
            y: tab-strip-h + open-tabs-strip-h + right-pad-v;
            width: parent.width - right-pad-h * 2;
            height: parent.height - tab-strip-h - open-tabs-strip-h - right-pad-v * 2 - 22px;
            background: #14161a;
            border-radius: 6px;
            border-width: 1px;
            border-color: Tokens.border-soft;

            VerticalLayout {
                alignment: center;
                spacing: 8px;
                Text {
                    text: "History";
                    color: Tokens.text-primary;
                    font-size: 13px;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Session transcript browser — coming in Phase 6.";
                    color: Tokens.text-tertiary;
                    font-size: 11px;
                    horizontal-alignment: center;
                }
            }
        }
    }

    // ── Polish 25 + 31: notification toast ──────────────────────────────
    // Floats above the status bar, anchored bottom-right. Polish 31
    // animates a vertical offset so the chip slides up by 16 px when
    // visible — combined with the opacity animation inside the Toast
    // component, the result is a smooth fade-up entrance and
    // fade-down exit.
    toast := Toast {
        x: parent.width - self.width - 16px;
        y: parent.height - status-bar-h - self.height - (root.toast-visible ? 12px : -4px);
        width: 320px;
        message: root.toast-message;
        kind: root.toast-kind;
        visible-toast: root.toast-visible;
        animate y { duration: 220ms; easing: ease-out; }
    }

    // ── Status bar (Polish 13) ──────────────────────────────────────────
    Rectangle {
        x: 0;
        y: parent.height - status-bar-h;
        width: parent.width;
        height: status-bar-h;
        background: #11131a;

        Rectangle {
            x: 0; y: 0;
            width: parent.width; height: 1px;
            background: Tokens.border-soft;
        }

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            spacing: 12px;
            alignment: start;

            Text {
                text: "Backlog " + root.stats-backlog;
                color: Tokens.text-tertiary;
                font-size: 9px;
                vertical-alignment: center;
            }
            Text { text: "·"; color: Tokens.text-muted; font-size: 9px; vertical-alignment: center; }
            Text {
                text: "Planning " + root.stats-planning;
                color: Tokens.text-tertiary;
                font-size: 9px;
                vertical-alignment: center;
            }
            Text { text: "·"; color: Tokens.text-muted; font-size: 9px; vertical-alignment: center; }
            Text {
                text: "Impl " + root.stats-implementation;
                color: Tokens.text-tertiary;
                font-size: 9px;
                vertical-alignment: center;
            }
            Text { text: "·"; color: Tokens.text-muted; font-size: 9px; vertical-alignment: center; }
            Text {
                text: "Review " + root.stats-review;
                color: Tokens.text-tertiary;
                font-size: 9px;
                vertical-alignment: center;
            }
            Text { text: "·"; color: Tokens.text-muted; font-size: 9px; vertical-alignment: center; }
            Text {
                text: "Done " + root.stats-done;
                color: Tokens.text-tertiary;
                font-size: 9px;
                vertical-alignment: center;
            }
            Text { text: "·"; color: Tokens.text-muted; font-size: 9px; vertical-alignment: center; }
            Text {
                text: "Misc " + root.stats-misc;
                color: Tokens.text-tertiary;
                font-size: 9px;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            Text {
                text: root.stats-sessions + " live session" + (root.stats-sessions == 1 ? "" : "s");
                color: root.stats-sessions > 0 ? Tokens.kind-enhancement : Tokens.text-tertiary;
                font-size: 9px;
                vertical-alignment: center;
            }
            Text { text: "·"; color: Tokens.text-muted; font-size: 9px; vertical-alignment: center; }
            Text {
                text: root.stats-total + " tasks total";
                color: Tokens.text-tertiary;
                font-size: 9px;
                vertical-alignment: center;
            }
        }
    }

    // ── New Task modal overlay (Polish 10 / 32) ─────────────────────────
    Rectangle {
        visible: root.new-task-open;
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 60%);
        // Polish 32 — fade scrim in/out so the modal doesn't snap.
        // The `visible` boolean still mounts/unmounts the subtree
        // (the animation is short enough that the snap to invisible
        // on `visible: false` is imperceptible).
        opacity: root.new-task-open ? 1.0 : 0.0;
        animate opacity { duration: 160ms; easing: ease-out; }

        TouchArea {
            clicked => { root.new-task-open = false; }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            // Polish 33 — slide-down + fade. The card lands into
            // place from 12 px above when the modal opens, so the
            // user perceives it appearing rather than snapping.
            y: (parent.height - self.height) / 2 + (root.new-task-open ? 0px : -12px);
            opacity: root.new-task-open ? 1.0 : 0.0;
            animate y { duration: 200ms; easing: ease-out; }
            animate opacity { duration: 180ms; easing: ease-out; }
            width: 460px;
            height: 320px;
            background: #14161a;
            border-radius: 10px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            TouchArea { }

            VerticalLayout {
                padding: 20px;
                spacing: 12px;

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "New Task";
                        color: Tokens.text-primary;
                        font-size: 15px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    CloseButton {
                        clicked => { root.new-task-open = false; }
                    }
                }

                Rectangle { height: 1px; background: Tokens.border-very-soft; }

                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "Title";
                        color: Tokens.text-secondary;
                        font-size: 10px;
                    }
                    LineEdit {
                        text: root.new-task-title;
                        placeholder-text: "e.g. Add dark mode";
                        font-size: 13px;
                        edited(t) => { root.new-task-title = t; }
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "Initial instructions (sent to the agent on start)";
                        color: Tokens.text-secondary;
                        font-size: 10px;
                    }
                    LineEdit {
                        text: root.new-task-instructions;
                        placeholder-text: "optional — what should the agent do first?";
                        font-size: 12px;
                        edited(t) => { root.new-task-instructions = t; }
                    }
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    TouchArea {
                        width: 72px;
                        height: 28px;
                        clicked => { root.new-task-open = false; }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            Text {
                                text: "Cancel";
                                color: Tokens.text-secondary;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                    TouchArea {
                        width: 84px;
                        height: 28px;
                        clicked => { root.submit-new-task(); }
                        Rectangle {
                            background: parent.has-hover ? rgba(96, 165, 250, 20%) : rgba(96, 165, 250, 12%);
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: rgba(96, 165, 250, 40%);
                            Text {
                                text: "Create";
                                color: Tokens.kind-feature;
                                font-size: 11px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }
            }
        }
    }

    // ── New Project modal overlay (Polish 8 / 32) ───────────────────────
    Rectangle {
        visible: root.new-project-open;
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 60%);
        opacity: root.new-project-open ? 1.0 : 0.0;
        animate opacity { duration: 160ms; easing: ease-out; }

        TouchArea {
            clicked => { root.new-project-open = false; }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            // Polish 33 — slide-down + fade.
            y: (parent.height - self.height) / 2 + (root.new-project-open ? 0px : -12px);
            opacity: root.new-project-open ? 1.0 : 0.0;
            animate y { duration: 200ms; easing: ease-out; }
            animate opacity { duration: 180ms; easing: ease-out; }
            width: 420px;
            height: 320px;
            background: #14161a;
            border-radius: 10px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            TouchArea { }   // swallow clicks so the backdrop close doesn't fire

            VerticalLayout {
                padding: 20px;
                spacing: 12px;

                // Header
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text {
                        text: "New Project";
                        color: Tokens.text-primary;
                        font-size: 15px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    CloseButton {
                        clicked => { root.new-project-open = false; }
                    }
                }

                Rectangle { height: 1px; background: Tokens.border-very-soft; }

                // Name
                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "Name";
                        color: Tokens.text-secondary;
                        font-size: 10px;
                    }
                    LineEdit {
                        text: root.new-project-name;
                        placeholder-text: "e.g. my-backend";
                        font-size: 12px;
                        edited(t) => { root.new-project-name = t; }
                    }
                }

                // Repo path
                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "Repository path";
                        color: Tokens.text-secondary;
                        font-size: 10px;
                    }
                    LineEdit {
                        text: root.new-project-repo-path;
                        placeholder-text: "/absolute/path/to/repo";
                        font-size: 12px;
                        edited(t) => { root.new-project-repo-path = t; }
                    }
                }

                // Base branch
                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "Base branch";
                        color: Tokens.text-secondary;
                        font-size: 10px;
                    }
                    LineEdit {
                        text: root.new-project-base-branch;
                        placeholder-text: "main";
                        font-size: 12px;
                        edited(t) => { root.new-project-base-branch = t; }
                    }
                }

                Rectangle { vertical-stretch: 1; }

                // Actions
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { horizontal-stretch: 1; }
                    TouchArea {
                        width: 72px;
                        height: 28px;
                        clicked => { root.new-project-open = false; }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            Text {
                                text: "Cancel";
                                color: Tokens.text-secondary;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                    TouchArea {
                        width: 84px;
                        height: 28px;
                        clicked => { root.create-project(); }
                        Rectangle {
                            background: parent.has-hover ? rgba(16, 185, 129, 20%) : rgba(16, 185, 129, 12%);
                            border-radius: 6px;
                            border-width: 1px;
                            border-color: rgba(16, 185, 129, 40%);
                            Text {
                                text: "Create";
                                color: Tokens.kind-enhancement;
                                font-size: 11px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Settings modal overlay (Polish 32 fade) ─────────────────────────
    Rectangle {
        visible: root.settings-open;
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 60%);
        opacity: root.settings-open ? 1.0 : 0.0;
        animate opacity { duration: 160ms; easing: ease-out; }

        // Click outside the card closes the modal.
        TouchArea {
            clicked => { root.settings-open = false; }
        }

        Rectangle {
            // Centered card.
            x: (parent.width - self.width) / 2;
            // Polish 33 — slide-down + fade.
            y: (parent.height - self.height) / 2 + (root.settings-open ? 0px : -12px);
            opacity: root.settings-open ? 1.0 : 0.0;
            animate y { duration: 200ms; easing: ease-out; }
            animate opacity { duration: 180ms; easing: ease-out; }
            width: 640px;
            height: 560px;
            background: #14161a;
            border-radius: 10px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            // Click inside the card — swallow so it doesn't close the modal.
            TouchArea { }

            VerticalLayout {
                padding: 20px;
                spacing: 14px;

                // Header row with title + close button.
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    Text {
                        text: "Settings";
                        color: Tokens.text-primary;
                        font-size: 16px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    CloseButton {
                        size: 24px;
                        clicked => { root.settings-open = false; }
                    }
                }

                Rectangle { height: 1px; background: Tokens.border-very-soft; }

                // ── General section ───────────────────────────────────
                Text {
                    text: "GENERAL";
                    color: Tokens.text-tertiary;
                    font-size: 9px;
                    font-weight: 700;
                }

                VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: "Default base branch";
                        color: Tokens.text-secondary;
                        font-size: 11px;
                    }
                    LineEdit {
                        text: root.settings-default-base-branch;
                        placeholder-text: "main";
                        font-size: 12px;
                        edited(new-text) => {
                            root.settings-base-branch-changed(new-text);
                        }
                    }
                }

                // ── Quick Actions section ─────────────────────────────
                Rectangle { height: 1px; background: Tokens.border-very-soft; }
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "QUICK ACTIONS";
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    Rectangle { horizontal-stretch: 1; height: 1px; }
                    Text {
                        text: root.settings-quick-actions.length;
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                    TouchArea {
                        width: 20px;
                        height: 16px;
                        clicked => { root.add-quick-action(); }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 3px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            Text {
                                text: "+";
                                color: Tokens.text-secondary;
                                font-size: 11px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }

                ScrollView {
                    height: 180px;
                    VerticalLayout {
                        spacing: 4px;
                        for qa in root.settings-quick-actions: Rectangle {
                            height: 48px;
                            background: #0e0f13;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;

                            VerticalLayout {
                                padding: 6px;
                                padding-left: 10px;
                                padding-right: 10px;
                                spacing: 2px;

                                // Top row: shortcut + name input + kind toggle + delete.
                                HorizontalLayout {
                                    spacing: 8px;
                                    alignment: start;
                                    VerticalLayout {
                                        alignment: center;
                                        width: 34px;
                                        Text {
                                            text: qa.shortcut == "" ? "—" : qa.shortcut;
                                            color: Tokens.text-tertiary;
                                            font-size: 9px;
                                            font-family: "JetBrains Mono";
                                        }
                                    }
                                    qa-name := LineEdit {
                                        horizontal-stretch: 1;
                                        text: qa.name;
                                        font-size: 11px;
                                        placeholder-text: "name";
                                        edited(t) => {
                                            root.update-quick-action(qa.id, t, qa.kind, qa-body.text);
                                        }
                                    }

                                    // Kind toggle: click to flip claude ↔ shell.
                                    TouchArea {
                                        width: 56px;
                                        height: 20px;
                                        clicked => {
                                            root.update-quick-action(
                                                qa.id,
                                                qa-name.text,
                                                qa.kind == "claude" ? "shell" : "claude",
                                                qa-body.text,
                                            );
                                        }
                                        Rectangle {
                                            background: parent.has-hover ? #1f2331 : transparent;
                                            border-radius: 3px;
                                            border-width: 1px;
                                            border-color: Tokens.border-soft;
                                            Text {
                                                text: qa.kind;
                                                color: qa.kind == "claude" ? Tokens.kind-feature : Tokens.kind-enhancement;
                                                font-size: 9px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                width: parent.width;
                                                height: parent.height;
                                            }
                                        }
                                    }

                                    // Delete button.
                                    CloseButton {
                                        size: 20px;
                                        clicked => { root.delete-quick-action(qa.id); }
                                    }
                                }

                                // Bottom row: body input (prompt or shell command).
                                qa-body := LineEdit {
                                    text: qa.body;
                                    font-size: 10px;
                                    placeholder-text: qa.kind == "claude" ? "prompt text…" : "shell command…";
                                    edited(t) => {
                                        root.update-quick-action(qa.id, qa-name.text, qa.kind, t);
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Process Manager section ───────────────────────────
                Rectangle { height: 1px; background: Tokens.border-very-soft; }
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "PROCESSES";
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; height: 1px; }
                    TouchArea {
                        width: 56px;
                        height: 16px;
                        clicked => { root.refresh-processes(); }
                        Rectangle {
                            background: parent.has-hover ? #1f2331 : transparent;
                            border-radius: 3px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            Text {
                                text: "↻ refresh";
                                color: Tokens.text-secondary;
                                font-size: 9px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                    Text {
                        text: root.settings-processes.length;
                        color: Tokens.text-tertiary;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                }

                ScrollView {
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 4px;
                        if root.settings-processes.length == 0: Text {
                            text: "No agent processes detected.";
                            color: Tokens.text-tertiary;
                            font-size: 11px;
                        }
                        for p in root.settings-processes: Rectangle {
                            height: 32px;
                            background: #0e0f13;
                            border-radius: 4px;
                            border-width: 1px;
                            border-color: Tokens.border-soft;
                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 6px;
                                spacing: 8px;
                                alignment: start;
                                VerticalLayout {
                                    alignment: center;
                                    Rectangle {
                                        width: 8px;
                                        height: 8px;
                                        border-radius: 4px;
                                        background: p.class == "tracked" ? Tokens.kind-enhancement
                                                  : p.class == "orphan" ? Tokens.kind-bug
                                                                         : #f5b54e;
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: p.name + "  " + p.pid;
                                        color: Tokens.text-primary;
                                        font-size: 11px;
                                        font-family: "JetBrains Mono";
                                    }
                                    Text {
                                        text: p.class;
                                        color: Tokens.text-tertiary;
                                        font-size: 9px;
                                    }
                                }
                                TouchArea {
                                    width: 52px;
                                    height: 22px;
                                    clicked => { root.process-kill(p.pid); }
                                    Rectangle {
                                        background: parent.has-hover ? rgba(245, 181, 78, 15%) : transparent;
                                        border-radius: 3px;
                                        border-width: 1px;
                                        border-color: rgba(245, 181, 78, 40%);
                                        Text {
                                            text: "stop";
                                            color: #f5b54e;
                                            font-size: 9px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }
                                }
                                TouchArea {
                                    width: 52px;
                                    height: 22px;
                                    clicked => { root.process-force-kill(p.pid); }
                                    Rectangle {
                                        background: parent.has-hover ? rgba(248, 113, 113, 15%) : transparent;
                                        border-radius: 3px;
                                        border-width: 1px;
                                        border-color: rgba(248, 113, 113, 40%);
                                        Text {
                                            text: "kill";
                                            color: Tokens.kind-bug;
                                            font-size: 9px;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Polish 26 + 32: Keyboard shortcuts overlay ──────────────────────
    Rectangle {
        visible: root.shortcuts-open;
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 60%);
        opacity: root.shortcuts-open ? 1.0 : 0.0;
        animate opacity { duration: 160ms; easing: ease-out; }

        TouchArea {
            clicked => { root.shortcuts-open = false; }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            // Polish 33 — slide-down + fade.
            y: (parent.height - self.height) / 2 + (root.shortcuts-open ? 0px : -12px);
            opacity: root.shortcuts-open ? 1.0 : 0.0;
            animate y { duration: 200ms; easing: ease-out; }
            animate opacity { duration: 180ms; easing: ease-out; }
            width: 540px;
            height: 460px;
            background: #14161a;
            border-radius: 10px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            // Block click-through.
            TouchArea { }

            VerticalLayout {
                padding: 24px;
                spacing: 14px;

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "Keyboard Shortcuts";
                        color: Tokens.text-primary;
                        font-size: 16px;
                        font-weight: 700;
                    }
                    Rectangle { horizontal-stretch: 1; }
                    CloseButton {
                        size: 24px;
                        clicked => { root.shortcuts-open = false; }
                    }
                }

                Rectangle { height: 1px; background: Tokens.border-very-soft; }

                // Two-column layout: category (left) + shortcut rows (right).
                VerticalLayout {
                    spacing: 16px;

                    // Tasks group
                    VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: "TASKS";
                            color: Tokens.text-tertiary;
                            font-size: 9px;
                            font-weight: 700;
                        }
                        ShortcutRow { keys: "⌘N"; label: "Create new task in Backlog"; }
                        ShortcutRow { keys: "⌘D"; label: "Move active task forward"; }
                        ShortcutRow { keys: "⌘⌫"; label: "Delete active task"; }
                        ShortcutRow { keys: "Enter"; label: "(in Instructions field) Start Implement"; }
                    }

                    // Tabs group
                    VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: "OPEN TABS";
                            color: Tokens.text-tertiary;
                            font-size: 9px;
                            font-weight: 700;
                        }
                        ShortcutRow { keys: "⌘W"; label: "Close active tab"; }
                        ShortcutRow { keys: "⌘⇧]"; label: "Cycle to next tab"; }
                        ShortcutRow { keys: "⌘⇧["; label: "Cycle to previous tab"; }
                    }

                    // Quick Actions group
                    VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: "QUICK ACTIONS";
                            color: Tokens.text-tertiary;
                            font-size: 9px;
                            font-weight: 700;
                        }
                        ShortcutRow { keys: "⌘⌥1..9"; label: "Run quick action by index"; }
                    }

                    // System group
                    VerticalLayout {
                        spacing: 4px;
                        Text {
                            text: "SYSTEM";
                            color: Tokens.text-tertiary;
                            font-size: 9px;
                            font-weight: 700;
                        }
                        ShortcutRow { keys: "⌘P"; label: "Quick task switcher"; }
                        ShortcutRow { keys: "⌘,"; label: "Open Settings"; }
                        ShortcutRow { keys: "⌘?"; label: "Show this overlay"; }
                        ShortcutRow { keys: "Esc"; label: "Close any open modal"; }
                    }
                }

                Rectangle { vertical-stretch: 1; }

                Text {
                    text: "Tip: ⌘ on macOS, Ctrl elsewhere. Esc closes this overlay.";
                    color: Tokens.text-tertiary;
                    font-size: 9px;
                    horizontal-alignment: center;
                }
            }
        }
    }

    // ── Polish 35: Cmd+P task quick switcher ────────────────────────────
    Rectangle {
        visible: root.task-search-open;
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        background: rgba(0, 0, 0, 60%);
        opacity: root.task-search-open ? 1.0 : 0.0;
        animate opacity { duration: 160ms; easing: ease-out; }

        TouchArea {
            clicked => { root.task-search-open = false; }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            // Anchor near the top — search modals feel right at ~18% of viewport.
            y: parent.height * 0.16 + (root.task-search-open ? 0px : -12px);
            opacity: root.task-search-open ? 1.0 : 0.0;
            animate y { duration: 200ms; easing: ease-out; }
            animate opacity { duration: 180ms; easing: ease-out; }
            width: 540px;
            height: 380px;
            background: #14161a;
            border-radius: 10px;
            border-width: 1px;
            border-color: Tokens.border-soft;
            clip: true;

            TouchArea { }   // swallow clicks so the backdrop close doesn't fire

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                // Search input.
                LineEdit {
                    text: root.task-search-query;
                    placeholder-text: "Type to search tasks…";
                    font-size: 13px;
                    edited(new-text) => {
                        root.task-search-query = new-text;
                        root.task-search-changed(new-text);
                    }
                }

                Rectangle { height: 1px; background: Tokens.border-very-soft; }

                // Results list.
                ScrollView {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    VerticalLayout {
                        spacing: 1px;

                        if root.task-search-results.length == 0: VerticalLayout {
                            padding-top: 40px;
                            spacing: 6px;
                            alignment: start;
                            Text {
                                text: "No matches";
                                color: Tokens.text-tertiary;
                                font-size: 12px;
                                horizontal-alignment: center;
                            }
                        }

                        for task in root.task-search-results: TouchArea {
                            height: 28px;
                            clicked => {
                                root.task-search-select(task.id);
                                root.task-search-open = false;
                            }
                            Rectangle {
                                background: parent.has-hover ? Tokens.bg-hover : transparent;
                                border-radius: 4px;
                                animate background { duration: 100ms; easing: ease-out; }
                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;
                                    spacing: 10px;
                                    alignment: start;
                                    Text {
                                        text: "#" + task.display-id;
                                        color: Tokens.text-tertiary;
                                        font-size: 10px;
                                        font-family: "JetBrains Mono";
                                        vertical-alignment: center;
                                    }
                                    KindDiamond { kind: task.kind; }
                                    Text {
                                        text: task.title;
                                        color: Tokens.text-primary;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                }

                Text {
                    text: "Esc to dismiss · click a result to open";
                    color: Tokens.text-tertiary;
                    font-size: 9px;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
