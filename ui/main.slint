// Quay main window — Lanes-inspired three-pane layout.
//
// Layout:
//   ┌──────────┬──────────────────┬─────────────────────────────┐
//   │ title bar (36px)                                            │
//   ├──────────┼──────────────────┼─────────────────────────────┤
//   │ sidebar  │  task list       │  task detail / terminal      │
//   │ 200px    │  flex            │  flex (2x)                   │
//   │          │                  │                              │
//   └──────────┴──────────────────┴─────────────────────────────┘
//
// All colours, paddings and dimensions are taken straight from the Lanes
// reference markup the user provided so the visual language stays close.

// Geist — the official Vercel / shadcn font family. Importing the TTFs
// here embeds them into the compiled Slint resources, so the font is
// available system-wide without depending on host-installed fonts.
// We ship Regular/Medium/SemiBold/Bold for Geist (sans) and
// Regular/Medium/Bold for Geist Mono (code, terminal chrome).
import "../assets/fonts/Geist-Regular.ttf";
import "../assets/fonts/Geist-Medium.ttf";
import "../assets/fonts/Geist-SemiBold.ttf";
import "../assets/fonts/Geist-Bold.ttf";
import "../assets/fonts/GeistMono-Regular.ttf";
import "../assets/fonts/GeistMono-Medium.ttf";
import "../assets/fonts/GeistMono-Bold.ttf";

import { ScrollView, TextEdit, LineEdit } from "std-widgets.slint";
import { IconSet } from "@lucide";

// Design tokens, bridge structs and reusable components live in their
// own files so this main window stays focused on layout + wiring.
import { Tokens } from "tokens.slint";
import {
    LabelPillData, QuickActionRowData, ProcessRowData, FileEntryData,
    HlSpanData, HighlightedLineData, TaskCardData, DiffLineData,
    DiffFileData, CommitEntryData, MenuItemData, ProjectData,
    OpenTaskTabData, SessionDotData, WorktreeEntryData, SessionEntryData,
    ToastData, ChatItemData,
} from "data.slint";
import {
    LucideIcon, KindDiamond, Spinner, KindChip, Avatar, CloseButton,
} from "components/atoms.slint";
import { Toast } from "components/toast.slint";
import {
    TabMenuRow, ShortcutRow, MenuRow, ProjectRow, FilterChip,
    SectionHeader, RightTab,
} from "components/menu.slint";
import { CardRow, OpenTaskTab } from "components/cards.slint";
import { Sidebar } from "components/sidebar.slint";
import { KanbanGrid } from "components/kanban_grid.slint";
import { RightPane } from "components/right_pane.slint";
import { StatusBar } from "components/status_bar.slint";
import { NewProjectModal } from "components/new_project_modal.slint";
import { SettingsPage } from "components/settings_page.slint";
import { ShortcutsOverlay } from "components/shortcuts_overlay.slint";
import { TaskSearchModal } from "components/task_search_modal.slint";
import { TabContextMenu } from "components/tab_context_menu.slint";
import { CardContextMenu } from "components/card_context_menu.slint";

// ── Main window ─────────────────────────────────────────────────────────────

export component MainWindow inherits Window {
    title: "Quay";
    background: Tokens.background;
    // Geist is the shadcn/Vercel sans default. Every Text element
    // without an explicit font-family inherits this; monospace usages
    // continue to override with Tokens.font-mono ("Geist Mono").
    default-font-family: Tokens.font-sans;

    // Terminal pixel buffer + dimensions (driven from Rust).
    in property <image> frame;
    in property <int> cell-w: 10;
    in property <int> cell-h: 22;
    // Dynamic terminal dimensions — computed from available right-pane
    // space so the PTY reflows when the window is resized. Rust reads
    // these via get_cols()/get_rows() and calls resize_all_sessions()
    // when they change.
    property <length> avail-term-w: max(40px * root.cell-w, root.width - sidebar-w - middle-w - right-pad-h * 2);
    property <length> avail-term-h: max(4px * root.cell-h, root.height - title-bar-h - tab-strip-h - open-tabs-strip-h - right-pad-v * 2 - status-bar-h);
    out property <int> cols: max(10, floor(avail-term-w / 1px / root.cell-w));
    out property <int> rows: max(4, floor(avail-term-h / 1px / root.cell-h));

    // Polish 22: window-wide braille spinner phase, cycled by the
    // existing poll_timer in main.rs at ~96 ms. All Spinner instances
    // (CardRow + OpenTaskTab) read this single string so every
    // spinner stays in lockstep — same convention every CLI spinner
    // (cargo, npm, rustup, …) follows.
    in property <string> spinner-glyph: "⣾";

    // Polish 25 — stacking toast notifications (Sonner-style). Each
    // entry in the model is one visible toast; newest at the end.
    // Rust pushes / removes via a VecModel, individual timers handle
    // auto-dismiss. `alive` drives the fade-out animation.
    in property <[ToastData]> toast-items: [];

    // Polish 26 — keyboard shortcuts overlay. Toggled by Cmd+? from
    // the key dispatcher in main.rs. Esc closes (handled in the
    // existing modal escape branch).
    in-out property <bool> shortcuts-open: false;

    // Polish 35 — Cmd+P fuzzy task quick switcher. Modal overlay
    // with a search input and a filtered list of tasks. The Rust
    // side rebuilds `task-search-results` on every keystroke.
    in-out property <bool> task-search-open: false;
    in-out property <string> task-search-query: "";
    in property <[TaskCardData]> task-search-results;
    callback task-search-changed(string);
    callback task-search-select(string);

    // Polish 28 — true when every kanban model is empty (after the
    // active label/project filters are applied in Rust). Drives the
    // empty-state placeholder in the middle pane.
    property <bool> kanban-empty:
        root.tasks-backlog.length == 0
        && root.tasks-planning.length == 0
        && root.tasks-implementation.length == 0
        && root.tasks-review.length == 0
        && root.tasks-done.length == 0
        && root.tasks-misc.length == 0;

    // Selection / context.
    in property <string> active-task-id: "";
    in property <string> active-task-display: "";
    in property <string> active-task-kind: "feature";
    in-out property <string> active-task-title: "";
    // Inline validation error for `active-task-title` (DescriptionPanel).
    // Written by Rust (`on_title_changed`) and cleared in Slint when the
    // user types again. Empty string = no error.
    in-out property <string> active-task-title-error: "";
    in-out property <string> active-task-description: "";
    // Session state for the active task: one of idle/busy/awaiting/stopped/exited/error.
    in property <string> active-task-session-state: "idle";

    // Polish 15 — live stats parsed from the Claude Code session JSONL
    // transcript at ~/.claude/projects/<cwd>/<session-id>.jsonl. A 2s
    // Timer in main.rs refreshes these for the active task whenever
    // it has a captured `claude_session_id`. Display strings are
    // pre-formatted in Rust (Slint's formatting story is limited).
    // `active-task-message-count` stays numeric so the row can hide
    // itself when there's no data yet.
    in property <string> active-task-tokens-text: "";
    in property <string> active-task-cost-text: "";
    in property <string> active-task-runtime-text: "";
    in property <int> active-task-message-count: 0;

    // Kanban data — one VecModel per column. Phase 2 expanded this from
    // 3 combined sections to 6 (matching Lanes' workflow).
    in property <[TaskCardData]> tasks-backlog;
    in property <[TaskCardData]> tasks-planning;
    in property <[TaskCardData]> tasks-implementation;
    in property <[TaskCardData]> tasks-review;
    in property <[TaskCardData]> tasks-done;
    in property <[TaskCardData]> tasks-misc;

    in property <[MenuItemData]> menu-items;
    in property <[ProjectData]> projects;
    // Phase D — worktree entries for the sidebar Worktrees section.
    in property <[WorktreeEntryData]> worktree-entries;
    callback worktree-clicked(string);

    // All labels available in the system, rendered as filter chips at
    // the top of the task list. Clicking one sets `filter-label-id`;
    // clicking it again (or the "All" chip) clears the filter.
    in property <[LabelPillData]> all-labels;
    in-out property <string> filter-label-id: "";
    // Polish 9: active project filter. Empty string = all projects.
    // Set by clicking a project row in the sidebar.
    in-out property <string> active-project-id: "";

    // Settings page data.
    in-out property <string> settings-default-base-branch: "main";
    in property <[QuickActionRowData]> settings-quick-actions;
    in property <[ProcessRowData]> settings-processes;

    // Polish 8: New Project modal state.
    in-out property <bool> new-project-open: false;
    in-out property <string> new-project-name: "";
    in-out property <string> new-project-repo-path: "";
    in-out property <string> new-project-base-branch: "main";
    // Populated by Rust whenever `new-project-repo-path` changes to
    // a valid git repo. Drives the BASE BRANCH Select in the modal.
    // Empty list = no repo picked yet (or the picked path isn't a
    // git repo), in which case the Select shows "No branches
    // available" until the user browses to a real repository.
    in property <[string]> new-project-branches: [];
    // Inline validation errors for the New Project form. Written by
    // Rust (`on_create_project`) on submit failure and cleared by the
    // modal itself when the user types into the corresponding field.
    in-out property <string> new-project-name-error: "";
    in-out property <string> new-project-repo-path-error: "";

    // Polish 13: status bar counts, updated on every refresh_kanban.
    in property <int> stats-backlog: 0;
    in property <int> stats-planning: 0;
    in property <int> stats-implementation: 0;
    in property <int> stats-review: 0;
    in property <int> stats-done: 0;
    in property <int> stats-misc: 0;
    in property <int> stats-sessions: 0;
    in property <int> stats-total: 0;
    // Phase D — per-session dots for the status bar.
    in property <[SessionDotData]> session-dots;
    callback session-dot-clicked(string);

    // Phase D — session history for the History tab.
    in property <[SessionEntryData]> session-history;

    // File browser state for the Files tab (Phase 6).
    in property <[FileEntryData]> file-entries;
    in-out property <string> file-current-dir: "";

    // Read-only file viewer state. When `viewer-open` is true, the
    // Files tab shows the syntect-coloured viewer instead of the
    // directory listing.
    in-out property <bool> viewer-open: false;
    in property <string> viewer-file-path: "";
    in property <string> viewer-syntax-name: "Plain Text";
    in property <[HighlightedLineData]> viewer-highlighted-lines;
    in property <int> viewer-line-count: 0;
    // Keyboard navigation — focused row in file tree (-1 = none).
    in-out property <int> file-tree-focused-index: -1;

    // Description tab: labels attached to the active task + dependencies.
    in property <[LabelPillData]> active-task-labels;
    // Potential labels to attach (all available ones the task doesn't have yet).
    in property <[LabelPillData]> active-task-available-labels;
    in property <[TaskCardData]> active-task-dependencies;
    // Polish 7: available dependency candidates (every task that isn't
    // this one and isn't already a prereq and wouldn't create a cycle).
    in property <[TaskCardData]> active-task-available-deps;
    in-out property <bool> label-picker-open: false;
    in-out property <bool> dep-picker-open: false;

    // Git Changes tab data — refreshed ~1×/s while the tab is open.
    in property <[DiffFileData]> git-diff-files;
    in property <[CommitEntryData]> git-commit-log;

    // Page-level navigation: "home" (kanban 3-pane) or "settings".
    in-out property <string> active-page: "home";

    // Right pane tab selection.
    in-out property <string> active-right-tab: "terminal";

    // Polish 16 — open task tabs at the top of the right pane. Each
    // entry is a task the user has "pinned" into the workspace. The
    // `is-active` flag on exactly one entry mirrors `active-task-id`.
    // The strip hides entirely when <2 tabs are open — a single task
    // does not need a tab bar.
    in property <[OpenTaskTabData]> open-task-tabs;
    callback open-task-tab(string);    // task id — make tab active
    callback close-task-tab(string);   // task id — close & fall back

    // Polish 41 — bulk tab management actions. Wired to the dropdown
    // menu at the right of the open-tabs strip and to keyboard
    // shortcuts (Cmd+Shift+W close others, etc.).
    callback close-other-task-tabs(string);   // keep only the given id
    callback close-all-task-tabs();
    callback close-task-tabs-right-of(string); // keep up to and including the given id

    // Polish 41 + 41b — context menu state. `target-id` is the tab
    // the user right-clicked on (NOT necessarily the active tab —
    // the actions operate on `target-id` so right-clicking an
    // inactive tab and choosing "Close other tabs" keeps THAT tab
    // and closes the rest, which matches every browser ever).
    // `tab-menu-x` / `tab-menu-y` are the absolute window coords
    // of the cursor at click time, used to anchor the popup.
    in-out property <bool> tab-menu-open: false;
    in-out property <string> tab-menu-target-id: "";
    in-out property <length> tab-menu-x: 0px;
    in-out property <length> tab-menu-y: 0px;

    // Card context menu state — right-click on a kanban card.
    in-out property <bool> card-menu-open: false;
    in-out property <string> card-menu-target-id: "";
    in-out property <length> card-menu-x: 0px;
    in-out property <length> card-menu-y: 0px;
    in-out property <bool> card-menu-target-has-session: false;
    callback card-stop-session(string);             // task-id
    callback card-delete(string);                   // task-id

    // Polish 20 — sidebar collapse stub. Wired to a no-op for now;
    // a future polish will actually shrink `sidebar-w` when toggled.
    callback toggle-sidebar();

    callback select-task(string);
    callback create-task();
    callback bare-terminal-requested(string);  // task-id — lazily spawn bare shell
    callback title-changed(string);
    callback description-changed(string);
    callback filter-changed(string);  // Phase 4: fires when filter-label-id changes
    callback toggle-settings();
    callback settings-base-branch-changed(string);
    callback locale-changed(string);   // i18n: switch language at runtime
    in-out property <string> current-locale: "en";
    callback permission-mode-changed(string);
    in-out property <string> current-permission-mode: "acceptEdits";
    callback process-kill(int);        // SIGTERM
    callback process-force-kill(int);  // SIGKILL
    callback stop-all-sessions();      // SIGTERM all tracked
    callback kill-all-processes();     // SIGKILL all
    callback refresh-processes();
    callback file-entry-clicked(string, string);   // path, kind
    callback viewer-close();
    callback activate-focused(int);              // keyboard Enter on tree
    callback attach-label(string);   // label id
    callback detach-label(string);   // label id
    callback remove-dependency(string);  // dep task id
    callback add-dependency(string);     // dep task id
    callback delete-task(string);    // task id
    callback create-project();
    // Opens the native folder picker (via Rust `rfd`) so the user
    // can browse for a repository path instead of typing the
    // absolute path by hand. On success, Rust writes the picked
    // path into `new-project-repo-path` and refreshes
    // `new-project-branches` to reflect the repo's local branches.
    callback pick-new-project-repo-path();
    // Fires every time the repo path text changes, so Rust can
    // refresh `new-project-branches` for the BASE BRANCH Select.
    callback new-project-repo-path-changed(string);
    callback project-clicked(string);   // project id
    callback close-project-chip(string);   // project id — hide chip from filter bar
    callback add-quick-action();        // opens inline editor with blank row
    callback delete-quick-action(string); // by id
    callback update-quick-action(string, string, string, string); // id, name, kind, body
    // text, ctrl, alt, shift, meta. Meta added in Polish 6 for
    // Cmd-based shortcuts on macOS.
    callback key-pressed(string, bool, bool, bool, bool);
    // Mouse wheel delta (in logical pixels) for the terminal pane.
    callback terminal-scroll(float);
    // Chat view (stream-json sessions).
    callback send-prompt(string);
    callback chat-model-changed(string);
    callback chat-effort-changed(string);
    in property <bool> is-chat-session: false;
    in property <[ChatItemData]> chat-items;
    in-out property <string> chat-selected-model: "sonnet";
    in-out property <string> chat-selected-effort: "high";

    // Layout constants.
    // Polish 24: sidebar-w switches between full and compact based
    // on `sidebar-collapsed`. The middle and right panes use this
    // in their `x:` positioning so they reflow automatically when
    // the toggle is fired.
    in-out property <bool> sidebar-collapsed: false;
    property <length> sidebar-w: sidebar-collapsed ? 56px : 200px;
    property <length> middle-w: (root.width - sidebar-w) * 35%;
    property <length> title-bar-h: 0px;
    property <length> tab-strip-h: 32px;
    property <length> term-w: root.cols * root.cell-w * 1px;
    property <length> term-h: root.rows * root.cell-h * 1px;
    property <length> right-pad-h: 0px;
    property <length> right-pad-v: 0px;

    property <length> status-bar-h: 22px;

    // Height of the open-task tabs strip above the inner
    // Terminal/Description/… strip. Always visible when at least one
    // tab is open, matching the Lanes reference layout.
    property <length> open-tabs-strip-h: root.open-task-tabs.length >= 1 ? 34px : 0px;

    // Preferred size uses the default 96×28 terminal; min allows 40×10
    // so the user can shrink the window and the PTY reflows.
    preferred-width: 1280px;
    preferred-height: title-bar-h + tab-strip-h + open-tabs-strip-h + 28 * root.cell-h * 1px + right-pad-v * 2 + 14px + status-bar-h;
    min-width: 900px;
    min-height: title-bar-h + tab-strip-h + open-tabs-strip-h + 10 * root.cell-h * 1px + right-pad-v * 2 + 14px + status-bar-h;

    // ── Sidebar (persists across all pages) ────────────────────────────
    Sidebar {
        x: 0;
        y: title-bar-h;
        width: sidebar-w;
        height: parent.height - title-bar-h;

        menu-items: root.menu-items;
        projects: root.projects;
        active-project-id: root.active-project-id;
        worktree-entries: root.worktree-entries;
        collapsed <=> root.sidebar-collapsed;

        menu-item-clicked(id) => {
            if (id == "new-task") { root.create-task(); }
            if (id == "configure") { root.active-page = "settings"; }
            if (id == "sessions") { root.active-right-tab = "history"; root.active-page = "home"; }
        }
        open-new-project => { root.new-project-open = true; }
        project-clicked(id) => { root.project-clicked(id); }
        worktree-clicked(task-id) => { root.worktree-clicked(task-id); }
        toggle-collapsed => { root.toggle-sidebar(); }
    }

    // ── HOME PAGE ─────────────────────────────────────────────────────
    if root.active-page == "home": Rectangle {
        x: 0; y: 0; width: parent.width; height: parent.height;

    // ── Middle pane: kanban grid ────────────────────────────────────────
    KanbanGrid {
        x: sidebar-w;
        y: title-bar-h;
        width: middle-w;
        height: parent.height - title-bar-h;

        tasks-backlog: root.tasks-backlog;
        tasks-planning: root.tasks-planning;
        tasks-implementation: root.tasks-implementation;
        tasks-review: root.tasks-review;
        tasks-done: root.tasks-done;
        tasks-misc: root.tasks-misc;
        all-labels: root.all-labels;
        filter-label-id <=> root.filter-label-id;
        projects: root.projects;
        active-project-id <=> root.active-project-id;
        active-task-id: root.active-task-id;
        spinner-glyph: root.spinner-glyph;
        tab-strip-h: root.tab-strip-h;

        select-task(id) => { root.select-task(id); }
        filter-changed(id) => { root.filter-changed(id); }
        close-project-chip(id) => { root.close-project-chip(id); }
        card-right-clicked(id, x, y, state, session-state) => {
            root.card-menu-target-id = id;
            root.card-menu-x = x;
            root.card-menu-y = y;
            root.card-menu-target-has-session =
                session-state == "busy" || session-state == "awaiting";
            root.card-menu-open = true;
        }
    }

    // ── Right pane ───────────────────────────────────────────────────────
    RightPane {
        x: sidebar-w + middle-w;
        y: title-bar-h;
        width: parent.width - sidebar-w - middle-w;
        height: parent.height - title-bar-h;

        tab-strip-h: root.tab-strip-h;
        open-tabs-strip-h: root.open-tabs-strip-h;
        right-pad-h: root.right-pad-h;
        right-pad-v: root.right-pad-v;
        term-w: root.term-w;
        term-h: root.term-h;
        spinner-glyph: root.spinner-glyph;

        // Open-tabs strip + context menu state.
        open-task-tabs: root.open-task-tabs;
        tab-menu-open <=> root.tab-menu-open;
        tab-menu-target-id <=> root.tab-menu-target-id;
        tab-menu-x <=> root.tab-menu-x;
        tab-menu-y <=> root.tab-menu-y;
        open-tab(id) => { root.open-task-tab(id); }
        close-tab(id) => { root.close-task-tab(id); }

        // Tab strip.
        active-right-tab <=> root.active-right-tab;

        // Terminal.
        frame: root.frame;
        terminal-key-pressed(text, ctrl, alt, shift, meta) => {
            root.key-pressed(text, ctrl, alt, shift, meta);
        }
        terminal-scroll(delta) => { root.terminal-scroll(delta); }
        is-chat-session: root.is-chat-session;
        chat-items: root.chat-items;
        chat-selected-model <=> root.chat-selected-model;
        chat-selected-effort <=> root.chat-selected-effort;
        send-prompt(text) => { root.send-prompt(text); }
        chat-model-changed(v) => { root.chat-model-changed(v); }
        chat-effort-changed(v) => { root.chat-effort-changed(v); }
        bare-terminal-requested(id) => { root.bare-terminal-requested(id); }

        // Description tab.
        active-task-id: root.active-task-id;
        active-task-display: root.active-task-display;
        active-task-session-state: root.active-task-session-state;
        active-task-title <=> root.active-task-title;
        active-task-title-error <=> root.active-task-title-error;
        active-task-description <=> root.active-task-description;
        active-task-tokens-text: root.active-task-tokens-text;
        active-task-cost-text: root.active-task-cost-text;
        active-task-runtime-text: root.active-task-runtime-text;
        active-task-message-count: root.active-task-message-count;
        active-task-labels: root.active-task-labels;
        active-task-available-labels: root.active-task-available-labels;
        label-picker-open <=> root.label-picker-open;
        active-task-dependencies: root.active-task-dependencies;
        active-task-available-deps: root.active-task-available-deps;
        dep-picker-open <=> root.dep-picker-open;

        delete-task(id) => { root.delete-task(id); }
        title-changed(t) => { root.title-changed(t); }
        description-changed(t) => { root.description-changed(t); }
        attach-label(id) => { root.attach-label(id); }
        detach-label(id) => { root.detach-label(id); }
        add-dependency(id) => { root.add-dependency(id); }
        remove-dependency(id) => { root.remove-dependency(id); }

        // Git tab.
        git-diff-files: root.git-diff-files;
        git-commit-log: root.git-commit-log;

        // Files tab.
        file-entries: root.file-entries;
        file-current-dir <=> root.file-current-dir;
        viewer-open <=> root.viewer-open;
        viewer-file-path: root.viewer-file-path;
        viewer-syntax-name: root.viewer-syntax-name;
        viewer-highlighted-lines: root.viewer-highlighted-lines;
        viewer-line-count: root.viewer-line-count;
        file-tree-focused-index <=> root.file-tree-focused-index;
        file-entry-clicked(path, kind) => { root.file-entry-clicked(path, kind); }
        viewer-close => { root.viewer-close(); }
        activate-focused(idx) => { root.activate-focused(idx); }

        // History tab.
        session-history: root.session-history;
    }

    // ── Status bar (Polish 13) ──────────────────────────────────────────
    StatusBar {
        x: 0;
        y: parent.height - status-bar-h;
        width: parent.width;
        height: status-bar-h;

        stats-backlog: root.stats-backlog;
        stats-planning: root.stats-planning;
        stats-implementation: root.stats-implementation;
        stats-review: root.stats-review;
        stats-done: root.stats-done;
        stats-misc: root.stats-misc;
        stats-sessions: root.stats-sessions;
        stats-total: root.stats-total;
        session-dots: root.session-dots;
        session-dot-clicked(id) => { root.session-dot-clicked(id); }
    }

    } // end home page

    // ── SETTINGS PAGE ───────────────────────────────────────────────────
    if root.active-page == "settings": SettingsPage {
        x: sidebar-w;
        y: title-bar-h;
        width: parent.width - sidebar-w;
        height: parent.height - title-bar-h;

        default-base-branch <=> root.settings-default-base-branch;
        current-locale <=> root.current-locale;
        current-permission-mode <=> root.current-permission-mode;
        quick-actions: root.settings-quick-actions;
        processes: root.settings-processes;

        base-branch-changed(t) => { root.settings-base-branch-changed(t); }
        locale-changed(locale) => { root.locale-changed(locale); }
        permission-mode-changed(mode) => { root.permission-mode-changed(mode); }
        add-quick-action => { root.add-quick-action(); }
        delete-quick-action(id) => { root.delete-quick-action(id); }
        update-quick-action(id, name, kind, body) => {
            root.update-quick-action(id, name, kind, body);
        }
        refresh-processes => { root.refresh-processes(); }
        process-kill(pid) => { root.process-kill(pid); }
        process-force-kill(pid) => { root.process-force-kill(pid); }
        stop-all-sessions => { root.stop-all-sessions(); }
        kill-all-processes => { root.kill-all-processes(); }
        go-back => { root.active-page = "home"; }
    }

    // Polish 25 + 31 — stacking toast notifications (Sonner-style).
    // Newest toast at the bottom, older ones slide upward. Each item
    // in `toast-items` is rendered independently; the `alive` field
    // drives per-toast fade-out before removal from the model.
    for toast-entry[idx] in root.toast-items: Toast {
        x: parent.width - self.width - 16px;
        y: parent.height - status-bar-h - (self.height + 8px) * (root.toast-items.length - idx) - 4px;
        width: 340px;
        message: toast-entry.message;
        kind: toast-entry.kind;
        visible-toast: toast-entry.alive;
        animate y { duration: 220ms; easing: ease-out; }
    }

    // ── New Project modal overlay (Polish 8 / 32) ───────────────────────
    NewProjectModal {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        open <=> root.new-project-open;
        name-text <=> root.new-project-name;
        repo-path-text <=> root.new-project-repo-path;
        base-branch-text <=> root.new-project-base-branch;
        branches: root.new-project-branches;
        name-error <=> root.new-project-name-error;
        repo-path-error <=> root.new-project-repo-path-error;
        browse-repo => { root.pick-new-project-repo-path(); }
        repo-path-changed(t) => { root.new-project-repo-path-changed(t); }
        submit => { root.create-project(); }
    }

    // ── Keyboard shortcuts overlay (Polish 26 + 32) ─────────────────────
    ShortcutsOverlay {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        open <=> root.shortcuts-open;
    }

    // ── Cmd+P task quick switcher (Polish 35) ───────────────────────────
    TaskSearchModal {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        open <=> root.task-search-open;
        query <=> root.task-search-query;
        results: root.task-search-results;
        query-changed(q) => { root.task-search-changed(q); }
        task-selected(id) => { root.task-search-select(id); }
    }

    // ── Tab right-click context menu (Polish 41 + 41b) ──────────────────
    TabContextMenu {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        open <=> root.tab-menu-open;
        target-id <=> root.tab-menu-target-id;
        anchor-x <=> root.tab-menu-x;
        anchor-y <=> root.tab-menu-y;
        open-tabs-count: root.open-task-tabs.length;
        close-this(id) => { root.close-task-tab(id); }
        close-others(id) => { root.close-other-task-tabs(id); }
        close-right-of(id) => { root.close-task-tabs-right-of(id); }
        close-all => { root.close-all-task-tabs(); }
    }

    // ── Card right-click context menu ───────────────────────────────────
    CardContextMenu {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        open <=> root.card-menu-open;
        target-id <=> root.card-menu-target-id;
        anchor-x <=> root.card-menu-x;
        anchor-y <=> root.card-menu-y;
        target-has-session: root.card-menu-target-has-session;
        stop-task-session(id) => { root.card-stop-session(id); }
        delete-card(id) => { root.card-delete(id); }
    }
}
