// Quay design tokens — full shadcn/ui zinc-dark port.
//
// This global centralises colours, radius, typography, and spacing so
// every component reads its values from a single source of truth. The
// vocabulary matches shadcn/ui conventions (background/foreground,
// primary/secondary/muted/accent, border/input/ring, radius-sm..xl,
// text-xs..xl, space-1..10) so a designer familiar with shadcn can
// navigate quay's UI without reading Slint.
//
// The palette is the exact shadcn `zinc` dark theme, with OKLCH values
// converted to hex since Slint 1.15 doesn't support `oklch()`.
//
// The only domain-specific extensions over vanilla shadcn are the
// kanban `kind-*` colours (feature/bug/enhancement/done) and the two
// decorative `accent-*` slots used by the title bar avatar.

export global Tokens {
    // === Core semantic colours (shadcn zinc-dark BASE + blue PRIMARY) ===
    //
    // Neutrals (bg/card/popover/secondary/muted/accent/border/input) are
    // the zinc dark palette ported from shadcn's default dark mode. Only
    // the accent/brand tokens — `primary`, `primary-foreground`, `ring`,
    // and the matching sidebar-primary pair — were overridden to match
    // shadcn's "blue" theme variant:
    //
    //   primary            oklch(0.707 0.165 254.624)  ≈ #3b82f6
    //   primary-foreground oklch(0.97  0.014 254.604)  ≈ #f0f9ff
    //   ring               same as primary
    //
    // The switch turns every Button{variant:"default"} (new task "Create",
    // new project "Create") and every keyboard focus ring blue instead
    // of the previous zinc near-white, matching the shadcn registry-item
    // example for a custom blue theme.
    out property <color> background: #0a0a0a;
    out property <color> foreground: #fafafa;
    out property <color> card: #171717;
    out property <color> card-foreground: #fafafa;
    out property <color> popover: #171717;
    out property <color> popover-foreground: #fafafa;
    out property <color> primary: #3b82f6;
    out property <color> primary-foreground: #f0f9ff;
    out property <color> secondary: #262626;
    out property <color> secondary-foreground: #fafafa;
    out property <color> muted: #262626;
    out property <color> muted-foreground: #a3a3a3;
    out property <color> accent: #262626;
    out property <color> accent-foreground: #fafafa;
    out property <color> destructive: #e5493e;
    out property <color> destructive-foreground: #fafafa;
    out property <color> border: rgba(255, 255, 255, 10%);
    out property <color> input: rgba(255, 255, 255, 15%);
    out property <color> ring: #3b82f6;

    // Sidebar tokens (shadcn has dedicated sidebar-* variables).
    // `sidebar-primary` mirrors the blue brand accent so any future
    // sidebar CTA (e.g. "New Task" highlighted row) picks up the same
    // colour as the main Button variant="default".
    out property <color> sidebar: #171717;
    out property <color> sidebar-foreground: #fafafa;
    out property <color> sidebar-primary: #3b82f6;
    out property <color> sidebar-primary-foreground: #f0f9ff;
    out property <color> sidebar-accent: #262626;
    out property <color> sidebar-accent-foreground: #fafafa;
    out property <color> sidebar-border: rgba(255, 255, 255, 10%);
    out property <color> sidebar-ring: #3b82f6;

    // === Radius scale (shadcn: --radius 0.625rem = 10px) ===
    out property <length> radius-sm: 6px;  // calc(radius * 0.6)
    out property <length> radius-md: 8px;  // calc(radius * 0.8)
    out property <length> radius-lg: 10px; // radius base
    out property <length> radius-xl: 14px; // calc(radius * 1.4)
    out property <length> radius-2xl: 18px;

    // === Typography scale ===
    out property <string> font-sans: "Geist";
    out property <string> font-mono: "Geist Mono";
    out property <length> text-xs: 10px;
    out property <length> text-sm: 11px;
    out property <length> text-base: 13px;
    out property <length> text-lg: 15px;
    out property <length> text-xl: 18px;
    out property <int> weight-regular: 400;
    out property <int> weight-medium: 500;
    out property <int> weight-semibold: 600;
    out property <int> weight-bold: 700;

    // === Spacing scale (Tailwind-like) ===
    out property <length> space-1: 4px;
    out property <length> space-2: 8px;
    out property <length> space-3: 12px;
    out property <length> space-4: 16px;
    out property <length> space-5: 20px;
    out property <length> space-6: 24px;
    out property <length> space-8: 32px;
    out property <length> space-10: 40px;

    // === Elevation / shadow scale ===
    // shadcn uses `shadow-sm`, `shadow-md`, `shadow-lg`, `shadow-xl` on
    // elevated surfaces (cards, popovers, dialogs). Slint 1.15's Rectangle
    // supports `drop-shadow-color/blur/offset-x/offset-y` natively — we
    // expose the blur radius + a reference color here so every callsite
    // picks the same physical parameters. Shadows are all black with
    // alpha since the whole app is dark-mode and a coloured shadow would
    // tint the underlying surface.
    out property <length> shadow-sm-blur: 2px;   // subtle hover bump
    out property <length> shadow-md-blur: 6px;   // resting card/tab
    out property <length> shadow-lg-blur: 14px;  // popover/dropdown
    out property <length> shadow-xl-blur: 28px;  // modal dialog
    out property <length> shadow-offset-y: 2px;
    out property <color> shadow-color-sm: rgba(0, 0, 0, 25%);
    out property <color> shadow-color-md: rgba(0, 0, 0, 35%);
    out property <color> shadow-color-lg: rgba(0, 0, 0, 45%);
    out property <color> shadow-color-xl: rgba(0, 0, 0, 55%);

    // === Domain colours (kanban kinds — preserved) ===
    out property <color> kind-enhancement: #10b981;
    out property <color> kind-feature: #60a5fa;
    out property <color> kind-bug: #e5493e;
    out property <color> kind-done: #34d399;

    // === Decorative accents (title bar avatar) ===
    out property <color> accent-warm: #c87533;
    out property <color> accent-pink-coral: #f58a82;
}
