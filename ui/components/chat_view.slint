// Chat-based session view — replaces TerminalView for Claude Code
// sessions using `--output-format stream-json`.
//
// Renders a flat list of ChatItemData entries (user prompts, assistant
// text, tool call cards, status lines) inside a scrollable area, with
// a TextInput at the bottom for sending follow-up prompts.

import { ScrollView } from "std-widgets.slint";
import { Tokens } from "../tokens.slint";
import { ChatItemData } from "../data.slint";

component UserBubble inherits Rectangle {
    in property <string> text;
    height: self.preferred-height;
    preferred-height: inner.preferred-height + 20px;

    inner := Rectangle {
        x: 32px;
        width: parent.width - 40px;
        height: msg.preferred-height + 16px;
        background: Tokens.accent.with-alpha(0.15);
        border-radius: 8px;

        msg := Text {
            x: 8px; y: 8px;
            width: parent.width - 16px;
            text: root.text;
            color: Tokens.foreground;
            font-size: Tokens.text-sm;
            wrap: word-wrap;
        }
    }
}

component AssistantText inherits Rectangle {
    in property <string> text;
    height: self.preferred-height;
    preferred-height: body.preferred-height + 12px;

    body := Text {
        x: 8px; y: 4px;
        width: parent.width - 48px;
        text: root.text;
        color: Tokens.foreground;
        font-size: Tokens.text-sm;
        wrap: word-wrap;
    }
}

component ToolCard inherits Rectangle {
    in property <string> tool-name;
    in property <string> text;    // tool input / output
    in property <bool> is-error;
    height: self.preferred-height;
    preferred-height: card.preferred-height + 12px;

    card := Rectangle {
        x: 8px;
        width: parent.width - 48px;
        height: card-col.preferred-height + 12px;
        background: Tokens.muted.with-alpha(0.08);
        border-radius: 6px;
        border-width: 1px;
        border-color: root.is-error ? Tokens.destructive : Tokens.border;

        card-col := VerticalLayout {
            padding: 6px;
            spacing: 4px;

            HorizontalLayout {
                spacing: 6px;
                Text {
                    text: "⚙";
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-xs;
                }
                Text {
                    text: root.tool-name;
                    color: root.is-error ? Tokens.destructive : Tokens.accent;
                    font-size: Tokens.text-xs;
                    font-weight: Tokens.weight-semibold;
                }
            }

            if root.text != "": Text {
                width: parent.width - 12px;
                text: root.text;
                color: Tokens.muted-foreground;
                font-size: 11px;
                font-family: Tokens.font-mono;
                wrap: word-wrap;
                overflow: elide;
            }
        }
    }
}

component StatusLine inherits Rectangle {
    in property <string> text;
    height: 28px;

    HorizontalLayout {
        alignment: center;
        padding: 8px;
        Text {
            text: root.text;
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
            horizontal-alignment: center;
        }
    }
}

// Compact chip with upward-opening dropdown for session config.
component ConfigChip inherits Rectangle {
    in property <[string]> options;
    in-out property <string> value;
    in property <string> label;
    callback changed(string);

    in-out property <bool> open: false;
    property <length> option-h: 24px;
    property <length> popup-h: root.options.length * option-h + 8px;

    height: 26px;
    width: chip-layout.preferred-width + 20px;

    // Popup — positioned absolutely above the chip.
    if root.open: Rectangle {
        x: 0;
        y: -popup-h - 4px;
        width: max(root.width, 100px);
        height: popup-h;
        background: Tokens.popover;
        border-radius: 6px;
        border-width: 1px;
        border-color: Tokens.border;
        drop-shadow-color: Tokens.shadow-color-lg;
        drop-shadow-blur: 8px;
        drop-shadow-offset-y: -2px;
        clip: true;

        VerticalLayout {
            padding: 4px;
            spacing: 0px;

            for opt in root.options: Rectangle {
                height: option-h;
                background: opt-ta.has-hover ? Tokens.accent : transparent;
                border-radius: 4px;

                opt-ta := TouchArea {
                    clicked => {
                        root.value = opt;
                        root.open = false;
                        root.changed(opt);
                    }
                }

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    Text {
                        text: opt;
                        color: Tokens.foreground;
                        font-size: Tokens.text-xs;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // Chip trigger.
    Rectangle {
        background: chip-ta.has-hover ? Tokens.muted.with-alpha(0.15) : transparent;
        border-radius: 4px;
        border-width: 1px;
        border-color: Tokens.border;
        animate background { duration: 100ms; }

        chip-ta := TouchArea {
            clicked => { root.open = !root.open; }
        }

        chip-layout := HorizontalLayout {
            padding-left: 8px;
            padding-right: 6px;
            spacing: 4px;
            alignment: center;

            Text {
                text: root.label + ": ";
                color: Tokens.muted-foreground;
                font-size: 10px;
                vertical-alignment: center;
            }
            Text {
                text: root.value;
                color: Tokens.foreground;
                font-size: 10px;
                font-weight: Tokens.weight-semibold;
                vertical-alignment: center;
            }
            Text {
                text: root.open ? "▴" : "▾";
                color: Tokens.muted-foreground;
                font-size: 8px;
                vertical-alignment: center;
            }
        }
    }
}

export component ChatView inherits Rectangle {
    in property <[ChatItemData]> items;
    in property <string> session-state;    // "idle" | "busy" | "awaiting" | ...
    in property <string> active-task-id;
    in-out property <string> selected-model: "sonnet";
    in-out property <string> selected-effort: "high";
    callback send-prompt(string);
    callback model-changed(string);
    callback effort-changed(string);

    VerticalLayout {
        // Placeholder when no messages yet — overlays the scroll area.
        if root.items.length == 0 && root.active-task-id != "" && root.session-state != "busy": Rectangle {
            vertical-stretch: 1;
            VerticalLayout {
                alignment: center;
                spacing: 8px;
                padding: 24px;

                Text {
                    text: "Claude Code";
                    color: Tokens.foreground;
                    font-size: Tokens.text-lg;
                    font-weight: Tokens.weight-semibold;
                    horizontal-alignment: center;
                }
                Text {
                    text: @tr("Type a message below to start the conversation.");
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-sm;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }

        // Chat history — scrollable (shown when items exist).
        if root.items.length > 0: ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                spacing: 2px;
                padding: 4px;

                for item in root.items: Rectangle {
                    if item.kind == "user": UserBubble {
                        width: parent.width;
                        text: item.text;
                    }
                    if item.kind == "text": AssistantText {
                        width: parent.width;
                        text: item.text;
                    }
                    if item.kind == "tool-use" || item.kind == "tool-result": ToolCard {
                        width: parent.width;
                        tool-name: item.tool-name;
                        text: item.text;
                        is-error: item.is-error;
                    }
                    if item.kind == "status": StatusLine {
                        width: parent.width;
                        text: item.text;
                    }
                }
            }
        }

        // Config strip — model + effort selectors.
        if root.session-state != "busy" && root.active-task-id != "": Rectangle {
            height: 32px;
            // Needs clip:false so the upward popup is visible.

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;
                alignment: start;

                ConfigChip {
                    label: "Model";
                    options: ["sonnet", "opus", "haiku"];
                    value <=> root.selected-model;
                    changed(v) => { root.model-changed(v); }
                }
                ConfigChip {
                    label: "Effort";
                    options: ["low", "medium", "high", "max"];
                    value <=> root.selected-effort;
                    changed(v) => { root.effort-changed(v); }
                }
            }
        }

        // Input bar — visible when session is awaiting input or idle.
        if root.session-state != "busy" && root.active-task-id != "": Rectangle {
            height: 44px;
            background: Tokens.card;
            border-width: 1px;
            border-color: Tokens.border;
            border-radius: 8px;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 6px;
                padding-top: 6px;
                padding-bottom: 6px;
                spacing: 8px;

                prompt-input := TextInput {
                    vertical-alignment: center;
                    font-size: Tokens.text-sm;
                    color: Tokens.foreground;
                    accepted => {
                        if self.text != "" {
                            root.send-prompt(self.text);
                            self.text = "";
                        }
                    }
                }

                Rectangle {
                    width: 30px;
                    height: 30px;
                    border-radius: 6px;
                    background: Tokens.accent;
                    TouchArea {
                        clicked => {
                            if prompt-input.text != "" {
                                root.send-prompt(prompt-input.text);
                                prompt-input.text = "";
                            }
                        }
                    }
                    Text {
                        text: "↵";
                        color: Tokens.foreground;
                        font-size: Tokens.text-sm;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Busy indicator while streaming.
        if root.session-state == "busy": Rectangle {
            height: 32px;
            HorizontalLayout {
                alignment: center;
                padding: 8px;
                Text {
                    text: @tr("Claude is working…");
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-xs;
                    font-weight: Tokens.weight-semibold;
                }
            }
        }

        // Empty state — no task selected at all.
        if root.active-task-id == "": Rectangle {
            vertical-stretch: 1;
            VerticalLayout {
                alignment: center;
                spacing: 8px;
                Text {
                    text: @tr("No active session");
                    color: Tokens.foreground;
                    font-size: Tokens.text-lg;
                    font-weight: Tokens.weight-semibold;
                    horizontal-alignment: center;
                }
                Text {
                    text: @tr("Press Ctrl+N to start a new session, or select a task from the kanban.");
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-sm;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
