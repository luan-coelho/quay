// Settings panel — inline right-pane page (formerly a modal overlay).
// Three sections:
//   - General (default base branch + language)
//   - Quick Actions CRUD
//   - Process Manager (Polish 1)
//
// Quick Action edit callbacks bubble up to the parent so the Rust
// side can persist them via QuickActionStore.

import { ScrollView } from "std-widgets.slint";
import { IconSet } from "@lucide";
import { Tokens } from "../tokens.slint";
import { QuickActionRowData, ProcessRowData } from "../data.slint";
import { LucideIcon, ShortcutKeys, CloseButton, Button, Card, Input, Divider } from "atoms.slint";

export component SettingsPanel inherits Rectangle {
    in-out property <string> default-base-branch;
    in-out property <string> current-locale: "en";
    in-out property <string> current-permission-mode: "acceptEdits";
    in property <[QuickActionRowData]> quick-actions;
    in property <[ProcessRowData]> processes;

    callback base-branch-changed(string);
    callback locale-changed(string);
    callback permission-mode-changed(string);
    callback add-quick-action();
    callback delete-quick-action(string);
    callback update-quick-action(string, string, string, string);
    callback refresh-processes();
    callback process-kill(int);
    callback process-force-kill(int);
    callback stop-all-sessions();
    callback kill-all-processes();

    ScrollView {
        VerticalLayout {
            alignment: start;
            padding: Tokens.space-3;
            spacing: Tokens.space-2;

            // ── General section ───────────────────────────────────
            Text {
                text: @tr("GENERAL");
                color: Tokens.muted-foreground;
                font-size: Tokens.text-xs;
                font-weight: Tokens.weight-bold;
            }

            VerticalLayout {
                spacing: Tokens.space-1 + 2px;
                Text {
                    text: @tr("Default base branch");
                    color: Tokens.foreground;
                    font-size: Tokens.text-sm;
                    font-weight: Tokens.weight-medium;
                }
                Input {
                    text: root.default-base-branch;
                    placeholder: "main";
                    edited(new-text) => {
                        root.base-branch-changed(new-text);
                    }
                }
            }

            // ── Language section ───────────────────────────────────
            VerticalLayout {
                spacing: Tokens.space-1 + 2px;
                Text {
                    text: @tr("Language");
                    color: Tokens.foreground;
                    font-size: Tokens.text-sm;
                    font-weight: Tokens.weight-medium;
                }
                HorizontalLayout {
                    spacing: Tokens.space-2;

                    // English option
                    TouchArea {
                        width: 120px;
                        height: 30px;
                        clicked => {
                            root.current-locale = "en";
                            root.locale-changed("en");
                        }
                        Rectangle {
                            background: root.current-locale == "en" ? Tokens.accent : Tokens.secondary;
                            border-radius: Tokens.radius-md;
                            border-width: 1px;
                            border-color: root.current-locale == "en" ? Tokens.ring : Tokens.border;
                            animate background { duration: 120ms; easing: ease-out; }
                            Text {
                                text: "English";
                                color: Tokens.foreground;
                                font-size: Tokens.text-sm;
                                font-weight: root.current-locale == "en" ? Tokens.weight-bold : Tokens.weight-medium;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }

                    // Português option
                    TouchArea {
                        width: 160px;
                        height: 30px;
                        clicked => {
                            root.current-locale = "pt-BR";
                            root.locale-changed("pt-BR");
                        }
                        Rectangle {
                            background: root.current-locale == "pt-BR" ? Tokens.accent : Tokens.secondary;
                            border-radius: Tokens.radius-md;
                            border-width: 1px;
                            border-color: root.current-locale == "pt-BR" ? Tokens.ring : Tokens.border;
                            animate background { duration: 120ms; easing: ease-out; }
                            Text {
                                text: "Português (Brasil)";
                                color: Tokens.foreground;
                                font-size: Tokens.text-sm;
                                font-weight: root.current-locale == "pt-BR" ? Tokens.weight-bold : Tokens.weight-medium;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }
            }

            // ── Permission Mode section ───────────────────────────
            VerticalLayout {
                spacing: Tokens.space-1 + 2px;
                Text {
                    text: @tr("Permission mode");
                    color: Tokens.foreground;
                    font-size: Tokens.text-sm;
                    font-weight: Tokens.weight-medium;
                }
                Text {
                    text: @tr("Controls whether the AI agent asks for approval before running commands.");
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-xs;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    spacing: Tokens.space-2;

                    // Accept Edits option
                    TouchArea {
                        width: 160px;
                        height: 30px;
                        mouse-cursor: pointer;
                        clicked => {
                            root.current-permission-mode = "acceptEdits";
                            root.permission-mode-changed("acceptEdits");
                        }
                        Rectangle {
                            background: root.current-permission-mode == "acceptEdits" ? Tokens.accent : Tokens.secondary;
                            border-radius: Tokens.radius-md;
                            border-width: 1px;
                            border-color: root.current-permission-mode == "acceptEdits" ? Tokens.ring : Tokens.border;
                            animate background { duration: 120ms; easing: ease-out; }
                            Text {
                                text: @tr("Accept Edits");
                                color: Tokens.foreground;
                                font-size: Tokens.text-sm;
                                font-weight: root.current-permission-mode == "acceptEdits" ? Tokens.weight-bold : Tokens.weight-medium;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }

                    // Bypass Permissions option
                    TouchArea {
                        width: 200px;
                        height: 30px;
                        mouse-cursor: pointer;
                        clicked => {
                            root.current-permission-mode = "bypassPermissions";
                            root.permission-mode-changed("bypassPermissions");
                        }
                        Rectangle {
                            background: root.current-permission-mode == "bypassPermissions" ? Tokens.accent : Tokens.secondary;
                            border-radius: Tokens.radius-md;
                            border-width: 1px;
                            border-color: root.current-permission-mode == "bypassPermissions" ? Tokens.ring : Tokens.border;
                            animate background { duration: 120ms; easing: ease-out; }
                            Text {
                                text: @tr("Bypass Permissions");
                                color: Tokens.foreground;
                                font-size: Tokens.text-sm;
                                font-weight: root.current-permission-mode == "bypassPermissions" ? Tokens.weight-bold : Tokens.weight-medium;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }
            }

            // ── Quick Actions section ─────────────────────────────
            Divider { }
            HorizontalLayout {
                spacing: Tokens.space-1 + 2px;
                Text {
                    text: @tr("QUICK ACTIONS");
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-xs;
                    font-weight: Tokens.weight-bold;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; height: 1px; }
                Text {
                    text: root.quick-actions.length;
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-xs;
                    font-family: Tokens.font-mono;
                    vertical-alignment: center;
                }
                TouchArea {
                    width: 20px;
                    height: 18px;
                    clicked => { root.add-quick-action(); }
                    Rectangle {
                        background: parent.has-hover ? Tokens.accent : transparent;
                        border-radius: Tokens.radius-sm;
                        border-width: 1px;
                        border-color: Tokens.border;
                        animate background { duration: 120ms; easing: ease-out; }
                        LucideIcon {
                            icon: IconSet.Plus;
                            size: 11px;
                            stroke: Tokens.muted-foreground;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }
                }
            }

            // Quick actions list.
            VerticalLayout {
                spacing: Tokens.space-1;
                for qa in root.quick-actions: Rectangle {
                    background: Tokens.secondary;
                    border-radius: Tokens.radius-md;
                    border-width: 1px;
                    border-color: Tokens.border;

                    VerticalLayout {
                        padding: Tokens.space-1 + 2px;
                        padding-left: Tokens.space-3;
                        padding-right: Tokens.space-3;
                        spacing: 2px;

                        // Top row: shortcut + name input + kind toggle + delete.
                        HorizontalLayout {
                            spacing: Tokens.space-2;
                            alignment: start;
                            VerticalLayout {
                                alignment: center;
                                width: 46px;
                                if qa.shortcut != "": ShortcutKeys {
                                    cmd: true; alt: true; key: qa.shortcut;
                                    icon-size: 11px;
                                }
                                if qa.shortcut == "": Text {
                                    text: "—";
                                    color: Tokens.muted-foreground;
                                    font-size: Tokens.text-xs;
                                    font-family: Tokens.font-mono;
                                }
                            }
                            qa-name := Input {
                                horizontal-stretch: 1;
                                input-height: 26px;
                                text: qa.name;
                                placeholder: @tr("name");
                                edited(t) => {
                                    root.update-quick-action(qa.id, t, qa.kind, qa-body.text);
                                }
                            }

                            // Kind toggle: click to flip claude ↔ shell.
                            TouchArea {
                                width: 58px;
                                height: 22px;
                                clicked => {
                                    root.update-quick-action(
                                        qa.id,
                                        qa-name.text,
                                        qa.kind == "claude" ? "shell" : "claude",
                                        qa-body.text,
                                    );
                                }
                                Rectangle {
                                    background: parent.has-hover ? Tokens.accent : transparent;
                                    border-radius: Tokens.radius-sm;
                                    border-width: 1px;
                                    border-color: Tokens.border;
                                    animate background { duration: 120ms; easing: ease-out; }
                                    Text {
                                        text: qa.kind;
                                        color: qa.kind == "claude" ? Tokens.kind-feature : Tokens.kind-enhancement;
                                        font-size: Tokens.text-xs;
                                        font-weight: Tokens.weight-medium;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: parent.width;
                                        height: parent.height;
                                    }
                                }
                            }

                            // Delete button.
                            CloseButton {
                                size: 20px;
                                clicked => { root.delete-quick-action(qa.id); }
                            }
                        }

                        // Bottom row: body input (prompt or shell command).
                        qa-body := Input {
                            input-height: 26px;
                            text: qa.body;
                            placeholder: qa.kind == "claude" ? @tr("prompt text…") : @tr("shell command…");
                            edited(t) => {
                                root.update-quick-action(qa.id, qa-name.text, qa.kind, t);
                            }
                        }
                    }
                }
            }

            // ── Process Manager section ───────────────────────────
            Divider { }
            HorizontalLayout {
                spacing: Tokens.space-1 + 2px;
                Text {
                    text: @tr("PROCESSES");
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-xs;
                    font-weight: Tokens.weight-bold;
                }
                Rectangle { horizontal-stretch: 1; height: 1px; }
                Button {
                    text: @tr("refresh");
                    variant: "outline";
                    size: "sm";
                    leading-icon: "rotate-cw";
                    clicked => { root.refresh-processes(); }
                }
                Button {
                    text: @tr("stop all");
                    variant: "outline";
                    size: "sm";
                    disabled: root.processes.length == 0;
                    clicked => { root.stop-all-sessions(); }
                }
                Button {
                    text: @tr("kill all");
                    variant: "destructive";
                    size: "sm";
                    leading-icon: "x";
                    disabled: root.processes.length == 0;
                    clicked => { root.kill-all-processes(); }
                }
                Text {
                    text: root.processes.length;
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-xs;
                    font-family: Tokens.font-mono;
                    vertical-alignment: center;
                }
            }

            VerticalLayout {
                spacing: Tokens.space-1;
                if root.processes.length == 0: Text {
                    text: @tr("No agent processes detected.");
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-sm;
                }
                for p in root.processes: Rectangle {
                    height: 34px;
                    background: Tokens.secondary;
                    border-radius: Tokens.radius-md;
                    border-width: 1px;
                    border-color: Tokens.border;
                    HorizontalLayout {
                        padding-left: Tokens.space-3;
                        padding-right: Tokens.space-1 + 2px;
                        spacing: Tokens.space-2;
                        alignment: start;
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 8px;
                                height: 8px;
                                border-radius: 4px;
                                background: p.class == "tracked" ? Tokens.kind-enhancement
                                          : p.class == "orphan" ? Tokens.destructive
                                                                 : #f5b54e;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            Text {
                                text: p.name + "  " + p.pid;
                                color: Tokens.foreground;
                                font-size: Tokens.text-sm;
                                font-family: Tokens.font-mono;
                            }
                            Text {
                                text: p.class;
                                color: Tokens.muted-foreground;
                                font-size: Tokens.text-xs;
                            }
                        }
                        Button {
                            text: @tr("stop");
                            variant: "outline";
                            size: "sm";
                            clicked => { root.process-kill(p.pid); }
                        }
                        Button {
                            text: @tr("kill");
                            variant: "destructive";
                            size: "sm";
                            clicked => { root.process-force-kill(p.pid); }
                        }
                    }
                }
            }
        }
    }
}
