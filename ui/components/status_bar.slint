// Polish 13 — bottom status bar showing per-column counts, live
// session dots, and total task count. Properties are pushed by
// `refresh_kanban` in Rust on every refresh.

import { Tokens } from "../tokens.slint";
import { SessionDotData } from "../data.slint";

export component StatusBar inherits Rectangle {
    in property <int> stats-backlog: 0;
    in property <int> stats-planning: 0;
    in property <int> stats-implementation: 0;
    in property <int> stats-review: 0;
    in property <int> stats-done: 0;
    in property <int> stats-misc: 0;
    in property <int> stats-sessions: 0;
    in property <int> stats-total: 0;
    // Phase D — per-session dots with state-based colour.
    in property <[SessionDotData]> session-dots;
    callback session-dot-clicked(string);

    background: Tokens.card;

    Rectangle {
        x: 0; y: 0;
        width: parent.width; height: 1px;
        background: Tokens.border;
    }

    HorizontalLayout {
        padding-left: Tokens.space-3;
        padding-right: Tokens.space-3;
        spacing: Tokens.space-3;
        alignment: start;

        Text {
            text: @tr("Backlog") + " " + root.stats-backlog;
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
            font-family: Tokens.font-mono;
            vertical-alignment: center;
        }
        Text { text: "·"; color: Tokens.muted-foreground; font-size: Tokens.text-xs; vertical-alignment: center; }
        Text {
            text: @tr("Planning") + " " + root.stats-planning;
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
            font-family: Tokens.font-mono;
            vertical-alignment: center;
        }
        Text { text: "·"; color: Tokens.muted-foreground; font-size: Tokens.text-xs; vertical-alignment: center; }
        Text {
            text: @tr("Impl") + " " + root.stats-implementation;
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
            font-family: Tokens.font-mono;
            vertical-alignment: center;
        }
        Text { text: "·"; color: Tokens.muted-foreground; font-size: Tokens.text-xs; vertical-alignment: center; }
        Text {
            text: @tr("Review") + " " + root.stats-review;
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
            font-family: Tokens.font-mono;
            vertical-alignment: center;
        }
        Text { text: "·"; color: Tokens.muted-foreground; font-size: Tokens.text-xs; vertical-alignment: center; }
        Text {
            text: @tr("Done") + " " + root.stats-done;
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
            font-family: Tokens.font-mono;
            vertical-alignment: center;
        }
        Text { text: "·"; color: Tokens.muted-foreground; font-size: Tokens.text-xs; vertical-alignment: center; }
        Text {
            text: @tr("Misc") + " " + root.stats-misc;
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
            font-family: Tokens.font-mono;
            vertical-alignment: center;
        }

        Rectangle { horizontal-stretch: 1; }

        // Phase D — per-session coloured dots. Green = busy,
        // amber = awaiting, grey = stopped/exited. Clickable.
        for dot in root.session-dots: Rectangle {
            width: 16px;
            height: self.width;
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 7px;
                        height: 7px;
                        border-radius: 3.5px;
                        background: dot.session-state == "busy"     ? Tokens.kind-enhancement
                                  : dot.session-state == "awaiting" ? Tokens.kind-feature
                                  : Tokens.muted-foreground;
                    }
                }
            }
            TouchArea {
                clicked => { root.session-dot-clicked(dot.task-id); }
            }
        }

        if root.session-dots.length == 0: Text {
            text: @tr("0 sessions");
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
            font-family: Tokens.font-mono;
            vertical-alignment: center;
        }

        Text { text: "·"; color: Tokens.muted-foreground; font-size: Tokens.text-xs; vertical-alignment: center; }
        Text {
            text: root.stats-total + " " + @tr("tasks total");
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
            font-family: Tokens.font-mono;
            vertical-alignment: center;
        }
    }
}
