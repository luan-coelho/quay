// Left sidebar — menu items (New Task / Quick Actions / Configure /
// Sessions / Worktrees) followed by a Projects section. Polish 24
// added a compact mode that hides labels and the Projects header
// when `collapsed` is true.

import { IconSet } from "@lucide";
import { Tokens } from "../tokens.slint";
import { MenuItemData, ProjectData, WorktreeEntryData } from "../data.slint";
import { LucideIcon } from "atoms.slint";
import { MenuRow, ProjectRow } from "menu.slint";

export component Sidebar inherits Rectangle {
    in property <[MenuItemData]> menu-items;
    in property <[ProjectData]> projects;
    in property <string> active-project-id;
    in property <[WorktreeEntryData]> worktree-entries;
    in-out property <bool> collapsed;
    in-out property <bool> worktrees-expanded: false;
    callback menu-item-clicked(string);
    callback open-new-project();
    callback project-clicked(string);
    callback worktree-clicked(string);
    callback toggle-collapsed();

    background: Tokens.sidebar;

    // Right divider.
    Rectangle {
        x: parent.width - 1px;
        y: 0;
        width: 1px;
        height: parent.height;
        background: Tokens.sidebar-border;
    }

    VerticalLayout {
        padding: Tokens.space-2;
        padding-top: Tokens.space-3;
        spacing: Tokens.space-4;

        // Collapse/expand toggle — shadcn `SidebarTrigger` pattern.
        // Rendered inside the sidebar itself (not in the window title
        // bar) because the title bar is now owned by the OS chrome.
        // Icon flips between `PanelLeftClose` (when expanded → click
        // to collapse) and `PanelLeftOpen` (when collapsed → click
        // to expand) so the affordance is immediately readable.
        HorizontalLayout {
            height: 28px;
            alignment: root.collapsed ? center : end;
            padding-right: root.collapsed ? 0px : Tokens.space-1;
            TouchArea {
                width: 28px;
                height: 28px;
                clicked => {
                    root.collapsed = !root.collapsed;
                    root.toggle-collapsed();
                }
                Rectangle {
                    background: parent.has-hover ? Tokens.sidebar-accent : transparent;
                    border-radius: Tokens.radius-sm;
                    animate background { duration: 120ms; easing: ease-out; }
                    if root.collapsed: LucideIcon {
                        icon: IconSet.PanelLeftOpen;
                        size: 15px;
                        stroke: Tokens.muted-foreground;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                    if !root.collapsed: LucideIcon {
                        icon: IconSet.PanelLeftClose;
                        size: 15px;
                        stroke: Tokens.muted-foreground;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
            }
        }

        // Menu items.
        VerticalLayout {
            spacing: 2px;
            for item in root.menu-items: MenuRow {
                item: item;
                compact: root.collapsed;
                clicked => { root.menu-item-clicked(item.id); }
            }
        }

        // Polish 20 — hairline divider before Projects section.
        Rectangle {
            height: 1px;
            background: Tokens.sidebar-border;
        }

        // Projects section.
        VerticalLayout {
            spacing: Tokens.space-1;

            // Polish 24: hide the "Projects" header + `+` row when the
            // sidebar is collapsed (compact mode shows only icons under it).
            if !root.collapsed: HorizontalLayout {
                padding-left: Tokens.space-3;
                padding-right: Tokens.space-3;
                height: 22px;
                spacing: 0px;
                alignment: start;

                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    Text {
                        text: "Projects";
                        color: Tokens.muted-foreground;
                        font-size: Tokens.text-sm;
                        font-weight: Tokens.weight-semibold;
                        vertical-alignment: center;
                    }
                }
                TouchArea {
                    width: 18px;
                    height: 18px;
                    clicked => { root.open-new-project(); }
                    Rectangle {
                        background: parent.has-hover ? Tokens.sidebar-accent : transparent;
                        border-radius: Tokens.radius-sm;
                        animate background { duration: 120ms; easing: ease-out; }
                        LucideIcon {
                            icon: IconSet.Plus;
                            size: 12px;
                            stroke: Tokens.muted-foreground;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }
                }
            }

            for project in root.projects: ProjectRow {
                project: project;
                selected: root.active-project-id == project.id;
                compact: root.collapsed;
                clicked => { root.project-clicked(project.id); }
            }
        }

        // Phase D — Worktrees section. Collapsible, hidden in compact
        // mode. Each entry shows branch name + associated task title.
        if root.worktree-entries.length > 0: Rectangle {
            height: 1px;
            background: Tokens.sidebar-border;
        }

        if root.worktree-entries.length > 0: VerticalLayout {
            spacing: Tokens.space-1;

            if !root.collapsed: HorizontalLayout {
                padding-left: Tokens.space-3;
                padding-right: Tokens.space-3;
                height: 22px;
                spacing: 0px;
                alignment: start;

                TouchArea {
                    horizontal-stretch: 1;
                    height: 22px;
                    clicked => { root.worktrees-expanded = !root.worktrees-expanded; }
                    HorizontalLayout {
                        spacing: Tokens.space-1;
                        VerticalLayout {
                            alignment: center;
                            LucideIcon {
                                icon: root.worktrees-expanded ? IconSet.ChevronDown : IconSet.ChevronRight;
                                size: 12px;
                                stroke: Tokens.muted-foreground;
                            }
                        }
                        Text {
                            text: "Worktrees";
                            color: Tokens.muted-foreground;
                            font-size: Tokens.text-sm;
                            font-weight: Tokens.weight-semibold;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            if root.worktrees-expanded && !root.collapsed: VerticalLayout {
                spacing: 2px;

                for wt in root.worktree-entries: TouchArea {
                    height: 32px;
                    clicked => { root.worktree-clicked(wt.task-id); }
                    Rectangle {
                        background: parent.has-hover ? Tokens.sidebar-accent : transparent;
                        border-radius: Tokens.radius-sm;
                        animate background { duration: 120ms; easing: ease-out; }

                        HorizontalLayout {
                            padding-left: Tokens.space-3;
                            padding-right: Tokens.space-3;
                            spacing: Tokens.space-2;
                            alignment: start;

                            VerticalLayout {
                                alignment: center;
                                LucideIcon {
                                    icon: IconSet.GitBranch;
                                    size: 13px;
                                    stroke: Tokens.muted-foreground;
                                }
                            }

                            VerticalLayout {
                                alignment: center;
                                horizontal-stretch: 1;
                                Text {
                                    text: wt.branch != "" ? wt.branch : wt.path;
                                    color: Tokens.foreground;
                                    font-size: Tokens.text-xs;
                                    font-family: Tokens.font-mono;
                                    overflow: elide;
                                }
                                if wt.task-title != "": Text {
                                    text: wt.task-title;
                                    color: Tokens.muted-foreground;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
