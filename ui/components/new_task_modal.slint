// Polish 10 / 32 — modal for creating a new task. The fields are
// `<=>` bound to MainWindow properties so the values survive reopen.
// `submit()` is the clicked-Create callback; the parent decides what
// to do with the values.
//
// Chrome (scrim + card + header + close button + divider) is
// delegated to `ModalFrame`; this file only owns the form content.

import { Tokens } from "../tokens.slint";
import { Button, FormField, Input, ModalFrame } from "atoms.slint";

export component NewTaskModal inherits Rectangle {
    in-out property <bool> open;
    in-out property <string> title-text;
    in-out property <string> instructions-text;
    in-out property <string> title-error;
    callback submit();

    ModalFrame {
        open <=> root.open;
        title: "New Task";
        card-width: 460px;
        card-height: 320px;
        closed => { root.open = false; }

        // Content slot — children become layout items in the
        // ModalFrame's internal VerticalLayout below the header.

        FormField {
            label: "TITLE";
            text <=> root.title-text;
            placeholder: "e.g. Add dark mode";
            error: root.title-error;
            edited(t) => {
                root.title-text = t;
                // Clear the error the moment the user starts editing;
                // no Rust round-trip needed — pure Slint reactivity.
                root.title-error = "";
            }
        }

        FormField {
            label: "INITIAL INSTRUCTIONS (SENT TO THE AGENT ON START)";
            text <=> root.instructions-text;
            placeholder: "optional — what should the agent do first?";
            edited(t) => { root.instructions-text = t; }
        }

        Rectangle { vertical-stretch: 1; }

        HorizontalLayout {
            spacing: Tokens.space-2;
            Rectangle { horizontal-stretch: 1; }

            Button {
                text: "Cancel";
                variant: "outline";
                size: "sm";
                clicked => { root.open = false; }
            }

            Button {
                text: "Create";
                variant: "default";
                size: "sm";
                clicked => { root.submit(); }
            }
        }
    }
}
