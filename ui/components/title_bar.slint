// In-app title bar strip — purely a contextual breadcrumb for the
// active task + the user Avatar. Ownership of window chrome (title
// text, close/minimize/maximize, sidebar-collapse trigger) is
// deliberately split:
//
//   - OS compositor: window title + macro controls (close/min/max).
//   - Sidebar header: the collapse/expand toggle (shadcn
//     `SidebarTrigger` pattern) — it lives where the thing it
//     controls lives, not on a separate bar.
//   - This TitleBar: just the "what task am I looking at?" breadcrumb
//     and Avatar, so the strip has a reason to exist beyond decoration.

import { Tokens } from "../tokens.slint";
import { Avatar } from "atoms.slint";

export component TitleBar inherits Rectangle {
    in property <string> active-task-display;
    in property <string> active-task-title;

    background: Tokens.background;

    Rectangle {
        x: 0; y: parent.height - 1px;
        width: parent.width; height: 1px;
        background: Tokens.border;
    }

    // Polish 27 — active task display id + truncated title. Was just
    // the display id ("#7"); now shows "#7 Add dark mode" so the user
    // has context even when the open-tabs strip is empty (only 1 tab
    // open). The title elides if too long.
    Rectangle {
        x: parent.width - self.width - 44px;
        y: (parent.height - self.height) / 2;
        width: title-info.preferred-width + 4px;
        height: title-info.preferred-height;
        background: transparent;

        title-info := HorizontalLayout {
            spacing: Tokens.space-2;
            alignment: end;

            Text {
                text: root.active-task-display;
                color: Tokens.muted-foreground;
                font-size: Tokens.text-sm;
                font-family: Tokens.font-mono;
                vertical-alignment: center;
            }
            Text {
                text: root.active-task-title;
                color: Tokens.foreground;
                font-size: Tokens.text-sm;
                font-weight: Tokens.weight-medium;
                vertical-alignment: center;
                overflow: elide;
                max-width: 240px;
            }
        }
    }

    // Polish 20 — user avatar circle (visual stub, no user system).
    Avatar {
        x: parent.width - self.width - 14px;
        y: (parent.height - self.height) / 2;
    }
}
