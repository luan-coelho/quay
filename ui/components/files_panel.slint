// Files tab — directory listing OR inline editor (Phase 7),
// switched by `editor-open`. The directory walker uses the flattened
// tree from `wiring::refreshes::rebuild_files`; clicking a file fires
// `entry-clicked(path, kind)` which the parent uses to either toggle
// a directory expansion or open the file in the editor.

import { ScrollView, TextEdit } from "std-widgets.slint";
import { IconSet } from "@lucide";
import { Tokens } from "../tokens.slint";
import { FileEntryData, HighlightedLineData } from "../data.slint";
import { LucideIcon, Button, Divider } from "atoms.slint";

export component FilesPanel inherits Rectangle {
    in property <[FileEntryData]> file-entries;
    in-out property <string> file-current-dir;
    in-out property <bool> editor-open;
    in-out property <string> editor-file-path;
    in-out property <string> editor-file-content;
    in property <string> editor-syntax-name;
    in property <bool> editor-file-dirty;
    in property <[HighlightedLineData]> editor-highlighted-lines;
    in property <int> editor-line-count;

    callback entry-clicked(string, string);
    callback content-changed(string);
    callback save();
    callback close();

    background: Tokens.card;
    border-radius: Tokens.radius-md;
    border-width: 1px;
    border-color: Tokens.border;
    clip: true;

    // ── File tree mode ─────────────────────────────────────
    if !root.editor-open: VerticalLayout {
        padding: Tokens.space-3;
        spacing: Tokens.space-2;

        HorizontalLayout {
            spacing: Tokens.space-1 + 2px;
            VerticalLayout {
                alignment: center;
                LucideIcon {
                    icon: IconSet.ChevronRight;
                    size: 11px;
                    stroke: Tokens.muted-foreground;
                }
            }
            Text {
                text: root.file-current-dir == "" ? "Select a task with a worktree" : root.file-current-dir;
                color: Tokens.foreground;
                font-size: Tokens.text-sm;
                font-family: Tokens.font-mono;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        Divider { }

        ScrollView {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            VerticalLayout {
                spacing: 1px;
                // Polish 17 — each row is one entry in the flattened
                // tree. Left padding scales with `depth` so nested
                // entries indent. Directory chevron flips ▸ ↔ ▾ based
                // on `expanded`.
                for entry in root.file-entries: TouchArea {
                    height: 22px;
                    clicked => {
                        root.entry-clicked(entry.path, entry.kind);
                    }
                    Rectangle {
                        background: parent.has-hover ? Tokens.accent : transparent;
                        border-radius: Tokens.radius-sm;
                        animate background { duration: 120ms; easing: ease-out; }
                        HorizontalLayout {
                            padding-left: 10px + entry.depth * 14px;
                            padding-right: Tokens.space-2;
                            spacing: Tokens.space-1 + 2px;
                            alignment: start;
                            // Directory chevron (▸/▾ replaced by Lucide
                            // ChevronRight/ChevronDown for vector
                            // rendering consistency with the rest of
                            // the UI). Files get a blank placeholder
                            // of the same width so the name column
                            // stays aligned.
                            VerticalLayout {
                                alignment: center;
                                width: 10px;
                                if entry.kind == "directory" && entry.expanded: LucideIcon {
                                    icon: IconSet.ChevronDown;
                                    size: 11px;
                                    stroke: Tokens.muted-foreground;
                                }
                                if entry.kind == "directory" && !entry.expanded: LucideIcon {
                                    icon: IconSet.ChevronRight;
                                    size: 11px;
                                    stroke: Tokens.muted-foreground;
                                }
                            }
                            // Polish 40 + 40b — real Lucide icon picked
                            // from `entry.icon`. The Rust
                            // `pick_file_icon` returns one of 11 icon
                            // names; here we resolve each name to the
                            // matching `IconSet.X` constant via a
                            // chain of `if` branches. Stroke color is
                            // the RGB triple computed in the same
                            // Rust call.
                            VerticalLayout {
                                alignment: center;
                                if entry.icon == "Folder": LucideIcon {
                                    icon: IconSet.Folder;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                                if entry.icon == "FileCode": LucideIcon {
                                    icon: IconSet.FileCode;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                                if entry.icon == "FileText": LucideIcon {
                                    icon: IconSet.FileText;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                                if entry.icon == "FileBraces": LucideIcon {
                                    icon: IconSet.FileBraces;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                                if entry.icon == "FileLock": LucideIcon {
                                    icon: IconSet.FileLock;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                                if entry.icon == "FileTerminal": LucideIcon {
                                    icon: IconSet.FileTerminal;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                                if entry.icon == "FileImage": LucideIcon {
                                    icon: IconSet.FileImage;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                                if entry.icon == "FileMusic": LucideIcon {
                                    icon: IconSet.FileMusic;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                                if entry.icon == "FileVideoCamera": LucideIcon {
                                    icon: IconSet.FileVideoCamera;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                                if entry.icon == "FileArchive": LucideIcon {
                                    icon: IconSet.FileArchive;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                                if entry.icon == "File": LucideIcon {
                                    icon: IconSet.File;
                                    size: 14px;
                                    stroke: rgb(entry.icon-r, entry.icon-g, entry.icon-b);
                                }
                            }
                            Text {
                                text: entry.name;
                                color: Tokens.foreground;
                                font-size: Tokens.text-sm;
                                font-family: Tokens.font-mono;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }

        Text {
            text: "Click a text file to open it in the built-in editor. Binary or very large files fall back to $EDITOR.";
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
        }
    }

    // ── Inline editor mode (Phase 7) ───────────────────────
    if root.editor-open: VerticalLayout {
        padding: Tokens.space-3;
        spacing: Tokens.space-2;

        // Header with path, syntax, dirty indicator, save/close buttons.
        HorizontalLayout {
            spacing: Tokens.space-2;
            alignment: start;

            // Back / close button.
            TouchArea {
                width: 22px;
                height: 22px;
                clicked => { root.close(); }
                Rectangle {
                    background: parent.has-hover ? Tokens.accent : transparent;
                    border-radius: Tokens.radius-sm;
                    animate background { duration: 120ms; easing: ease-out; }
                    LucideIcon {
                        icon: IconSet.ArrowLeft;
                        size: 14px;
                        stroke: Tokens.muted-foreground;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                    }
                }
            }

            Text {
                text: root.editor-file-path;
                color: Tokens.foreground;
                font-size: Tokens.text-sm;
                font-family: Tokens.font-mono;
                overflow: elide;
                vertical-alignment: center;
            }

            // Dirty dot.
            Rectangle {
                visible: root.editor-file-dirty;
                width: 6px;
                height: 6px;
                y: (parent.height - self.height) / 2;
                border-radius: 3px;
                background: #f5b54e;
            }

            Rectangle { horizontal-stretch: 1; }

            // Syntax badge.
            Rectangle {
                width: syn-text.preferred-width + 12px;
                height: 18px;
                border-radius: Tokens.radius-md;
                border-width: 1px;
                border-color: Tokens.border;
                syn-text := Text {
                    text: root.editor-syntax-name;
                    color: Tokens.muted-foreground;
                    font-size: Tokens.text-xs;
                    font-weight: Tokens.weight-medium;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
            }

            // Save button — shadcn Button with the `success` variant
            // to keep the kind-enhancement green tint of the original.
            Button {
                text: "save";
                variant: "success";
                size: "sm";
                leading-icon: "check";
                clicked => { root.save(); }
            }
        }

        Divider { }

        // ── Syntect-coloured read-only preview ──────────────
        // Shows the last saved state of the file with per-token
        // colouring. Updates on save so it always reflects disk state.
        Rectangle {
            height: 220px;
            background: Tokens.background;
            border-radius: Tokens.radius-sm;
            border-width: 1px;
            border-color: Tokens.border;
            clip: true;

            ScrollView {
                VerticalLayout {
                    padding: Tokens.space-2;
                    spacing: 0px;
                    if root.editor-line-count == 0: Text {
                        text: "(empty file)";
                        color: Tokens.muted-foreground;
                        font-size: Tokens.text-xs;
                        font-family: Tokens.font-mono;
                    }
                    for line in root.editor-highlighted-lines: HorizontalLayout {
                        spacing: Tokens.space-2;
                        alignment: start;
                        Text {
                            text: line.line-no;
                            color: Tokens.muted-foreground;
                            font-size: Tokens.text-xs;
                            font-family: Tokens.font-mono;
                            width: 32px;
                            horizontal-alignment: right;
                        }
                        HorizontalLayout {
                            spacing: 0px;
                            alignment: start;
                            horizontal-stretch: 1;
                            for span in line.spans: Text {
                                text: span.text;
                                color: rgb(span.color-r, span.color-g, span.color-b);
                                font-size: Tokens.text-sm;
                                font-family: Tokens.font-mono;
                            }
                        }
                    }
                }
            }
        }

        // ── Editable TextEdit ───────────────────────────────
        // Plain (non-coloured) text editing surface. Slint's built-in
        // TextEdit doesn't support per-token colour so editing happens
        // in uniform text; the preview above shows the colours for the
        // last saved state.
        TextEdit {
            text: root.editor-file-content;
            wrap: no-wrap;
            horizontal-stretch: 1;
            vertical-stretch: 1;
            font-size: Tokens.text-base;
            edited => {
                root.content-changed(self.text);
            }
        }

        Text {
            text: "Top pane: syntect-coloured preview of the last saved state. Bottom pane: plain editable text. Save to refresh the preview.";
            color: Tokens.muted-foreground;
            font-size: Tokens.text-xs;
        }
    }
}
