// Polish 26 + 32 — keyboard shortcuts overlay. Toggled by Cmd+? from
// the dispatcher in `src/main.rs`. Esc closes (handled in the existing
// modal escape branch). The list is hard-coded — keep it in sync with
// the actual hotkey table in `src/hotkeys.rs::classify_hotkey`.

import { Tokens } from "../tokens.slint";
import { CloseButton, Divider } from "atoms.slint";
import { ShortcutRow } from "menu.slint";

export component ShortcutsOverlay inherits Rectangle {
    in-out property <bool> open;

    visible: open;
    background: rgba(0, 0, 0, 60%);
    opacity: open ? 1.0 : 0.0;
    animate opacity { duration: 160ms; easing: ease-out; }

    TouchArea {
        clicked => { root.open = false; }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        // Polish 33 — slide-down + fade.
        y: (parent.height - self.height) / 2 + (root.open ? 0px : -12px);
        opacity: root.open ? 1.0 : 0.0;
        animate y { duration: 200ms; easing: ease-out; }
        animate opacity { duration: 180ms; easing: ease-out; }
        width: 540px;
        height: 460px;
        background: Tokens.popover;
        border-radius: Tokens.radius-lg;
        border-width: 1px;
        border-color: Tokens.border;
        clip: true;

        // Block click-through.
        TouchArea { }

        VerticalLayout {
            padding: Tokens.space-6;
            spacing: Tokens.space-4 - 2px;

            HorizontalLayout {
                spacing: Tokens.space-2;
                Text {
                    text: @tr("Keyboard Shortcuts");
                    color: Tokens.foreground;
                    font-size: Tokens.text-xl - 2px;
                    font-weight: Tokens.weight-bold;
                }
                Rectangle { horizontal-stretch: 1; }
                CloseButton {
                    size: 24px;
                    clicked => { root.open = false; }
                }
            }

            Divider { }

            VerticalLayout {
                spacing: Tokens.space-4;

                // Tasks group
                VerticalLayout {
                    spacing: Tokens.space-1;
                    Text {
                        text: @tr("TASKS");
                        color: Tokens.muted-foreground;
                        font-size: Tokens.text-xs;
                        font-weight: Tokens.weight-bold;
                    }
                    ShortcutRow { cmd: true; key: "N"; label: @tr("New CLI session"); }
                    ShortcutRow { cmd: true; del: true; label: @tr("Delete active task"); }
                }

                // Tabs group
                VerticalLayout {
                    spacing: Tokens.space-1;
                    Text {
                        text: @tr("OPEN TABS");
                        color: Tokens.muted-foreground;
                        font-size: Tokens.text-xs;
                        font-weight: Tokens.weight-bold;
                    }
                    ShortcutRow { cmd: true; key: "W"; label: @tr("Close active tab"); }
                    ShortcutRow { cmd: true; shift: true; key: "W"; label: @tr("Close all OTHER tabs"); }
                    ShortcutRow { cmd: true; alt: true; key: "W"; label: @tr("Close ALL tabs"); }
                    ShortcutRow { cmd: true; shift: true; key: "]"; label: @tr("Cycle to next tab"); }
                    ShortcutRow { cmd: true; shift: true; key: "["; label: @tr("Cycle to previous tab"); }
                }

                // Quick Actions group
                VerticalLayout {
                    spacing: Tokens.space-1;
                    Text {
                        text: @tr("QUICK ACTIONS");
                        color: Tokens.muted-foreground;
                        font-size: Tokens.text-xs;
                        font-weight: Tokens.weight-bold;
                    }
                    ShortcutRow { cmd: true; alt: true; key: "1..9"; label: @tr("Run quick action by index"); }
                }

                // System group
                VerticalLayout {
                    spacing: Tokens.space-1;
                    Text {
                        text: @tr("SYSTEM");
                        color: Tokens.muted-foreground;
                        font-size: Tokens.text-xs;
                        font-weight: Tokens.weight-bold;
                    }
                    ShortcutRow { cmd: true; key: "P"; label: @tr("Quick task switcher"); }
                    ShortcutRow { cmd: true; key: ","; label: @tr("Open Settings"); }
                    ShortcutRow { cmd: true; key: "?"; label: @tr("Show this overlay"); }
                    ShortcutRow { cmd: true; shift: true; key: "V"; label: @tr("Paste from clipboard"); }
                    ShortcutRow { key: "Esc"; label: @tr("Close any open modal"); }
                }
            }

            Rectangle { vertical-stretch: 1; }

            Text {
                text: @tr("Tip: Cmd on macOS, Ctrl elsewhere. Esc closes this overlay.");
                color: Tokens.muted-foreground;
                font-size: Tokens.text-xs;
                horizontal-alignment: center;
            }
        }
    }
}
