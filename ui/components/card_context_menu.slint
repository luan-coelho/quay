// Card context menu — right-click on a kanban card. Triggered by
// right-clicking any CardRow. The menu floats at the cursor position
// via `anchor-x` / `anchor-y` and operates on `target-id` (the card
// that was clicked, NOT necessarily the active task).
// Click outside or Esc dismisses. Items: move to column, stop session,
// delete task — matching the Lanes reference.

import { Tokens } from "../tokens.slint";
import { TabMenuRow } from "menu.slint";

export component CardContextMenu inherits Rectangle {
    in-out property <bool> open;
    in-out property <string> target-id;
    in-out property <length> anchor-x;
    in-out property <length> anchor-y;
    // Whether the target task has a running session.
    in property <bool> target-has-session;
    callback stop-task-session(string);       // task-id
    callback delete-card(string);             // task-id

    visible: open;
    background: transparent;

    // Click anywhere outside the menu card dismisses.
    TouchArea {
        clicked => { root.open = false; }
    }

    Rectangle {
        x: min(root.anchor-x, parent.width - self.width - 8px);
        y: min(root.anchor-y, parent.height - self.height - 8px);
        width: 220px;
        height: menu-stack.preferred-height + 12px;
        background: Tokens.popover;
        border-radius: Tokens.radius-lg;
        border-width: 1px;
        border-color: Tokens.border;
        opacity: root.open ? 1.0 : 0.0;
        animate opacity { duration: 140ms; easing: ease-out; }

        // Block click-through.
        TouchArea {}

        menu-stack := VerticalLayout {
            padding: Tokens.space-1 + 2px;
            spacing: 2px;

            TabMenuRow {
                label: @tr("Stop session");
                enabled: root.target-has-session;
                clicked => {
                    root.stop-task-session(root.target-id);
                    root.open = false;
                }
            }

            Rectangle {
                height: 1px;
                background: Tokens.border;
            }

            TabMenuRow {
                label: @tr("Delete task");
                clicked => {
                    root.delete-card(root.target-id);
                    root.open = false;
                }
            }
        }
    }
}
